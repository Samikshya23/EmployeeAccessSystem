@model IEnumerable<EmployeeAccessSystem.Models.AccessRequest>

@{
    ViewData["Title"] = "Request History";
    Layout = "~/Views/Shared/_SupervisorLayout.cshtml";
    int sn = 1;
    string currentSearch = ViewBag.Search ?? "";
    string currentStatus = ViewBag.Status ?? "All";
}

<style>
    .page-card {
        background: #ffffff;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        padding: 24px;
    }

    .page-subtitle {
        color: #6b7280;
        margin-bottom: 18px;
        font-size: 15px;
    }

    .toolbar-row {
        margin-bottom: 18px;
    }

    .toolbar-form {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
    }

    .toolbar-left {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .toolbar-input,
    .toolbar-select {
        border: 1px solid #dbe3ef;
        border-radius: 10px;
        padding: 10px 12px;
        background: #fff;
        min-width: 220px;
        font-size: 14px;
        outline: none;
    }

    .search-btn {
        background: #0f172a;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 10px 16px;
        font-weight: 600;
        font-size: 14px;
    }

    .table-wrap {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
    }

    .table {
        margin-bottom: 0;
    }

        .table thead th {
            background: #f8fafc;
            color: #334155;
            font-weight: 700;
            font-size: 14px;
            vertical-align: middle;
            white-space: nowrap;
            border-bottom: 1px solid #e5e7eb;
        }

        .table tbody td {
            vertical-align: middle;
            font-size: 15px;
            color: #1f2937;
        }

    .employee-name {
        font-weight: 600;
        color: #111827;
    }

    .server-ip {
        color: #64748b;
        font-size: 13px;
        margin-top: 2px;
    }

    .status-badge {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 600;
    }

    .approved {
        background: #ecfdf3;
        color: #15803d;
    }

    .rejected {
        background: #fef2f2;
        color: #b91c1c;
    }

    .saved-comment {
        max-width: 220px;
        color: #64748b;
        font-size: 14px;
        white-space: normal;
        word-break: break-word;
    }

    .empty-box {
        background: #f8fafc;
        border: 1px dashed #cbd5e1;
        border-radius: 14px;
        padding: 30px;
        text-align: center;
        color: #64748b;
    }
</style>

<div class="page-card">
    <div class="page-subtitle">
        View approved and rejected requests with supervisor comments.
    </div>

    <div class="toolbar-row">
        <form method="get" id="historyForm" class="toolbar-form">
            <div class="toolbar-left">
                <input type="text"
                       name="search"
                       value="@currentSearch"
                       class="toolbar-input"
                       placeholder="Search employee, category, server..." />

                <select name="status"
                        class="toolbar-select"
                        onchange="document.getElementById('historyForm').submit();">
                    @if (currentStatus == "All")
                    {
                        <option value="All" selected>All</option>
                    }
                    else
                    {
                        <option value="All">All</option>
                    }

                    @if (currentStatus == "Approved")
                    {
                        <option value="Approved" selected>Approved</option>
                    }
                    else
                    {
                        <option value="Approved">Approved</option>
                    }

                    @if (currentStatus == "Rejected")
                    {
                        <option value="Rejected" selected>Rejected</option>
                    }
                    else
                    {
                        <option value="Rejected">Rejected</option>
                    }
                </select>
            </div>

            <button type="submit" class="search-btn">Search</button>
        </form>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-box">
            No reviewed requests found.
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>SN</th>
                        <th>Employee</th>
                        <th>Category</th>
                        <th>Server</th>
                        <th>Duration</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Comment</th>
                        <th>Action Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var statusClass = item.SupervisorStatus == "Approved" ? "approved" : "rejected";

                        <tr>
                            <td>@sn</td>
                            <td><div class="employee-name">@item.EmployeeName</div></td>
                            <td>@item.CategoryName</td>
                            <td>
                                <div>@item.ServerName</div>
                                <div class="server-ip">@item.ServerIP</div>
                            </td>
                            <td>@item.Duration</td>
                            <td>@item.RequestReason</td>
                            <td>
                                <span class="status-badge @statusClass">@item.SupervisorStatus</span>
                            </td>
                            <td>
                                <div class="saved-comment">
                                    @(string.IsNullOrWhiteSpace(item.SupervisorComment) ? "-" : item.SupervisorComment)
                                </div>
                            </td>
                            <td>
                                @(item.SupervisorActionDate.HasValue
                                                        ? item.SupervisorActionDate.Value.ToString("yyyy-MM-dd hh:mm tt")
                                                        : "-")
                    </td>
                </tr>

                                sn++;
                    }
                </tbody>
            </table>
        </div>
    }
</div>