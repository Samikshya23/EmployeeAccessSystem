<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - EmployeeAccessSystem</title>

    <link rel="stylesheet" href="~/adminlte/plugins/fontawesome-free/css/all.min.css" />
    <link rel="stylesheet" href="~/adminlte/plugins/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            min-height: 100vh;
            margin: 0;
            background: #f4f6f9;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        .form-page-wrap {
            width: 100%;
            max-width: 520px;
        }

        .form-page-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .form-page-header {
            padding: 18px 22px;
            border-bottom: 1px solid #edf1f5;
            background: #ffffff;
        }

        .form-page-title {
            margin: 0;
            font-size: 22px;
            font-weight: 700;
            color: #1f2937;
            line-height: 1.3;
        }

        .form-page-body {
            padding: 22px;
        }

        .form-row-custom {
            margin-bottom: 18px;
        }

        .form-label {
            font-size: 14px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 8px;
        }

        .form-control,
        .form-select {
            height: 44px;
            border-radius: 12px;
            border: 1px solid #d1d5db;
            font-size: 14px;
            color: #1f2937;
            box-shadow: none;
        }

            .form-control:focus,
            .form-select:focus {
                border-color: #94a3b8;
                box-shadow: 0 0 0 0.12rem rgba(148, 163, 184, 0.18);
            }

        .toggle-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 6px;
            margin-bottom: 22px;
        }

        .toggle-label {
            margin: 0;
            font-size: 14px;
            font-weight: 600;
            color: #374151;
        }

        .switch {
            position: relative;
            display: inline-block;
            width: 52px;
            height: 30px;
            margin: 0;
        }

            .switch input {
                opacity: 0;
                width: 0;
                height: 0;
                position: absolute;
            }

        .slider {
            position: absolute;
            inset: 0;
            cursor: pointer;
            background-color: #cbd5e1;
            transition: .25s ease;
            border-radius: 999px;
        }

            .slider:before {
                content: "";
                position: absolute;
                height: 22px;
                width: 22px;
                left: 4px;
                top: 4px;
                background: #ffffff;
                border-radius: 50%;
                transition: .25s ease;
                box-shadow: 0 2px 6px rgba(0,0,0,0.16);
            }

        .switch input:checked + .slider {
            background-color: #22c55e;
        }

            .switch input:checked + .slider:before {
                transform: translateX(22px);
            }

        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        .btn-form {
            min-width: 102px;
            height: 42px;
            padding: 0 18px;
            border-radius: 999px;
            font-size: 14px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none !important;
            transition: all 0.2s ease;
            box-shadow: none;
        }

            .btn-form:hover,
            .btn-form:focus {
                text-decoration: none !important;
            }

        .btn-back {
            background: #ffffff;
            color: #475569;
            border: 1px solid #9ca3af;
        }

            .btn-back:hover {
                background: #f8fafc;
                color: #334155;
                border-color: #6b7280;
            }

        .btn-save {
            background: #1d4ed8;
            color: #ffffff;
            border: 1px solid #1d4ed8;
        }

            .btn-save:hover {
                background: #1e40af;
                border-color: #1e40af;
                color: #ffffff;
            }

        .btn-update {
            background: #c56a04;
            color: #ffffff;
            border: 1px solid #c56a04;
        }

            .btn-update:hover {
                background: #a85604;
                border-color: #a85604;
                color: #ffffff;
            }

        .btn-delete {
            background: #dc2626;
            color: #ffffff;
            border: 1px solid #dc2626;
        }

            .btn-delete:hover {
                background: #b91c1c;
                border-color: #b91c1c;
                color: #ffffff;
            }

        .delete-note {
            font-size: 14px;
            color: #4b5563;
            margin-bottom: 14px;
        }

        .table.form-view-table {
            margin-bottom: 0;
            border-color: #d8dee6;
        }

            .table.form-view-table th {
                width: 160px;
                background: #f8fafc;
                color: #374151;
                font-weight: 600;
            }

            .table.form-view-table th,
            .table.form-view-table td {
                padding: 12px 14px;
                vertical-align: middle;
            }

        .text-danger-validation {
            font-size: 13px;
        }

        @@media (max-width: 576px) {
            .form-page-wrap {
                max-width: 100%;
            }

            .form-page-header {
                padding: 16px 18px;
            }

            .form-page-body {
                padding: 18px;
            }

            .form-page-title {
                font-size: 20px;
            }

            .btn-form {
                min-width: 96px;
            }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="form-page-wrap">
        <div class="form-page-card">
            @RenderBody()
        </div>
    </div>

    <script src="~/adminlte/plugins/jquery/jquery.min.js"></script>
    <script src="~/adminlte/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>