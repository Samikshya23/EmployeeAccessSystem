<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EmployeeAccessSystem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        body {
            margin: 0;
            background: #f4f7fb;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .supervisor-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .supervisor-sidebar {
            width: 250px;
            background: linear-gradient(180deg, #0f172a, #1e293b);
            color: white;
            padding: 24px 0;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
        }

        .supervisor-brand {
            font-size: 22px;
            font-weight: 700;
            text-align: center;
            margin-bottom: 30px;
        }

        .supervisor-sidebar a {
            display: block;
            color: #e2e8f0;
            text-decoration: none;
            padding: 14px 24px;
            font-size: 16px;
            transition: 0.3s;
        }

            .supervisor-sidebar a:hover {
                background: rgba(255,255,255,0.08);
                color: white;
            }

        .supervisor-content {
            margin-left: 250px;
            width: calc(100% - 250px);
            padding: 30px;
        }

        .topbar {
            background: white;
            border-radius: 18px;
            padding: 18px 24px;
            margin-bottom: 24px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .topbar-title {
            font-size: 22px;
            font-weight: 700;
            color: #0f172a;
        }

        .logout-btn {
            color: white;
            background: #ef4444;
            padding: 10px 18px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 600;
        }

            .logout-btn:hover {
                background: #dc2626;
                color: white;
            }
    </style>
</head>
<body>
    <div class="supervisor-wrapper">
        <div class="supervisor-sidebar">
            <div class="supervisor-brand">Supervisor Panel</div>

            <a asp-controller="SupervisorDashboard" asp-action="PendingRequests">
                <i class="fa fa-clock me-2"></i> Pending Requests
            </a>

            <a asp-controller="SupervisorDashboard" asp-action="RequestHistory">
                <i class="fa fa-folder-open me-2"></i> Request History
            </a>

            <a asp-controller="Account" asp-action="Logout">
                <i class="fa fa-right-from-bracket me-2"></i> Logout
            </a>
        </div>

        <div class="supervisor-content">
            <div class="topbar">
                <div class="topbar-title">@ViewData["Title"]</div>
                <a asp-controller="Account" asp-action="Logout" class="logout-btn">Logout</a>
            </div>

            @RenderBody()
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>