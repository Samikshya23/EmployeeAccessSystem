@model EmployeeAccessSystem.Models.PingProductField

@{
    Layout = null;
}

<form asp-action="Delete" method="post" id="deletePingProductFieldForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="pingProductFieldId" value="@Model.PingProductFieldId" />

    <h5 class="text-center mb-2">
        Are you sure?
    </h5>

    <p class="text-center mb-4" style="color:#000;">
        You want to delete this Ping Product Field
        <span>"@Model.FieldName"</span>
    </p>

    <div class="modal-footer justify-content-center border-0 pt-0">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">
            Cancel
        </button>
        <button type="submit" class="btn btn-danger">
            Confirm
        </button>
    </div>
</form>