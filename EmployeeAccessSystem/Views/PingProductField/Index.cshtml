@model IEnumerable<EmployeeAccessSystem.Models.PingProductField>
@{
    ViewData["Title"] = "Ping Product Field";
    int sn = 1;
    var shownProductIds = new List<int>();
}

<section class="content pt-2 pb-0">
    <div class="container-fluid px-0">

        <div class="row mb-2 mx-0 align-items-center">
            <div class="col-sm-6 px-0">
                <h3 class="mb-0">Ping Product Field</h3>
            </div>
            <div class="col-sm-6 text-right px-0">
                <a asp-action="Create"
                   asp-controller="PingProductField"
                   class="btn btn-primary rounded-pill open-modal-btn"
                   data-title="Add Ping Product Field">
                    <i class="fas fa-plus mr-1"></i> Add
                </a>
            </div>
        </div>

        <div class="card mb-0 border-left border-right border-bottom shadow-none rounded-0">
            <div class="card-header bg-white border-bottom-0 py-1 px-2 rounded-0">
                <div class="d-flex justify-content-end">
                    <div class="col-md-3 px-0">
                        <input type="text"
                               id="customSearch"
                               class="form-control form-control-sm"
                               placeholder="Search" />
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                <table id="pingProductFieldTable"
                       class="table table-bordered table-hover table-sm mb-0 rounded-0"
                       style="border-color:#dee2e6;">
                    <thead class="bg-light border-bottom">
                        <tr>
                            <th class="text-center align-middle" style="width:70px;">SN</th>
                            <th class="text-center align-middle" style="width:35%;">Ping Product</th>
                            <th class="text-center align-middle" style="width:35%;">Field Name</th>
                            <th class="text-center align-middle" style="width:110px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var product in Model)
                            {
                                if (!shownProductIds.Contains(product.PingProductId))
                                {
                                    shownProductIds.Add(product.PingProductId);

                                    var groupItems = new List<EmployeeAccessSystem.Models.PingProductField>();

                                    foreach (var item in Model)
                                    {
                                        if (item.PingProductId == product.PingProductId)
                                        {
                                            groupItems.Add(item);
                                        }
                                    }

                                    string combinedFieldNames = "";
                                    bool firstText = true;

                                    foreach (var groupItem in groupItems)
                                    {
                                        if (firstText)
                                        {
                                            combinedFieldNames = groupItem.FieldName;
                                            firstText = false;
                                        }
                                        else
                                        {
                                            combinedFieldNames = combinedFieldNames + " " + groupItem.FieldName;
                                        }
                                    }

                                    <tr>
                                        <td class="text-center align-middle" style="vertical-align: middle !important;">
                                            @sn
                                        </td>

                                        <td class="align-middle" style="vertical-align: middle !important;">
                                            @product.PingProductName
                                        </td>

                                        <td class="p-0 align-top" data-order="@combinedFieldNames">
                                            <table class="table table-sm mb-0" style="table-layout:fixed;">
                                                <tbody>
                                                    @for (int i = 0; i < groupItems.Count; i++)
                                                    {
                                                        <tr>
                                                            <td class="p-0 align-middle @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                                <div class="d-flex align-items-center px-2" style="height:34px;">
                                                                    @groupItems[i].FieldName
                                                                    @if (!groupItems[i].IsActive)
                                                                    {
                                                                        <span class="text-muted ml-2">(Inactive)</span>
                                                                    }
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </td>

                                        <td class="p-0 align-top">
                                            <table class="table table-sm mb-0" style="table-layout:fixed;">
                                                <tbody>
                                                    @for (int i = 0; i < groupItems.Count; i++)
                                                    {
                                                        <tr>
                                                            <td class="p-0 align-middle text-center @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                                <div class="d-flex justify-content-center align-items-center" style="height:34px; gap:4px;">
                                                                    <a asp-action="Edit"
                                                                       asp-controller="PingProductField"
                                                                       asp-route-id="@groupItems[i].PingProductFieldId"
                                                                       class="btn btn-xs btn-light border open-modal-btn"
                                                                       data-title="Edit Ping Product Field"
                                                                       title="Edit">
                                                                        <i class="fas fa-pen"></i>
                                                                    </a>

                                                                    <a asp-action="Delete"
                                                                       asp-controller="PingProductField"
                                                                       asp-route-id="@groupItems[i].PingProductFieldId"
                                                                       class="btn btn-xs btn-outline-danger open-modal-btn"
                                                                       data-title="Delete Ping Product Field"
                                                                       title="Delete">
                                                                        <i class="fas fa-trash-alt"></i>
                                                                    </a>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </td>
                                    </tr>

                                    sn++;
                                }
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center align-middle">No Ping Product Fields found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>

<div class="modal fade" id="mainActionModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered modal-md" role="document">
        <div class="modal-content rounded-0">
            <div class="modal-header">
                <h5 class="modal-title" id="mainActionModalTitle">Ping Product Field</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body" id="mainActionModalBody">
                <div class="text-center py-3">
                    <i class="fas fa-spinner fa-spin mr-2"></i> Loading...
                </div>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <div class="position-fixed" style="top: 15px; right: 15px; z-index: 1055;">

        @if (TempData["Success"] != null)
        {
            <div class="toast bg-success text-white fade" id="successToast" data-delay="3000">
                <div class="toast-header bg-success text-white border-0">
                    <strong class="mr-auto">Success</strong>
                    <small>Now</small>
                    <button type="button" class="close text-white" data-dismiss="toast">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="toast-body">
                    @TempData["Success"]
                </div>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="toast bg-danger text-white fade" id="errorToast" data-delay="4000">
                <div class="toast-header bg-danger text-white border-0">
                    <strong class="mr-auto">Error</strong>
                    <small>Now</small>
                    <button type="button" class="close text-white" data-dismiss="toast">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="toast-body">
                    @TempData["Error"]
                </div>
            </div>
        }

    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {

            var table = $('#pingProductFieldTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                info: true,
                lengthChange: true,
                pageLength: 10,
                autoWidth: false,
                columnDefs: [
                    { orderable: true, targets: 0 },
                    { orderable: true, targets: 1 },
                    { orderable: true, targets: 2 },
                    { orderable: false, targets: 3 }
                ],
                dom: 'lrtip'
            });

            $('#customSearch').on('keyup', function () {
                table.search(this.value).draw();
            });

            $(document).on('click', '.open-modal-btn', function (e) {
                e.preventDefault();

                var url = $(this).attr('href');
                var title = $(this).data('title') || 'Ping Product Field';

                $('#mainActionModalTitle').text(title);
                $('#mainActionModalBody').html('<div class="text-center py-3"><i class="fas fa-spinner fa-spin mr-2"></i> Loading...</div>');

                $('#mainActionModalBody').load(url, function () {
                    $('#mainActionModal').modal('show');
                });
            });

            $(document).on('submit', '#createPingProductFieldForm, #editPingProductFieldForm, #deletePingProductFieldForm', function (e) {
                e.preventDefault();

                var form = $(this);
                var actionUrl = form.attr('action');
                var formData = form.serialize();

                $.ajax({
                    type: 'POST',
                    url: actionUrl,
                    data: formData,
                    success: function (response) {

                        if (typeof response === 'string' && response.startsWith('success|')) {
                            var message = response.split('|')[1];
                            $('#mainActionModal').modal('hide');
                            window.location.href = '/PingProductField/Index?successMessage=' + encodeURIComponent(message);
                            return;
                        }

                        if (typeof response === 'string' && response.startsWith('error|')) {
                            var errorMessage = response.split('|')[1];
                            $('#mainActionModal').modal('hide');
                            window.location.href = '/PingProductField/Index?errorMessage=' + encodeURIComponent(errorMessage);
                            return;
                        }

                        var html = $('<div>').html(response);
                        var hasForm =
                            html.find('#createPingProductFieldForm').length > 0 ||
                            html.find('#editPingProductFieldForm').length > 0 ||
                            html.find('#deletePingProductFieldForm').length > 0;

                        if (hasForm) {
                            $('#mainActionModalBody').html(response);
                        } else {
                            $('#mainActionModal').modal('hide');
                            window.location.href = '/PingProductField/Index';
                        }
                    },
                    error: function () {
                        alert('An error occurred while processing your request.');
                    }
                });
            });

            $('#mainActionModal').on('hidden.bs.modal', function () {
                $('#mainActionModalBody').html('');
            });

            if ($('#successToast').length) {
                $('#successToast').toast('show');
            }

            if ($('#errorToast').length) {
                $('#errorToast').toast('show');
            }

        });
    </script>
}