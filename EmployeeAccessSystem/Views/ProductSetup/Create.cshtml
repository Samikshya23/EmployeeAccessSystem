@model EmployeeAccessSystem.Models.ProductSetup

@{
    Layout = null;
}

<form asp-action="Create" method="post" id="createProductForm">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

    <div class="form-group">
        <label asp-for="ProductName" class="font-weight-bold">Product Name</label>
        <input asp-for="ProductName" class="form-control" placeholder="Enter product name" />
        <span asp-validation-for="ProductName" class="text-danger small"></span>
    </div>

    <div class="form-group mb-4">
        <div class="custom-control custom-switch">
            <input asp-for="IsActive" class="custom-control-input" id="IsActive" />
            <label class="custom-control-label font-weight-bold" for="IsActive">Active</label>
        </div>
        <span asp-validation-for="IsActive" class="text-danger small"></span>
    </div>

    <div class="modal-footer px-0 pb-0">
        <button type="button" class="btn btn-default" data-dismiss="modal">Back</button>
        <button type="submit" class="btn btn-primary">Save</button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />