@model IEnumerable<EmployeeAccessSystem.Models.ProductSetup>

@{
    ViewData["Title"] = "Product Setup";
}

<div class="container-fluid mt-3">
    <div class="card shadow-sm product-setup-card">
        <div class="card-header bg-white border-0 pt-3 pb-2">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0 fw-semibold">Product Setup</h5>

                <a href="@Url.Action("Create", "ProductSetup")"
                   class="btn add-btn open-modal-btn"
                   data-title="Add Product Setup">
                    <i class="fas fa-plus mr-1"></i> Add Product
                </a>
            </div>
        </div>

        <div class="card-body pt-2">
            <div class="table-responsive">
                <table id="productSetupTable" class="table table-bordered table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Product Name</th>
                            <th class="text-center action-column">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td class="text-center action-column">
                                        <a href="@Url.Action("Edit", "ProductSetup", new { id = item.ProductId })"
                                           class="action-icon-btn edit-icon-btn open-modal-btn"
                                           data-title="Edit Product Setup"
                                           title="Edit">
                                            <i class="fas fa-pen"></i>
                                        </a>

                                        <a href="@Url.Action("Delete", "ProductSetup", new { id = item.ProductId })"
                                           class="action-icon-btn delete-icon-btn open-modal-btn"
                                           data-title="Delete Product Setup"
                                           title="Delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Reusable Modal -->
<div class="modal fade custom-office-modal" id="mainActionModal" tabindex="-1" role="dialog" aria-labelledby="mainActionModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md" role="document">
        <div class="modal-content office-modal-content">
            <div class="modal-header office-modal-header">
                <h5 class="modal-title" id="mainActionModalTitle">Product Setup</h5>
                <button type="button" class="close modal-close-btn" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body office-modal-body" id="mainActionModalBody">
                <div class="text-center py-4">
                    <i class="fas fa-spinner fa-spin mr-2"></i> Loading...
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            $('#productSetupTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                info: false,
                lengthChange: false,
                pageLength: 10,
                autoWidth: false,
                columnDefs: [
                    { orderable: false, targets: 1 }
                ],
                language: {
                    search: "",
                    searchPlaceholder: "Search products..."
                }
            });

            $(document).on('click', '.open-modal-btn', function (e) {
                e.preventDefault();

                var url = $(this).attr('href');
                var title = $(this).data('title') || 'Product Setup';

                $('#mainActionModalTitle').text(title);
                $('#mainActionModalBody').html('<div class="text-center py-4"><i class="fas fa-spinner fa-spin mr-2"></i> Loading...</div>');

                $('#mainActionModalBody').load(url, function (response, status, xhr) {
                    if (status === "error") {
                        $('#mainActionModalBody').html('<div class="alert alert-danger mb-0">Failed to load content.</div>');
                        return;
                    }

                    $('#mainActionModal').modal({
                        backdrop: true,
                        keyboard: true
                    });

                    $('#mainActionModal').modal('show');
                });
            });

            $(document).on('submit', '#createProductForm, #editProductForm, #deleteProductForm', function (e) {
                e.preventDefault();

                var form = $(this);
                var url = form.attr('action');
                var method = form.attr('method');
                var formData = form.serialize();

                var submitButton = form.find('button[type="submit"]');
                submitButton.prop('disabled', true);

                $.ajax({
                    url: url,
                    type: method,
                    data: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    success: function (response) {
                        if (response.success) {
                            $('#mainActionModalBody').html(
                                '<div class="modal-success-box">' +
                                    '<i class="fas fa-check-circle success-icon"></i>' +
                                    '<div class="success-text">' + response.message + '</div>' +
                                '</div>'
                            );

                            setTimeout(function () {
                                $('#mainActionModal').modal('hide');
                                location.reload();
                            }, 1000);
                        }
                        else {
                            $('#mainActionModalBody').html(response);
                        }
                    },
                    error: function () {
                        submitButton.prop('disabled', false);

                        $('#mainActionModalBody').prepend(
                            '<div class="alert alert-danger">Something went wrong. Please try again.</div>'
                        );
                    }
                });
            });
        });
    </script>

    <style>
        .product-setup-card {
            border-radius: 14px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
        }

        #productSetupTable {
            width: 100% !important;
        }

            #productSetupTable thead th {
                background-color: #f8fafc !important;
                color: #334155;
                font-size: 14px;
                font-weight: 600;
                padding: 11px 14px;
                vertical-align: middle;
                border: 1px solid #d6dde5 !important;
            }

            #productSetupTable tbody td {
                font-size: 14px;
                padding: 10px 14px !important;
                vertical-align: middle;
                border: 1px solid #d6dde5 !important;
                color: #1f2937;
            }

        .action-column {
            width: 130px;
            white-space: nowrap;
        }

        .action-icon-btn {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none !important;
            transition: all 0.2s ease;
            margin: 0 4px;
            border: 1px solid transparent;
            font-size: 14px;
        }

        .edit-icon-btn {
            background: #f8fafc;
            color: #475569;
            border-color: #dbe2ea;
        }

            .edit-icon-btn:hover {
                background: #eef2f7;
                color: #334155;
                border-color: #cbd5e1;
            }

        .delete-icon-btn {
            background: #fff7f7;
            color: #b42318;
            border-color: #f3d0d0;
        }

            .delete-icon-btn:hover {
                background: #fdecec;
                color: #912018;
                border-color: #e8b4b4;
            }

        .add-btn {
            background: #1f2937;
            color: #ffffff !important;
            border-radius: 999px;
            padding: 8px 18px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none !important;
            display: inline-flex;
            align-items: center;
            border: 1px solid #1f2937;
        }

            .add-btn:hover {
                background: #111827;
                color: #ffffff !important;
                border-color: #111827;
            }

        .dataTables_wrapper .dataTables_filter {
            margin-bottom: 14px;
        }

            .dataTables_wrapper .dataTables_filter input {
                width: 280px !important;
                max-width: 100%;
                height: 41px;
                padding: 8px 14px;
                border-radius: 10px;
                border: 1px solid #cbd5e1;
                font-size: 14px;
                outline: none;
                box-shadow: none !important;
            }

                .dataTables_wrapper .dataTables_filter input:focus {
                    border-color: #94a3b8;
                }

        .dataTables_paginate .paginate_button {
            border-radius: 8px !important;
        }

        .custom-office-modal .modal-dialog {
            max-width: 520px;
        }

        .custom-office-modal .modal-content.office-modal-content {
            border: 0;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.20);
        }

        .office-modal-header {
            background: #ffffff;
            border-bottom: 1px solid #eef2f7;
            padding: 16px 20px;
        }

            .office-modal-header .modal-title {
                font-size: 20px;
                font-weight: 700;
                color: #1f2937;
            }

        .office-modal-body {
            padding: 20px;
            background: #ffffff;
        }

        .modal-close-btn {
            font-size: 24px;
            color: #6b7280;
            opacity: 1;
            text-shadow: none;
            box-shadow: none !important;
            outline: none !important;
        }

            .modal-close-btn:hover {
                color: #111827;
            }

        .modal-backdrop {
            background-color: rgba(0, 0, 0, 0.25) !important;
        }

            .modal-backdrop.show {
                opacity: 1 !important;
                backdrop-filter: blur(6px);
                -webkit-backdrop-filter: blur(6px);
            }

        .modal-success-box {
            text-align: center;
            padding: 28px 10px 20px 10px;
        }

        .success-icon {
            font-size: 42px;
            color: #16a34a;
            margin-bottom: 12px;
        }

        .success-text {
            font-size: 16px;
            font-weight: 600;
            color: #1f2937;
        }

        table.dataTable thead th.sorting:before,
        table.dataTable thead th.sorting:after,
        table.dataTable thead th.sorting_asc:before,
        table.dataTable thead th.sorting_asc:after,
        table.dataTable thead th.sorting_desc:before,
        table.dataTable thead th.sorting_desc:after {
            opacity: 0.85;
        }
    </style>
}