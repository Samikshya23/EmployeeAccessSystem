@model EmployeeAccessSystem.Models.ReportPageViewModel
@using System.Linq

@{
    ViewData["Title"] = "Reports";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Reports</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="breadcrumb-item active">Reports</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        <div class="card">
            <div class="card-body">
                <form asp-controller="Report" asp-action="Index" method="get">
                    <div class="form-row align-items-end">
                        <div class="form-group col-md-4">
                            <label for="selectedProductId">Product</label>
                            <select id="selectedProductId" name="selectedProductId" class="form-control">
                                <option value="">-- Select Product --</option>
                                @if (Model.ProductList != null && Model.ProductList.Count > 0)
                                {
                                    foreach (var product in Model.ProductList)
                                    {
                                        if (Model.SelectedProductId == product.ProductId)
                                        {
                                            <option value="@product.ProductId" selected>@product.ProductName</option>
                                        }
                                        else
                                        {
                                            <option value="@product.ProductId">@product.ProductName</option>
                                        }
                                    }
                                }
                            </select>
                        </div>

                        <div class="form-group col-md-3">
                            <label for="fromDate">From Date</label>
                            <input type="date"
                                   id="fromDate"
                                   name="fromDate"
                                   class="form-control"
                                   value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-dd") : "")" />
                        </div>

                        <div class="form-group col-md-3">
                            <label for="toDate">To Date</label>
                            <input type="date"
                                   id="toDate"
                                   name="toDate"
                                   class="form-control"
                                   value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-dd") : "")" />
                        </div>

                        <div class="form-group col-md-2">
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-chart-bar mr-1"></i> Generate
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @if (!Model.SelectedProductId.HasValue)
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle mr-1"></i>
                Please select a product to generate report.
            </div>
        }
        else if (!Model.HasData || Model.ReportData == null || Model.ReportData.Count == 0)
        {
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-circle mr-1"></i>
                No report data found for the selected criteria.
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">@Model.ReportTitle</h3>
                </div>

                <div class="card-body">
                    <p class="text-muted mb-3">
                        Monitoring status from
                        <strong>@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("dd MMM yyyy") : "")</strong>
                        to
                        <strong>@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("dd MMM yyyy") : "")</strong>
                    </p>

                    <div class="table-responsive">
                        <table class="table table-bordered table-hover mb-0">
                            <thead>
                                <tr>
                                    <th class="align-middle">Monitoring Type</th>
                                    <th class="align-middle">Item</th>
                                    @foreach (var date in Model.Dates)
                                    {
                                        <th class="text-center align-middle">
                                            <div>@date.ToString("dd MMM")</div>
                                            <small class="text-muted">@date.ToString("ddd")</small>
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var groupedData = Model.ReportData
                                    .GroupBy(x => x.MonitoringTypeName)
                                    .ToList();
                                }

                                @foreach (var group in groupedData)
                                {
                                    var items = group
                                    .GroupBy(x => x.ItemName)
                                    .ToList();

                                    var firstRow = true;

                                    foreach (var itemGroup in items)
                                    {
                                        <tr>
                                            @if (firstRow)
                                            {
                                                <td class="align-middle bg-light" rowspan="@items.Count">
                                                    @group.Key
                                                </td>
                                                firstRow = false;
                                            }

                                            <td class="align-middle">
                                                @itemGroup.Key
                                            </td>

                                            @foreach (var date in Model.Dates)
                                            {
                                                var cell = itemGroup.FirstOrDefault(x => x.EntryDate.Date == date.Date);

                                                <td class="text-center align-middle">
                                                    @if (cell == null)
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    else if (cell.EntryMode == "Checkbox")
                                                    {
                                                        if (cell.IsChecked)
                                                        {
                                                            <span class="badge badge-success">
                                                                <i class="fas fa-check"></i>
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">-</span>
                                                        }
                                                    }
                                                    else if (cell.EntryMode == "Percentage")
                                                    {
                                                        <span class="badge badge-primary">@cell.ConfigValue</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-secondary">@cell.ConfigValue</span>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {

            $('#fromDate').removeAttr('max');
            $('#toDate').removeAttr('max');

            function applyToDateMin() {
                var fromDateValue = $('#fromDate').val();

                if (fromDateValue) {
                    $('#toDate').attr('min', fromDateValue);
                } else {
                    $('#toDate').removeAttr('min');
                }
            }

            applyToDateMin();

            $('#fromDate').on('change', function () {
                applyToDateMin();

                var fromDateValue = $('#fromDate').val();
                var toDateValue = $('#toDate').val();

                if (fromDateValue && toDateValue && toDateValue < fromDateValue) {
                    $('#toDate').val(fromDateValue);
                }
            });
        });
    </script>
}