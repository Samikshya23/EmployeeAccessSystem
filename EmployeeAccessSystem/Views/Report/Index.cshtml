@model EmployeeAccessSystem.Models.ReportPageViewModel

@{
    ViewData["Title"] = "Reports";
    var todayDate = DateTime.Today.ToString("yyyy-MM-dd");

    var uniqueRows = new List<EmployeeAccessSystem.Models.ReportModel>();

    if (Model.ReportData != null)
    {
        for (int i = 0; i < Model.ReportData.Count; i++)
        {
            bool exists = false;

            for (int j = 0; j < uniqueRows.Count; j++)
            {
                if (uniqueRows[j].MonitoringTypeName == Model.ReportData[i].MonitoringTypeName &&
                    uniqueRows[j].ItemName == Model.ReportData[i].ItemName)
                {
                    exists = true;
                    break;
                }
            }

            if (!exists)
            {
                uniqueRows.Add(Model.ReportData[i]);
            }
        }
    }

    string selectedRangeText = "";

    if (Model.FromDate.HasValue && Model.ToDate.HasValue)
    {
        selectedRangeText = Model.FromDate.Value.ToString("dd MMM yyyy") + " - " + Model.ToDate.Value.ToString("dd MMM yyyy");
    }
}

<div class="card shadow-sm mb-0 h-100">
    <div class="card-header bg-white py-2">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h3 class="mb-0">Reports</h3>
            </div>
        </div>
    </div>

    <div class="card-body p-2">
        <div class="card mb-3">
            <div class="card-body">
                <form asp-controller="Report" asp-action="Index" method="get" id="reportForm">
                    <div class="row">

                        <div class="col-md-4">
                            <div class="form-group mb-2">
                                <label for="selectedProductId">Product</label>
                                <select id="selectedProductId"
                                        name="selectedProductId"
                                        class="form-control select2bs4">
                                    <option value="">Select Product</option>

                                    @if (Model.ProductList != null)
                                    {
                                        for (int i = 0; i < Model.ProductList.Count; i++)
                                        {
                                            if (Model.SelectedProductId.HasValue &&
                                            Model.SelectedProductId.Value == Model.ProductList[i].ProductId)
                                            {
                                                <option value="@Model.ProductList[i].ProductId" selected="selected">
                                                    @Model.ProductList[i].ProductName
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@Model.ProductList[i].ProductId">
                                                    @Model.ProductList[i].ProductName
                                                </option>
                                            }
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-2">
                                <label for="fromDate">From Date</label>
                                <input type="date"
                                       id="fromDate"
                                       name="fromDate"
                                       class="form-control"
                                       max="@todayDate"
                                       value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-dd") : "")" />
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-2">
                                <label for="toDate">To Date</label>
                                <input type="date"
                                       id="toDate"
                                       name="toDate"
                                       class="form-control"
                                       max="@todayDate"
                                       value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-dd") : "")" />
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label>&nbsp;</label>
                                <button type="submit" class="btn btn-primary btn-block">
                                    <i class="fas fa-chart-bar mr-1"></i> Generate
                                </button>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-danger mb-3">
                @Model.Message
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mb-3">
                @TempData["Error"]
            </div>
        }

        @if (Model.SelectedProductId.HasValue && (!Model.HasData || Model.ReportData == null || Model.ReportData.Count == 0))
        {
            <div class="alert alert-warning mb-0">
                No report data found for the selected criteria.
            </div>
        }
        else if (Model.SelectedProductId.HasValue && Model.HasData && Model.ReportData != null && Model.ReportData.Count > 0)
        {
            <div class="mb-0">
                <div class="d-flex justify-content-between align-items-center mb-2 px-1">
                    <div>
                        @if (!string.IsNullOrEmpty(selectedRangeText))
                        {
                            <span style="color:#212529; font-size:16px; font-weight:500;">
                                @selectedRangeText
                            </span>
                        }
                    </div>

                    <div class="btn-group">
                        <button type="button"
                                class="btn btn-danger dropdown-toggle"
                                data-toggle="dropdown"
                                aria-haspopup="true"
                                aria-expanded="false">
                            <i class="fas fa-download mr-1"></i> Download
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item"
                               asp-controller="Report"
                               asp-action="DownloadPdf"
                               asp-route-selectedProductId="@Model.SelectedProductId"
                               asp-route-fromDate="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-dd") : "")"
                               asp-route-toDate="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-dd") : "")">
                                <i class="fas fa-file-pdf text-danger mr-2"></i> PDF
                            </a>

                            <a class="dropdown-item"
                               asp-controller="Report"
                               asp-action="DownloadExcel"
                               asp-route-selectedProductId="@Model.SelectedProductId"
                               asp-route-fromDate="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-dd") : "")"
                               asp-route-toDate="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-dd") : "")">
                                <i class="fas fa-file-excel text-success mr-2"></i> Excel
                            </a>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered table-sm mb-0 text-center">
                        <thead>
                            <tr>
                                <th rowspan="2"
                                    class="align-middle bg-light"
                                    style="min-width:160px; border:1px solid #ced4da;">
                                    Monitoring Type
                                </th>

                                <th rowspan="2"
                                    class="align-middle bg-light"
                                    style="min-width:170px; border:1px solid #ced4da;">
                                    Item
                                </th>

                                @if (Model.Dates != null)
                                {
                                    for (int d = 0; d < Model.Dates.Count; d++)
                                    {
                                        <th class="text-center bg-light"
                                            style="min-width:80px; border:1px solid #ced4da; border-bottom:none; padding:6px 4px 3px 4px;">
                                            <div class="font-weight-bold" style="font-size:15px; line-height:1.1;">
                                                @Model.Dates[d].ToString("dd")
                                            </div>
                                        </th>
                                    }
                                }
                            </tr>

                            <tr>
                                @if (Model.Dates != null)
                                {
                                    for (int d = 0; d < Model.Dates.Count; d++)
                                    {
                                        <th class="text-center bg-light"
                                            style="min-width:80px; border-left:1px solid #ced4da; border-right:1px solid #ced4da; border-bottom:1px solid #ced4da; border-top:1px solid #bfc5cb; padding:4px 4px 5px 4px;">
                                            <small style="color:#343a40; font-weight:500;">
                                                @Model.Dates[d].ToString("ddd")
                                            </small>
                                        </th>
                                    }
                                }
                            </tr>
                        </thead>

                        <tbody>
                            @for (int i = 0; i < uniqueRows.Count; i++)
                            {
                                var currentRow = uniqueRows[i];

                                bool showMonitoringType = true;

                                for (int x = 0; x < i; x++)
                                {
                                    if (uniqueRows[x].MonitoringTypeName == currentRow.MonitoringTypeName)
                                    {
                                        showMonitoringType = false;
                                        break;
                                    }
                                }

                                int sameTypeCount = 0;

                                for (int y = 0; y < uniqueRows.Count; y++)
                                {
                                    if (uniqueRows[y].MonitoringTypeName == currentRow.MonitoringTypeName)
                                    {
                                        sameTypeCount++;
                                    }
                                }

                                <tr>
                                    @if (showMonitoringType)
                                    {
                                        <td rowspan="@sameTypeCount"
                                            class="align-middle bg-light font-weight-bold text-left"
                                            style="font-size:15px; border:1px solid #ced4da; padding:12px 10px;">
                                            @currentRow.MonitoringTypeName
                                        </td>
                                    }

                                    <td class="align-middle text-left"
                                        style="font-size:15px; border:1px solid #ced4da; padding:10px 10px;">
                                        @currentRow.ItemName
                                    </td>

                                    @if (Model.Dates != null)
                                    {
                                        for (int d = 0; d < Model.Dates.Count; d++)
                                        {
                                            string displayText = "";
                                            string entryMode = "";
                                            bool isChecked = false;
                                            bool foundRow = false;

                                            for (int r = 0; r < Model.ReportData.Count; r++)
                                            {
                                                if (Model.ReportData[r].MonitoringTypeName == currentRow.MonitoringTypeName &&
                                                Model.ReportData[r].ItemName == currentRow.ItemName &&
                                                Model.ReportData[r].EntryDate.Date == Model.Dates[d].Date)
                                                {
                                                    foundRow = true;

                                                    if (Model.ReportData[r].EntryMode != null)
                                                    {
                                                        entryMode = Model.ReportData[r].EntryMode.Trim();
                                                    }

                                                    isChecked = Model.ReportData[r].IsChecked;

                                                    if (Model.ReportData[r].ConfigValue != null)
                                                    {
                                                        displayText = Model.ReportData[r].ConfigValue.Trim();
                                                    }

                                                    break;
                                                }
                                            }

                                            <td class="text-center align-middle"
                                                style="font-size:15px; border:1px solid #ced4da; padding:10px 6px;">
                                                @if (!foundRow)
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                                else if (entryMode == "Checkbox")
                                                {
                                                    if (isChecked)
                                                    {
                                                        <i class="fas fa-check text-success"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="fas fa-times text-danger"></i>
                                                    }
                                                }
                                                else if (entryMode == "Value")
                                                {
                                                    if (!string.IsNullOrWhiteSpace(displayText))
                                                    {
                                                        <span>@displayText</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                }
                                                else
                                                {
                                                    if (!string.IsNullOrWhiteSpace(displayText))
                                                    {
                                                        <span>@displayText</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                }
                                            </td>
                                        }
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            if ($('#selectedProductId').hasClass('select2-hidden-accessible')) {
                $('#selectedProductId').select2('destroy');
            }

            $('#selectedProductId').select2({
                theme: 'bootstrap4',
                placeholder: 'Select Product',
                allowClear: true,
                minimumResultsForSearch: 0,
                width: '100%'
            });

            var today = '@todayDate';

            $('#fromDate').attr('max', today);
            $('#toDate').attr('max', today);

            function formatDate(date) {
                var year = date.getFullYear();
                var month = (date.getMonth() + 1).toString().padStart(2, '0');
                var day = date.getDate().toString().padStart(2, '0');
                return year + '-' + month + '-' + day;
            }

            function updateToDateLimits() {
                var fromDateValue = $('#fromDate').val();

                if (fromDateValue !== '') {
                    var fromDate = new Date(fromDateValue);

                    var maxToDate = new Date(fromDate);
                    maxToDate.setDate(maxToDate.getDate() + 31);

                    var todayDateObj = new Date(today);

                    if (maxToDate > todayDateObj) {
                        maxToDate = todayDateObj;
                    }

                    $('#toDate').attr('min', formatDate(fromDate));
                    $('#toDate').attr('max', formatDate(maxToDate));

                    var toDateValue = $('#toDate').val();

                    if (toDateValue !== '') {
                        if (toDateValue < formatDate(fromDate)) {
                            $('#toDate').val(formatDate(fromDate));
                        }

                        if (toDateValue > formatDate(maxToDate)) {
                            $('#toDate').val(formatDate(maxToDate));
                        }
                    }
                }
                else {
                    $('#toDate').removeAttr('min');
                    $('#toDate').attr('max', today);
                }
            }

            function updateFromDateLimits() {
                var toDateValue = $('#toDate').val();

                if (toDateValue !== '') {
                    $('#fromDate').attr('max', toDateValue);
                }
                else {
                    $('#fromDate').attr('max', today);
                }
            }

            updateToDateLimits();
            updateFromDateLimits();

            $('#fromDate').on('change', function () {
                updateToDateLimits();
            });

            $('#toDate').on('change', function () {
                updateFromDateLimits();
            });

            $('#reportForm').on('submit', function (e) {
                var fromDate = $('#fromDate').val();
                var toDate = $('#toDate').val();
                var productId = $('#selectedProductId').val();

                if (productId === '' || productId === null) {
                    alert('Please select product.');
                    e.preventDefault();
                    return false;
                }

                if (fromDate === '' || toDate === '') {
                    alert('Please select both from date and to date.');
                    e.preventDefault();
                    return false;
                }

                var from = new Date(fromDate);
                var to = new Date(toDate);

                var timeDifference = to.getTime() - from.getTime();
                var dayDifference = Math.floor(timeDifference / (1000 * 60 * 60 * 24));

                if (dayDifference < 0) {
                    alert('From Date cannot be greater than To Date.');
                    e.preventDefault();
                    return false;
                }

                if (dayDifference > 31) {
                    alert('Maximum report range is 31 days only.');
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}