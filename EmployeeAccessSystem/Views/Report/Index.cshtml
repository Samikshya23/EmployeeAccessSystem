@{
    ViewData["Title"] = "Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid report-page">

    <!-- Small Page Header -->
    <div class="card shadow-sm border-0 page-title-card mb-3">
        <div class="card-body py-3 px-4">
            <h2 class="page-title mb-1">Reports</h2>
            <p class="page-subtitle mb-0">View monitoring reports for all products</p>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card shadow-sm border-0 report-card mb-3">
        <div class="card-body py-3 px-4">
            <form method="get" asp-controller="Report" asp-action="Index">
                <div class="row g-3 align-items-end">

                    <div class="col-lg-3 col-md-6">
                        <label class="form-label report-label">Product</label>
                        <select class="form-select report-input">
                            <option selected>SMSC</option>
                            <option>Fortigate</option>
                            <option>Website</option>
                            <option>Server Ping</option>
                            <option>VEEAM Backup</option>
                        </select>
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <label class="form-label report-label">From Date</label>
                        <input type="date" class="form-control report-input" value="2026-03-23" />
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <label class="form-label report-label">To Date</label>
                        <input type="date" class="form-control report-input" value="2026-03-29" />
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <button type="submit" class="btn report-btn w-100">
                            Generate Report
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-3">
        <div class="col-lg-3 col-md-6">
            <div class="summary-card">
                <div class="summary-title">Total Records</div>
                <div class="summary-value text-primary">18</div>
                <div class="summary-text">Entries found</div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="summary-card">
                <div class="summary-title">Monitoring Types</div>
                <div class="summary-value text-purple">3</div>
                <div class="summary-text">Telnet, Resource Utilization, Log</div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="summary-card">
                <div class="summary-title">Items</div>
                <div class="summary-value text-success">5</div>
                <div class="summary-text">NTC, Ncell, CPU, Memory, Bulk SMS</div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="summary-card">
                <div class="summary-title">Date Range</div>
                <div class="summary-value text-orange">7 Days</div>
                <div class="summary-text">23 Mar - 29 Mar 2026</div>
            </div>
        </div>
    </div>

    <!-- Main Report -->
    <div class="card shadow-sm border-0 report-card mb-3">
        <div class="card-body py-3 px-4">

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                <div>
                    <h4 class="report-section-title mb-1">SMSC Report Summary</h4>
                    <p class="report-section-subtitle mb-0">Monitoring status by item across selected date range</p>
                </div>

                <div class="d-flex gap-2">
                    <button type="button" class="btn table-action-btn">Print</button>
                    <button type="button" class="btn table-action-btn">Export</button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered align-middle report-table mb-0">
                    <thead>
                        <tr>
                            <th>Monitoring Type</th>
                            <th>Item</th>
                            <th>23 Mar<br /><small>Mon</small></th>
                            <th>24 Mar<br /><small>Tue</small></th>
                            <th>25 Mar<br /><small>Wed</small></th>
                            <th>26 Mar<br /><small>Thu</small></th>
                            <th>27 Mar<br /><small>Fri</small></th>
                            <th>28 Mar<br /><small>Sat</small></th>
                            <th>29 Mar<br /><small>Sun</small></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td rowspan="2" class="monitoring-type-cell">Telnet</td>
                            <td>NTC</td>
                            <td><span class="status-badge ok-badge">OK</span></td>
                            <td><span class="status-badge ok-badge">OK</span></td>
                            <td><span class="status-badge fail-badge">Failed</span></td>
                            <td><span class="status-badge ok-badge">OK</span></td>
                            <td><span class="status-badge fail-badge">Failed</span></td>
                            <td><span class="status-badge ok-badge">OK</span></td>
                            <td><span class="status-badge ok-badge">OK</span></td>
                        </tr>
                        <tr>
                            <td>Ncell</td>
                            <td><span class="status-badge ok-badge">OK</span></td>
                            <td><span class="status-badge fail-badge">Failed</span></td>
                            <td><span class="status-badge ok-badge">OK</span></td>
                            <td><span class="status-badge ok-badge">OK</span></td>
                            <td><span class="status-badge ok-badge">OK</span></td>
                            <td><span class="status-badge ok-badge">OK</span></td>
                            <td><span class="status-badge fail-badge">Failed</span></td>
                        </tr>

                        <tr>
                            <td rowspan="2" class="monitoring-type-cell">Resource Utilization</td>
                            <td>CPU</td>
                            <td><span class="status-badge percent-badge">65%</span></td>
                            <td><span class="status-badge percent-badge">72%</span></td>
                            <td><span class="status-badge percent-badge">78%</span></td>
                            <td><span class="status-badge percent-badge">70%</span></td>
                            <td><span class="status-badge percent-badge">80%</span></td>
                            <td><span class="status-badge percent-badge">75%</span></td>
                            <td><span class="status-badge percent-badge">70%</span></td>
                        </tr>
                        <tr>
                            <td>Memory</td>
                            <td><span class="status-badge percent-badge">60%</span></td>
                            <td><span class="status-badge percent-badge">66%</span></td>
                            <td><span class="status-badge percent-badge">70%</span></td>
                            <td><span class="status-badge percent-badge">68%</span></td>
                            <td><span class="status-badge percent-badge">72%</span></td>
                            <td><span class="status-badge percent-badge">68%</span></td>
                            <td><span class="status-badge percent-badge">65%</span></td>
                        </tr>

                        <tr>
                            <td class="monitoring-type-cell">Log</td>
                            <td>Morning Bulk SMS</td>
                            <td><span class="status-badge complete-badge">Completed</span><div class="sub-value">12,075</div></td>
                            <td><span class="status-badge complete-badge">Completed</span><div class="sub-value">11,856</div></td>
                            <td><span class="status-badge complete-badge">Completed</span><div class="sub-value">12,450</div></td>
                            <td><span class="status-badge complete-badge">Completed</span><div class="sub-value">12,103</div></td>
                            <td><span class="status-badge complete-badge">Completed</span><div class="sub-value">13,201</div></td>
                            <td><span class="status-badge complete-badge">Completed</span><div class="sub-value">12,540</div></td>
                            <td><span class="status-badge complete-badge">Completed</span><div class="sub-value">12,940</div></td>
                        </tr>

                        <tr class="daily-status-row">
                            <td colspan="2"><strong>Daily Status</strong></td>
                            <td><span class="status-badge ok-badge">All OK</span></td>
                            <td><span class="status-badge issue-badge">1 Issue</span></td>
                            <td><span class="status-badge issue-badge">2 Issues</span></td>
                            <td><span class="status-badge ok-badge">All OK</span></td>
                            <td><span class="status-badge issue-badge">2 Issues</span></td>
                            <td><span class="status-badge ok-badge">All OK</span></td>
                            <td><span class="status-badge issue-badge">1 Issue</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<style>
    .report-page {
        padding: 12px 8px 4px 8px;
    }

    .page-title-card,
    .report-card {
        border-radius: 10px;
        overflow: hidden;
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: #1f2937;
        margin: 0;
    }

    .page-subtitle {
        font-size: 14px;
        color: #6b7280;
    }

    .report-label {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }

    .report-input {
        height: 40px;
        border-radius: 8px;
        border: 1px solid #d7dde5;
        font-size: 14px;
        box-shadow: none;
    }

        .report-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 0.12rem rgba(59,130,246,0.12);
        }

    .report-btn {
        height: 40px;
        background: #2f80ed;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
    }

        .report-btn:hover {
            background: #1f6fe0;
            color: #fff;
        }

    .summary-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 16px;
        height: 100%;
        box-shadow: 0 1px 6px rgba(0,0,0,0.04);
    }

    .summary-title {
        font-size: 13px;
        font-weight: 600;
        color: #6b7280;
        margin-bottom: 10px;
    }

    .summary-value {
        font-size: 22px;
        font-weight: 700;
        line-height: 1.1;
        margin-bottom: 8px;
    }

    .summary-text {
        font-size: 13px;
        color: #6b7280;
        line-height: 1.5;
    }

    .text-purple {
        color: #7c3aed;
    }

    .text-orange {
        color: #ea580c;
    }

    .report-section-title {
        font-size: 18px;
        font-weight: 700;
        color: #1f2937;
    }

    .report-section-subtitle {
        font-size: 13px;
        color: #6b7280;
    }

    .table-action-btn {
        padding: 6px 14px;
        background: #f8fafc;
        border: 1px solid #d7dde5;
        color: #374151;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
    }

        .table-action-btn:hover {
            background: #eef2f7;
            color: #1f2937;
        }

    .report-table thead th {
        background: #f3f4f6;
        color: #374151;
        font-size: 13px;
        font-weight: 700;
        text-align: center;
        vertical-align: middle;
        white-space: nowrap;
        padding: 10px 8px;
        border-color: #d9dee5;
    }

    .report-table tbody td {
        font-size: 13px;
        color: #374151;
        text-align: center;
        vertical-align: middle;
        padding: 9px 8px;
        border-color: #e2e8f0;
    }

        .report-table tbody td:first-child,
        .report-table tbody td:nth-child(2) {
            text-align: left;
        }

    .monitoring-type-cell {
        font-weight: 700;
        background: #fafafa;
        min-width: 150px;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        min-width: 52px;
    }

    .ok-badge {
        background: #dcfce7;
        color: #166534;
    }

    .fail-badge {
        background: #fee2e2;
        color: #991b1b;
    }

    .percent-badge {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .complete-badge {
        background: #dcfce7;
        color: #166534;
    }

    .issue-badge {
        background: #fef3c7;
        color: #92400e;
    }

    .sub-value {
        font-size: 11px;
        color: #6b7280;
        margin-top: 4px;
    }

    .daily-status-row td {
        background: #fcfcfd;
    }

    @@media (max-width: 768px) {
        .page-title {
            font-size: 20px;
        }

        .summary-value {
            font-size: 20px;
        }

        .report-page {
            padding: 10px 4px 2px 4px;
        }
    }
</style>