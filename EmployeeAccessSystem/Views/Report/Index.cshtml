@model EmployeeAccessSystem.Models.ReportPageViewModel

@{
    ViewData["Title"] = "Reports";
    var todayDate = DateTime.Today.ToString("yyyy-MM-dd");

    var uniqueRows = new List<EmployeeAccessSystem.Models.ReportModel>();

    for (int i = 0; i < Model.ReportData.Count; i++)
    {
        bool alreadyExists = false;

        for (int j = 0; j < uniqueRows.Count; j++)
        {
            if (uniqueRows[j].MonitoringTypeName == Model.ReportData[i].MonitoringTypeName &&
                uniqueRows[j].ItemName == Model.ReportData[i].ItemName)
            {
                alreadyExists = true;
                break;
            }
        }

        if (!alreadyExists)
        {
            uniqueRows.Add(Model.ReportData[i]);
        }
    }
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Reports</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="breadcrumb-item active">Reports</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        <div class="card">
            <div class="card-body">
                <form asp-controller="Report" asp-action="Index" method="get">
                    <div class="row">

                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="selectedProductId">Product</label>
                                <select id="selectedProductId"
                                        name="selectedProductId"
                                        class="form-control select2bs4"
                                        data-placeholder="Select Product">
                                    <option value=""></option>
                                    @for (int i = 0; i < Model.ProductList.Count; i++)
                                    {
                                        if (Model.SelectedProductId.HasValue && Model.SelectedProductId.Value == Model.ProductList[i].ProductId)
                                        {
                                            <option value="@Model.ProductList[i].ProductId" selected="selected">
                                                @Model.ProductList[i].ProductName
                                            </option>
                                        }
                                        else
                                        {
                                            <option value="@Model.ProductList[i].ProductId">
                                                @Model.ProductList[i].ProductName
                                            </option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fromDate">From Date</label>
                                <input type="date"
                                       id="fromDate"
                                       name="fromDate"
                                       class="form-control"
                                       max="@todayDate"
                                       value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-dd") : "")" />
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="toDate">To Date</label>
                                <input type="date"
                                       id="toDate"
                                       name="toDate"
                                       class="form-control"
                                       max="@todayDate"
                                       value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-dd") : "")" />
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group">
                                <label>&nbsp;</label>
                                <button type="submit" class="btn btn-primary btn-block">
                                    <i class="fas fa-chart-bar mr-1"></i> Generate
                                </button>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>

        @if (!Model.SelectedProductId.HasValue)
        {
            <div class="alert alert-info">
                Please select a product to generate report.
            </div>
        }
        else if (!Model.HasData || Model.ReportData == null || Model.ReportData.Count == 0)
        {
            <div class="alert alert-warning">
                No report data found for the selected criteria.
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">@Model.ReportTitle</h3>
                </div>

                <div class="card-body p-0">
                    <div class="px-3 pt-3 pb-2 text-muted">
                        Monitoring status from
                        <strong>@Model.FromDate?.ToString("dd MMM yyyy")</strong>
                        to
                        <strong>@Model.ToDate?.ToString("dd MMM yyyy")</strong>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered table-hover mb-0">
                            <thead class="thead-light">
                                <tr>
                                    <th>Monitoring Type</th>
                                    <th>Item</th>
                                    @for (int d = 0; d < Model.Dates.Count; d++)
                                    {
                                        <th class="text-center">
                                            <div>@Model.Dates[d].ToString("dd MMM")</div>
                                            <small class="text-muted">@Model.Dates[d].ToString("ddd")</small>
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < uniqueRows.Count; i++)
                                {
                                    var currentRow = uniqueRows[i];
                                    bool showMonitoringType = true;

                                    for (int p = 0; p < i; p++)
                                    {
                                        if (uniqueRows[p].MonitoringTypeName == currentRow.MonitoringTypeName)
                                        {
                                            showMonitoringType = false;
                                            break;
                                        }
                                    }

                                    int rowCount = 0;

                                    for (int c = 0; c < uniqueRows.Count; c++)
                                    {
                                        if (uniqueRows[c].MonitoringTypeName == currentRow.MonitoringTypeName)
                                        {
                                            rowCount++;
                                        }
                                    }

                                    <tr>
                                        @if (showMonitoringType)
                                        {
                                            <td rowspan="@rowCount" class="align-middle bg-light">
                                                @currentRow.MonitoringTypeName
                                            </td>
                                        }

                                        <td class="align-middle">
                                            @currentRow.ItemName
                                        </td>

                                        @for (int d = 0; d < Model.Dates.Count; d++)
                                        {
                                            bool found = false;

                                            <td class="text-center align-middle">
                                                @for (int r = 0; r < Model.ReportData.Count; r++)
                                                {
                                                    if (Model.ReportData[r].MonitoringTypeName == currentRow.MonitoringTypeName &&
                                                    Model.ReportData[r].ItemName == currentRow.ItemName &&
                                                    Model.ReportData[r].EntryDate.Date == Model.Dates[d].Date)
                                                    {
                                                        found = true;

                                                        if (Model.ReportData[r].EntryMode == "Checkbox")
                                                        {
                                                            if (Model.ReportData[r].IsChecked)
                                                            {
                                                                <span class="badge badge-success">
                                                                    <i class="fas fa-check"></i>
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">-</span>
                                                            }
                                                        }
                                                        else if (Model.ReportData[r].EntryMode == "Percentage")
                                                        {
                                                            <span class="badge badge-primary">
                                                                @Model.ReportData[r].ConfigValue
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge badge-secondary">
                                                                @Model.ReportData[r].ConfigValue
                                                            </span>
                                                        }

                                                        break;
                                                    }
                                                }

                                                @if (!found)
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        $(function () {
            $('#selectedProductId').select2({
                theme: 'bootstrap4',
                placeholder: 'Select Product',
                allowClear: true,
                minimumResultsForSearch: 0,
                width: '100%'
            });

            var today = '@todayDate';

            $('#fromDate').attr('max', today);
            $('#toDate').attr('max', today);

            if ($('#fromDate').val() !== '') {
                $('#toDate').attr('min', $('#fromDate').val());
            }

            $('#fromDate').on('change', function () {
                var fromDate = $(this).val();

                if (fromDate !== '') {
                    $('#toDate').attr('min', fromDate);
                } else {
                    $('#toDate').removeAttr('min');
                }

                var toDate = $('#toDate').val();

                if (toDate !== '' && fromDate !== '' && toDate < fromDate) {
                    $('#toDate').val(fromDate);
                }
            });
        });
    </script>
}