@model EmployeeAccessSystem.Models.ReportPageViewModel
@{
    ViewData["Title"] = "Reports";

    var uniqueRows = new List<EmployeeAccessSystem.Models.ReportModel>();
    var uniquePingRows = new List<EmployeeAccessSystem.Models.ReportModel>();

    if (Model.ReportData != null)
    {
        for (int i = 0; i < Model.ReportData.Count; i++)
        {
            bool exists = false;

            for (int j = 0; j < uniqueRows.Count; j++)
            {
                if (uniqueRows[j].MonitoringTypeName == Model.ReportData[i].MonitoringTypeName &&
                    uniqueRows[j].ItemName == Model.ReportData[i].ItemName)
                {
                    exists = true;
                    break;
                }
            }

            if (!exists)
            {
                uniqueRows.Add(Model.ReportData[i]);
            }
        }

        for (int i = 0; i < Model.ReportData.Count; i++)
        {
            bool exists = false;

            for (int j = 0; j < uniquePingRows.Count; j++)
            {
                if (uniquePingRows[j].IPAddress == Model.ReportData[i].IPAddress &&
                    uniquePingRows[j].ServerHostName == Model.ReportData[i].ServerHostName)
                {
                    exists = true;
                    break;
                }
            }

            if (!exists)
            {
                uniquePingRows.Add(Model.ReportData[i]);
            }
        }
    }

    string selectedRangeText = "";
    if (Model.FromDate.HasValue && Model.ToDate.HasValue)
    {
        selectedRangeText = Model.FromDate.Value.ToString("dd MMM yyyy") + " - " + Model.ToDate.Value.ToString("dd MMM yyyy");
    }
}

<div class="card shadow-sm mb-0 h-100">
    <div class="card-header bg-white py-2">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h3 class="mb-0">Reports</h3>
            </div>
        </div>
    </div>

    <div class="card-body p-2">
        <div class="card mb-3">
            <div class="card-body">
                <form asp-controller="Report" asp-action="Index" method="get" id="reportForm">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group mb-2">
                                <label for="selectedProductId">Product</label>
                                <select id="selectedProductId"
                                        name="selectedProductId"
                                        class="form-control select2bs4">
                                    <option value="">Select Product</option>
                                    @if (Model.ProductList != null)
                                    {
                                        for (int i = 0; i < Model.ProductList.Count; i++)
                                        {
                                            if (Model.SelectedProductId.HasValue &&
                                            Model.SelectedProductId.Value == Model.ProductList[i].ProductId)
                                            {
                                                <option value="@Model.ProductList[i].ProductId" selected="selected">
                                                    @Model.ProductList[i].ProductName
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@Model.ProductList[i].ProductId">
                                                    @Model.ProductList[i].ProductName
                                                </option>
                                            }
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-2">
                                <label for="dateRange">Date Range</label>
                                <div class="input-group">
                                    <input type="text"
                                           id="dateRange"
                                           class="form-control"
                                           readonly
                                           placeholder="Pick date range" />
                                    <div class="input-group-append">
                                        <span class="input-group-text" id="dateRangeIcon" style="cursor:pointer;">
                                            <i class="far fa-calendar-alt"></i>
                                        </span>
                                    </div>
                                </div>

                                <input type="hidden"
                                       id="fromDate"
                                       name="fromDate"
                                       value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-dd") : "")" />

                                <input type="hidden"
                                       id="toDate"
                                       name="toDate"
                                       value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-dd") : "")" />
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label>&nbsp;</label>
                                <button type="submit" class="btn btn-primary btn-block">
                                    <i class="fas fa-chart-bar mr-1"></i> Generate
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-danger mb-3">
                @Model.Message
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mb-3">
                @TempData["Error"]
            </div>
        }

        @if (Model.SelectedProductId.HasValue && (!Model.HasData || Model.ReportData == null || Model.ReportData.Count == 0))
        {
            <div class="alert alert-warning mb-0">
                No report data found for the selected criteria.
            </div>
        }
        else if (Model.SelectedProductId.HasValue && Model.HasData && Model.ReportData != null && Model.ReportData.Count > 0)
        {
            <div class="card mb-0">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-center mb-2 px-1">
                        <div>
                            @if (!string.IsNullOrEmpty(selectedRangeText))
                            {
                                <span class="text-dark font-weight-medium">
                                    @selectedRangeText
                                </span>
                            }
                        </div>

                        <div class="btn-group">
                            <button type="button"
                                    class="btn btn-danger dropdown-toggle"
                                    data-toggle="dropdown"
                                    aria-haspopup="true"
                                    aria-expanded="false">
                                <i class="fas fa-download mr-1"></i> Download
                            </button>
                            <div class="dropdown-menu dropdown-menu-right">
                                <a class="dropdown-item"
                                   asp-controller="Report"
                                   asp-action="DownloadPdf"
                                   asp-route-selectedProductId="@Model.SelectedProductId"
                                   asp-route-fromDate="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-dd") : "")"
                                   asp-route-toDate="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-dd") : "")">
                                    <i class="fas fa-file-pdf text-danger mr-2"></i> PDF
                                </a>
                                <a class="dropdown-item"
                                   asp-controller="Report"
                                   asp-action="DownloadExcel"
                                   asp-route-selectedProductId="@Model.SelectedProductId"
                                   asp-route-fromDate="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-dd") : "")"
                                   asp-route-toDate="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-dd") : "")">
                                    <i class="fas fa-file-excel text-success mr-2"></i> Excel
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2 report-pagination-bar">
                        <div class="form-inline">
                            <label class="mr-2 mb-0">Show</label>
                            <select id="reportPageSize" class="form-control form-control-sm mr-2" style="width:90px;">
                                <option value="10" selected>10</option>
                                <option value="15">15</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                            </select>
                            <span>entries</span>
                        </div>

                        <div class="report-pagination-info text-muted small">
                            Showing <span id="reportStartEntry">0</span> to <span id="reportEndEntry">0</span> of <span id="reportTotalEntry">0</span> entries
                        </div>
                    </div>

                    <div class="table-responsive p-0" style="max-height:70vh; overflow:auto;">
                        @if (Model.IsPingReport)
                        {
                            <table class="table table-bordered table-sm table-hover mb-0 text-center bg-white report-table-ping" id="pingReportTable">
                                <thead>
                                    <tr>
                                        <th rowspan="2"
                                            class="align-middle bg-light"
                                            style="position:sticky; top:0; left:0; z-index:6; min-width:60px;">
                                            SN
                                        </th>
                                        <th rowspan="2"
                                            class="align-middle bg-light"
                                            style="position:sticky; top:0; left:60px; z-index:6; min-width:140px;">
                                            IP
                                        </th>
                                        <th rowspan="2"
                                            class="align-middle bg-light"
                                            style="position:sticky; top:0; left:200px; z-index:6; min-width:180px;">
                                            Server Host Name
                                        </th>

                                        @if (Model.Dates != null)
                                        {
                                            for (int d = 0; d < Model.Dates.Count; d++)
                                            {
                                                <th class="text-center bg-light"
                                                    style="position:sticky; top:0; z-index:5; min-width:55px;">
                                                    <div class="font-weight-bold">
                                                        @Model.Dates[d].ToString("dd")
                                                    </div>
                                                </th>
                                            }
                                        }
                                    </tr>
                                    <tr>
                                        @if (Model.Dates != null)
                                        {
                                            for (int d = 0; d < Model.Dates.Count; d++)
                                            {
                                                <th class="text-center bg-light"
                                                    style="position:sticky; top:39px; z-index:5; min-width:55px;">
                                                    <small>@Model.Dates[d].ToString("ddd")</small>
                                                </th>
                                            }
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < uniquePingRows.Count; i++)
                                    {
                                        var currentRow = uniquePingRows[i];

                                        <tr class="ping-entry-row">
                                            <td class="align-middle bg-white"
                                                style="position:sticky; left:0; z-index:4; min-width:60px;">
                                                @(i + 1)
                                            </td>
                                            <td class="align-middle text-left bg-white"
                                                style="position:sticky; left:60px; z-index:4; min-width:140px; white-space:nowrap;">
                                                @currentRow.IPAddress
                                            </td>
                                            <td class="align-middle text-left bg-white"
                                                style="position:sticky; left:200px; z-index:4; min-width:180px;">
                                                @currentRow.ServerHostName
                                            </td>

                                            @if (Model.Dates != null)
                                            {
                                                for (int d = 0; d < Model.Dates.Count; d++)
                                                {
                                                    string displayText = "";
                                                    string entryMode = "";
                                                    bool isChecked = false;
                                                    bool foundRow = false;

                                                    for (int r = 0; r < Model.ReportData.Count; r++)
                                                    {
                                                        if (Model.ReportData[r].IPAddress == currentRow.IPAddress &&
                                                        Model.ReportData[r].ServerHostName == currentRow.ServerHostName &&
                                                        Model.ReportData[r].EntryDate.Date == Model.Dates[d].Date)
                                                        {
                                                            foundRow = true;

                                                            if (Model.ReportData[r].EntryMode != null)
                                                            {
                                                                entryMode = Model.ReportData[r].EntryMode.Trim();
                                                            }

                                                            isChecked = Model.ReportData[r].IsChecked;

                                                            if (Model.ReportData[r].ConfigValue != null)
                                                            {
                                                                displayText = Model.ReportData[r].ConfigValue.Trim();
                                                            }

                                                            break;
                                                        }
                                                    }

                                                    <td class="text-center align-middle" style="min-width:55px;">
                                                        @if (!foundRow)
                                                        {
                                                            <span class="text-muted">-</span>
                                                        }
                                                        else if (entryMode == "Checkbox")
                                                        {
                                                            if (isChecked)
                                                            {
                                                                <i class="fas fa-check text-success"></i>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">-</span>
                                                            }
                                                        }
                                                        else if (entryMode == "Value")
                                                        {
                                                            if (!string.IsNullOrWhiteSpace(displayText))
                                                            {
                                                                <span>@displayText</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">-</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            if (!string.IsNullOrWhiteSpace(displayText))
                                                            {
                                                                <span>@displayText</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">-</span>
                                                            }
                                                        }
                                                    </td>
                                                }
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else if (Model.IsFortigateReport)
                        {
                            @Html.Partial("_FortigateReport", Model)
                        }
                        else
                        {
                            <table class="table table-bordered table-sm table-hover mb-0 text-center bg-white report-table-grouped" id="smscReportTable">
                                <thead>
                                    <tr>
                                        <th rowspan="2"
                                            class="align-middle bg-light"
                                            style="position:sticky; top:0; left:0; z-index:6; min-width:180px;">
                                            Monitoring Type
                                        </th>
                                        <th rowspan="2"
                                            class="align-middle bg-light"
                                            style="position:sticky; top:0; left:180px; z-index:6; min-width:160px;">
                                            Item
                                        </th>

                                        @if (Model.Dates != null)
                                        {
                                            for (int d = 0; d < Model.Dates.Count; d++)
                                            {
                                                <th class="text-center bg-light"
                                                    style="position:sticky; top:0; z-index:5; min-width:55px;">
                                                    <div class="font-weight-bold">
                                                        @Model.Dates[d].ToString("dd")
                                                    </div>
                                                </th>
                                            }
                                        }
                                    </tr>
                                    <tr>
                                        @if (Model.Dates != null)
                                        {
                                            for (int d = 0; d < Model.Dates.Count; d++)
                                            {
                                                <th class="text-center bg-light"
                                                    style="position:sticky; top:39px; z-index:5; min-width:55px;">
                                                    <small>@Model.Dates[d].ToString("ddd")</small>
                                                </th>
                                            }
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < uniqueRows.Count; i++)
                                    {
                                        var currentRow = uniqueRows[i];

                                        bool showMonitoringType = true;

                                        for (int x = 0; x < i; x++)
                                        {
                                            if (uniqueRows[x].MonitoringTypeName == currentRow.MonitoringTypeName)
                                            {
                                                showMonitoringType = false;
                                                break;
                                            }
                                        }

                                        int sameTypeCount = 0;

                                        for (int y = 0; y < uniqueRows.Count; y++)
                                        {
                                            if (uniqueRows[y].MonitoringTypeName == currentRow.MonitoringTypeName)
                                            {
                                                sameTypeCount++;
                                            }
                                        }

                                        <tr data-group="@currentRow.MonitoringTypeName">
                                            @if (showMonitoringType)
                                            {
                                                <td rowspan="@sameTypeCount"
                                                    class="align-middle bg-light font-weight-bold text-left"
                                                    style="position:sticky; left:0; z-index:4; min-width:180px;">
                                                    @currentRow.MonitoringTypeName
                                                </td>
                                            }

                                            <td class="align-middle text-left bg-white"
                                                style="position:sticky; left:180px; z-index:4; min-width:160px;">
                                                @currentRow.ItemName
                                            </td>

                                            @if (Model.Dates != null)
                                            {
                                                for (int d = 0; d < Model.Dates.Count; d++)
                                                {
                                                    string displayText = "";
                                                    string entryMode = "";
                                                    bool isChecked = false;
                                                    bool foundRow = false;

                                                    for (int r = 0; r < Model.ReportData.Count; r++)
                                                    {
                                                        if (Model.ReportData[r].MonitoringTypeName == currentRow.MonitoringTypeName &&
                                                        Model.ReportData[r].ItemName == currentRow.ItemName &&
                                                        Model.ReportData[r].EntryDate.Date == Model.Dates[d].Date)
                                                        {
                                                            foundRow = true;

                                                            if (Model.ReportData[r].EntryMode != null)
                                                            {
                                                                entryMode = Model.ReportData[r].EntryMode.Trim();
                                                            }

                                                            isChecked = Model.ReportData[r].IsChecked;

                                                            if (Model.ReportData[r].ConfigValue != null)
                                                            {
                                                                displayText = Model.ReportData[r].ConfigValue.Trim();
                                                            }

                                                            break;
                                                        }
                                                    }

                                                    <td class="text-center align-middle" style="min-width:55px;">
                                                        @if (!foundRow)
                                                        {
                                                            <span class="text-muted">-</span>
                                                        }
                                                        else if (entryMode == "Checkbox")
                                                        {
                                                            if (isChecked)
                                                            {
                                                                <i class="fas fa-check text-success"></i>
                                                            }
                                                            else
                                                            {
                                                                <i class="fas fa-times text-danger"></i>
                                                            }
                                                        }
                                                        else if (entryMode == "Value")
                                                        {
                                                            if (!string.IsNullOrWhiteSpace(displayText))
                                                            {
                                                                <span>@displayText</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">-</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            if (!string.IsNullOrWhiteSpace(displayText))
                                                            {
                                                                <span>@displayText</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">-</span>
                                                            }
                                                        }
                                                    </td>
                                                }
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-2 report-pagination-footer">
                        <div class="text-muted small">
                            Showing <span id="reportStartEntryBottom">0</span> to <span id="reportEndEntryBottom">0</span> of <span id="reportTotalEntryBottom">0</span> entries
                        </div>

                        <ul class="pagination pagination-sm mb-0" id="reportPagination"></ul>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            if ($('#selectedProductId').hasClass('select2-hidden-accessible')) {
                $('#selectedProductId').select2('destroy');
            }

            $('#selectedProductId').select2({
                theme: 'bootstrap4',
                placeholder: 'Select Product',
                allowClear: true,
                minimumResultsForSearch: 0,
                width: '100%'
            });

            function setRangeValues(start, end) {
                $('#fromDate').val(start.format('YYYY-MM-DD'));
                $('#toDate').val(end.format('YYYY-MM-DD'));
                $('#dateRange').val(start.format('DD MMM YYYY') + ' - ' + end.format('DD MMM YYYY'));
            }

            var today = moment();
            var startDate;
            var endDate;

            if ($('#fromDate').val() !== '' && $('#toDate').val() !== '') {
                startDate = moment($('#fromDate').val(), 'YYYY-MM-DD');
                endDate = moment($('#toDate').val(), 'YYYY-MM-DD');
            }
            else {
                startDate = today.clone();
                endDate = today.clone();
            }

            $('#dateRange').daterangepicker({
                autoUpdateInput: false,
                opens: 'center',
                drops: 'down',
                linkedCalendars: false,
                alwaysShowCalendars: true,
                showDropdowns: true,
                autoApply: false,
                maxDate: today,
                startDate: startDate,
                endDate: endDate,
                maxSpan: {
                    days: 31
                },
                locale: {
                    format: 'DD MMM YYYY',
                    cancelLabel: 'Clear',
                    applyLabel: 'Apply'
                }
            });

            if ($('#fromDate').val() !== '' && $('#toDate').val() !== '') {
                setRangeValues(startDate, endDate);
            }

            $('#dateRange').on('apply.daterangepicker', function (ev, picker) {
                setRangeValues(picker.startDate, picker.endDate);
            });

            $('#dateRange').on('cancel.daterangepicker', function () {
                $('#dateRange').val('');
                $('#fromDate').val('');
                $('#toDate').val('');
            });

            $('#dateRangeIcon').on('click', function () {
                $('#dateRange').trigger('click');
            });

            $('#reportForm').on('submit', function (e) {
                var productId = $('#selectedProductId').val();
                var fromDate = $('#fromDate').val();
                var toDate = $('#toDate').val();

                if (productId === '' || productId === null) {
                    alert('Please select product.');
                    e.preventDefault();
                    return false;
                }

                if (fromDate === '' || toDate === '') {
                    alert('Please select date range.');
                    e.preventDefault();
                    return false;
                }

                var from = moment(fromDate, 'YYYY-MM-DD');
                var to = moment(toDate, 'YYYY-MM-DD');

                if (to.isBefore(from)) {
                    alert('Start date cannot be greater than end date.');
                    e.preventDefault();
                    return false;
                }

                var dayDifference = to.diff(from, 'days');

                if (dayDifference > 31) {
                    alert('Maximum report range is 31 days only.');
                    e.preventDefault();
                    return false;
                }
            });

            function buildGroupedPagination(tableSelector) {
                var pageSize = parseInt($('#reportPageSize').val());
                var rows = $(tableSelector + ' tbody tr');
                var groupNames = [];
                var added = {};

                rows.each(function () {
                    var groupName = $(this).attr('data-group');

                    if (groupName && !added[groupName]) {
                        added[groupName] = true;
                        groupNames.push(groupName);
                    }
                });

                function renderPage(pageNumber) {
                    rows.hide();

                    var totalEntries = groupNames.length;
                    var totalPages = Math.ceil(totalEntries / pageSize);

                    if (totalPages === 0) {
                        totalPages = 1;
                    }

                    if (pageNumber < 1) {
                        pageNumber = 1;
                    }

                    if (pageNumber > totalPages) {
                        pageNumber = totalPages;
                    }

                    var startIndex = (pageNumber - 1) * pageSize;
                    var endIndex = startIndex + pageSize;

                    var visibleGroups = groupNames.slice(startIndex, endIndex);

                    for (var i = 0; i < visibleGroups.length; i++) {
                        $(tableSelector + ' tbody tr[data-group="' + visibleGroups[i].replace(/"/g, '\\"') + '"]').show();
                    }

                    var startEntry = totalEntries === 0 ? 0 : startIndex + 1;
                    var endEntry = endIndex > totalEntries ? totalEntries : endIndex;

                    $('#reportStartEntry').text(startEntry);
                    $('#reportEndEntry').text(endEntry);
                    $('#reportTotalEntry').text(totalEntries);

                    $('#reportStartEntryBottom').text(startEntry);
                    $('#reportEndEntryBottom').text(endEntry);
                    $('#reportTotalEntryBottom').text(totalEntries);

                    buildPaginationButtons(pageNumber, totalPages);
                }

                function buildPaginationButtons(currentPage, totalPages) {
                    var pagination = $('#reportPagination');
                    pagination.empty();

                    var prevDisabled = currentPage === 1 ? 'disabled' : '';
                    pagination.append('<li class="page-item ' + prevDisabled + '"><a class="page-link report-page-link" href="#" data-page="' + (currentPage - 1) + '">Previous</a></li>');

                    for (var i = 1; i <= totalPages; i++) {
                        var activeClass = currentPage === i ? 'active' : '';
                        pagination.append('<li class="page-item ' + activeClass + '"><a class="page-link report-page-link" href="#" data-page="' + i + '">' + i + '</a></li>');
                    }

                    var nextDisabled = currentPage === totalPages ? 'disabled' : '';
                    pagination.append('<li class="page-item ' + nextDisabled + '"><a class="page-link report-page-link" href="#" data-page="' + (currentPage + 1) + '">Next</a></li>');
                }

                $('#reportPagination').off('click', '.report-page-link').on('click', '.report-page-link', function (e) {
                    e.preventDefault();

                    var page = parseInt($(this).attr('data-page'));

                    if (!isNaN(page)) {
                        renderPage(page);
                    }
                });

                $('#reportPageSize').off('change').on('change', function () {
                    pageSize = parseInt($(this).val());
                    renderPage(1);
                });

                renderPage(1);
            }

            function buildPingPagination() {
                var pageSize = parseInt($('#reportPageSize').val());
                var rows = $('#pingReportTable tbody tr');

                function renderPage(pageNumber) {
                    rows.hide();

                    var totalEntries = rows.length;
                    var totalPages = Math.ceil(totalEntries / pageSize);

                    if (totalPages === 0) {
                        totalPages = 1;
                    }

                    if (pageNumber < 1) {
                        pageNumber = 1;
                    }

                    if (pageNumber > totalPages) {
                        pageNumber = totalPages;
                    }

                    var startIndex = (pageNumber - 1) * pageSize;
                    var endIndex = startIndex + pageSize;

                    rows.slice(startIndex, endIndex).show();

                    var startEntry = totalEntries === 0 ? 0 : startIndex + 1;
                    var endEntry = endIndex > totalEntries ? totalEntries : endIndex;

                    $('#reportStartEntry').text(startEntry);
                    $('#reportEndEntry').text(endEntry);
                    $('#reportTotalEntry').text(totalEntries);

                    $('#reportStartEntryBottom').text(startEntry);
                    $('#reportEndEntryBottom').text(endEntry);
                    $('#reportTotalEntryBottom').text(totalEntries);

                    buildPaginationButtons(pageNumber, totalPages);
                }

                function buildPaginationButtons(currentPage, totalPages) {
                    var pagination = $('#reportPagination');
                    pagination.empty();

                    var prevDisabled = currentPage === 1 ? 'disabled' : '';
                    pagination.append('<li class="page-item ' + prevDisabled + '"><a class="page-link report-page-link" href="#" data-page="' + (currentPage - 1) + '">Previous</a></li>');

                    for (var i = 1; i <= totalPages; i++) {
                        var activeClass = currentPage === i ? 'active' : '';
                        pagination.append('<li class="page-item ' + activeClass + '"><a class="page-link report-page-link" href="#" data-page="' + i + '">' + i + '</a></li>');
                    }

                    var nextDisabled = currentPage === totalPages ? 'disabled' : '';
                    pagination.append('<li class="page-item ' + nextDisabled + '"><a class="page-link report-page-link" href="#" data-page="' + (currentPage + 1) + '">Next</a></li>');
                }

                $('#reportPagination').off('click', '.report-page-link').on('click', '.report-page-link', function (e) {
                    e.preventDefault();

                    var page = parseInt($(this).attr('data-page'));

                    if (!isNaN(page)) {
                        renderPage(page);
                    }
                });

                $('#reportPageSize').off('change').on('change', function () {
                    pageSize = parseInt($(this).val());
                    renderPage(1);
                });

                renderPage(1);
            }

            @if (Model.SelectedProductId.HasValue && Model.HasData && Model.ReportData != null && Model.ReportData.Count > 0)
            {
                    <text>
                    if (@(Model.IsPingReport.ToString().ToLower())) {
                        buildPingPagination();
                    }
                    else if (@(Model.IsFortigateReport.ToString().ToLower())) {
                        buildGroupedPagination('#fortigateReportTable');
                    }
                    else {
                        buildGroupedPagination('#smscReportTable');
                    }
                    </text>
            }
        });
    </script>
}