@model EmployeeAccessSystem.Models.FortigateItem

<div class="modal-header">
    <h5 class="modal-title">Edit Fortigate Item</h5>
    <button type="button" class="close" data-dismiss="modal">
        <span>&times;</span>
    </button>
</div>

<form id="fortigateItemEditForm" method="post" action="/FortigateItem/Edit">
    <div class="modal-body">
        <input type="hidden" asp-for="FortigateItemId" />

        <div class="form-group">
            <label>Fortigate Category</label>
            <select asp-for="FortigateCategoryId" asp-items="ViewBag.FortigateCategoryList" class="form-control">
                <option value="">Select Fortigate Category</option>
            </select>
            <span asp-validation-for="FortigateCategoryId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Item Name</label>
            <input asp-for="ItemName" class="form-control" placeholder="Enter item name" />
            <span asp-validation-for="ItemName" class="text-danger"></span>
        </div>

        <div class="form-group mb-0">
            <div class="custom-control custom-switch">
                <input asp-for="IsActive" type="checkbox" class="custom-control-input" id="editIsActive">
                <label class="custom-control-label" for="editIsActive">Active</label>
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Back</button>
        <button type="submit" class="btn btn-primary">Update</button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />