@model EmployeeAccessSystem.Models.FortigateItem

<div class="modal-header">
    <h5 class="modal-title">Delete Fortigate Item</h5>
    <button type="button" class="close" data-dismiss="modal">
        <span>&times;</span>
    </button>
</div>

<form id="fortigateItemDeleteForm" method="post" action="/FortigateItem/DeleteConfirmed">
    <div class="modal-body">
        <input type="hidden" name="id" value="@Model.FortigateItemId" />

        <div class="form-group">
            <label>Fortigate Category</label>
            <input type="text" class="form-control" value="@Model.CategoryName" readonly />
        </div>

        <div class="form-group mb-0">
            <label>Item Name</label>
            <input type="text" class="form-control" value="@Model.ItemName" readonly />
        </div>

        <div class="mt-3">
            Are you sure you want to delete this fortigate item?
        </div>
    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Back</button>
        <button type="submit" class="btn btn-danger">Delete</button>
    </div>
</form>