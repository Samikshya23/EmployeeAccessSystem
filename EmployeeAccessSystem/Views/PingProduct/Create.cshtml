@model EmployeeAccessSystem.Models.PingProduct
@{
    Layout = null;
}

<form asp-action="Create" method="post" id="createPingProductForm">
    @Html.AntiForgeryToken()

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row">
        <div class="col-md-12">
            <div class="form-group">
                <label asp-for="ProductId" class="font-weight-bold">Product</label>
                <select asp-for="ProductId" asp-items="ViewBag.ProductList" class="form-control">
                    <option value="">Select Product</option>
                </select>
                <span asp-validation-for="ProductId" class="text-danger small"></span>
            </div>
        </div>

        <div class="col-md-12">
            <div class="form-group">
                <label asp-for="IPAddress" class="font-weight-bold">IP Address</label>
                <input asp-for="IPAddress" class="form-control" placeholder="Enter IP Address" />
                <span asp-validation-for="IPAddress" class="text-danger small"></span>
            </div>
        </div>

        <div class="col-md-12">
            <div class="form-group">
                <label asp-for="ServerHostName" class="font-weight-bold">Server Host Name</label>
                <input asp-for="ServerHostName" class="form-control" placeholder="Enter Server Host Name" />
                <span asp-validation-for="ServerHostName" class="text-danger small"></span>
            </div>
        </div>

        <div class="col-md-12">
            <div class="form-group mb-0">
                <div class="custom-control custom-switch">
                    <input asp-for="IsActive" type="checkbox" class="custom-control-input" id="createIsActiveSwitch" />
                    <label class="custom-control-label font-weight-bold" for="createIsActiveSwitch">Active</label>
                </div>
                <span asp-validation-for="IsActive" class="text-danger small"></span>
            </div>
        </div>
    </div>

    <div class="modal-footer px-0 pb-0 pt-3">
        <button type="button" class="btn btn-default" data-dismiss="modal">Back</button>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save mr-1"></i>Save
        </button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />