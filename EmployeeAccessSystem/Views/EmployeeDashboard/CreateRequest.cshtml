@model EmployeeAccessSystem.Models.AccessRequest

@{
    // ViewData["Title"] = "Create Request";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<style>
    .request-page {
        min-height: calc(100vh - 80px);
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 40px 20px;
        background: #f4f6f9;
    }

    .request-card {
        width: 100%;
        max-width: 760px;
        background: #ffffff;
        border-radius: 28px;
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.08);
        padding: 34px 34px 28px 34px;
        border: 1px solid #eef1f5;
    }

    .request-title {
        font-size: 34px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 8px;
    }

    .request-subtitle {
        color: #6b7280;
        font-size: 15px;
        margin-bottom: 28px;
    }

    .form-label-custom {
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 8px;
        display: block;
        font-size: 15px;
    }

    .form-control-custom,
    .form-select-custom,
    .form-textarea-custom {
        width: 100%;
        border: 1.5px solid #e5e7eb;
        border-radius: 16px;
        background: #f9fafb;
        padding: 14px 16px;
        font-size: 16px;
        color: #111827;
        transition: all 0.2s ease;
        box-shadow: none;
    }

    .form-control-custom,
    .form-select-custom {
        height: 56px;
    }

    .form-textarea-custom {
        min-height: 130px;
        resize: vertical;
    }

    .form-control-custom:focus,
    .form-select-custom:focus,
    .form-textarea-custom:focus {
        outline: none;
        border-color: #3b82f6;
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.10);
    }

    .readonly-box {
        background: #eef2f7 !important;
        color: #4b5563;
    }

    .field-gap {
        margin-bottom: 22px;
    }

    .request-actions {
        display: flex;
        justify-content: flex-end;
        gap: 14px;
        margin-top: 10px;
    }

    .btn-cancel-custom {
        border: 1px solid #d1d5db;
        background: #ffffff;
        color: #374151;
        padding: 12px 24px;
        border-radius: 999px;
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.2s ease;
    }

    .btn-cancel-custom:hover {
        background: #f3f4f6;
        color: #111827;
        text-decoration: none;
    }

    .btn-submit-custom {
        border: none;
        background: linear-gradient(135deg, #1677ff, #0d6efd);
        color: #ffffff;
        padding: 12px 26px;
        border-radius: 999px;
        font-size: 15px;
        font-weight: 600;
        transition: 0.2s ease;
        box-shadow: 0 10px 20px rgba(13, 110, 253, 0.18);
    }

    .btn-submit-custom:hover {
        transform: translateY(-1px);
        box-shadow: 0 14px 24px rgba(13, 110, 253, 0.22);
    }

    .alert {
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 20px;
    }

    .text-danger {
        font-size: 14px;
        margin-top: 6px;
        display: block;
    }

    @@media (max-width: 768px) {
        .request-card {
            padding: 24px 18px;
            border-radius: 22px;
        }

        .request-title {
            font-size: 28px;
        }

        .request-actions {
            flex-direction: column;
        }

        .btn-cancel-custom,
        .btn-submit-custom {
            width: 100%;
            text-align: center;
        }
    }
</style>

<div class="request-page">
    <div class="request-card">
        <div class="request-title">Create Access Request</div>
        <div class="request-subtitle">
            Fill in the details below to request access to a specific server resource.
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }

        <form asp-action="CreateRequest" method="post">
            <div class="field-gap">
                <label class="form-label-custom">Asset Tag</label>
                <input asp-for="AssetTag" class="form-control-custom" placeholder="Enter asset tag" />
                <span asp-validation-for="AssetTag" class="text-danger"></span>
            </div>

            <div class="field-gap">
                <label class="form-label-custom">Category</label>
                <select asp-for="CategoryId" class="form-select-custom" id="categoryDropdown">
                    <option value="">Select Category</option>
                    @foreach (var item in ViewBag.Categories)
                    {
                        <option value="@item.CategoryId">@item.CategoryName</option>
                    }
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="field-gap">
                <label class="form-label-custom">Server Name</label>
                <select asp-for="SubCategoryId" class="form-select-custom" id="subCategoryDropdown">
                    <option value="">Select Server</option>
                    @foreach (var item in ViewBag.SubCategories)
                    {
                        <option value="@item.SubCategoryId"
                                data-category="@item.CategoryId"
                                data-ip="@item.ServerIP">
                            @item.ServerName
                        </option>
                    }
                </select>
                <span asp-validation-for="SubCategoryId" class="text-danger"></span>
            </div>

            <div class="field-gap">
                <label class="form-label-custom">Server IP</label>
                <input type="text"
                       id="serverIpDisplay"
                       class="form-control-custom readonly-box"
                       placeholder="Server IP will appear here"
                       readonly />
            </div>

            <div class="field-gap">
                <label class="form-label-custom">Duration</label>
                <select asp-for="Duration" class="form-select-custom">
                    <option value="">Select Duration</option>
                    <option value="1 Day">1 Day</option>
                    <option value="3 Days">3 Days</option>
                    <option value="1 Week">1 Week</option>
                    <option value="2 Weeks">2 Weeks</option>
                    <option value="1 Month">1 Month</option>
             
                </select>
                <span asp-validation-for="Duration" class="text-danger"></span>
            </div>

            <div class="field-gap">
                <label class="form-label-custom">Justification</label>
                <textarea asp-for="RequestReason"
                          class="form-textarea-custom"
                          placeholder="Explain why you need access"></textarea>
                <span asp-validation-for="RequestReason" class="text-danger"></span>
            </div>

            <div class="request-actions">
                <a asp-action="Index" class="btn-cancel-custom">Cancel</a>
                <button type="submit" class="btn-submit-custom">Submit Request</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const categoryDropdown = document.getElementById("categoryDropdown");
        const subCategoryDropdown = document.getElementById("subCategoryDropdown");
        const serverIpDisplay = document.getElementById("serverIpDisplay");

        function filterServers() {
            const selectedCategory = categoryDropdown.value;

            for (let i = 0; i < subCategoryDropdown.options.length; i++) {
                const option = subCategoryDropdown.options[i];
                const optionCategory = option.getAttribute("data-category");

                if (!optionCategory) {
                    option.style.display = "block";
                    continue;
                }

                if (optionCategory === selectedCategory) {
                    option.style.display = "block";
                } else {
                    option.style.display = "none";
                }
            }

            subCategoryDropdown.value = "";
            serverIpDisplay.value = "";
        }

        function fillServerIp() {
            const selectedOption = subCategoryDropdown.options[subCategoryDropdown.selectedIndex];
            const ip = selectedOption ? selectedOption.getAttribute("data-ip") : "";
            serverIpDisplay.value = ip || "";
        }

        categoryDropdown.addEventListener("change", filterServers);
        subCategoryDropdown.addEventListener("change", fillServerIp);
    </script>
}