@model EmployeeAccessSystem.Models.Employee

@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="container pt-4">
    <h2>My Profile</h2>
    <hr />

    <p><strong>Name:</strong> @Model.FullName</p>
    <p><strong>Email:</strong> @Model.Email</p>
    <p><strong>Department:</strong> @Model.DepartmentName</p>
    <p><strong>Supervisor:</strong> @Model.SupervisorName</p>
    <p><strong>Status:</strong> @(Model.IsActive ? "Active" : "Inactive")</p>
</div>