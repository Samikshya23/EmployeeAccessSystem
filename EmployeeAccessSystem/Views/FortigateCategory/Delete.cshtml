@model EmployeeAccessSystem.Models.FortigateCategory

@{
    Layout = null;
}

<form asp-action="DeleteConfirmed" method="post" id="deleteFortigateCategoryForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="FortigateCategoryId" value="@Model.FortigateCategoryId" />

    <h5 class="text-center mb-2">
        Are you sure?
    </h5>

    <p class="text-center mb-4" style="color:#000;">
        You want to delete this Fortigate Category
        <span>"@Model.CategoryName"</span>
    </p>

    <div class="modal-footer justify-content-center border-0 pt-0">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">
            Cancel
        </button>
        <button type="submit" class="btn btn-danger">
            Confirm
        </button>
    </div>
</form>