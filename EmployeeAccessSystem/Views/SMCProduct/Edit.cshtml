@model EmployeeAccessSystem.Models.SMCProduct

@{
    Layout = null;
}

<form asp-action="Edit" method="post" id="editSMCProductForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="SMCProductId" />
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <div class="form-group">
        <label asp-for="ProductId" class="font-weight-bold">Product</label>
        <select asp-for="ProductId" asp-items="ViewBag.ProductList" class="form-control">
            <option value="">Select Product</option>
        </select>
        <span asp-validation-for="ProductId" class="text-danger small"></span>
    </div>

    <div class="form-group">
        <label asp-for="SMCProductName" class="font-weight-bold">SMC Product Name</label>
        <input asp-for="SMCProductName" class="form-control" placeholder="Enter SMC Product Name" />
        <span asp-validation-for="SMCProductName" class="text-danger small"></span>
    </div>

    <div class="form-group mb-4">
        <div class="custom-control custom-switch">
            <input asp-for="IsActive" class="custom-control-input" id="EditIsActive" />
            <label class="custom-control-label font-weight-bold" for="EditIsActive">Active</label>
        </div>
        <span asp-validation-for="IsActive" class="text-danger small"></span>
    </div>

    <div class="modal-footer px-0 pb-0">
        <button type="button" class="btn btn-default" data-dismiss="modal">Back</button>
        <button type="submit" class="btn btn-warning">Update</button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />