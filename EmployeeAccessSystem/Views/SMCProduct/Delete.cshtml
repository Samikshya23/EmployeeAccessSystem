@model EmployeeAccessSystem.Models.SMCProduct

@{
    ViewData["Title"] = "Delete SMC Product";
}

<div class="content-header">
    <div class="container-fluid">
        <h2>Delete SMC Product</h2>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card shadow-sm">
            <div class="card-header bg-danger text-white">
                <h3 class="card-title">Delete Confirmation</h3>
            </div>
            <div class="card-body">
                <h5>Are you sure you want to delete this SMC Product?</h5>
                <hr />

                <dl class="row">
                    <dt class="col-sm-3">SMC Product Name</dt>
                    <dd class="col-sm-9">@Model.SMCProductName</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="SMCProductId" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Index" class="btn btn-secondary ml-2">Back</a>
                </form>
            </div>
        </div>
    </div>
</section>