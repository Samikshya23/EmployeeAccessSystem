@model EmployeeAccessSystem.Models.SMCProduct

@{
    Layout = null;
}

<form asp-action="Delete" method="post" id="deleteSMCProductForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="smcProductId" value="@Model.SMCProductId" />

    <p class="text-muted mb-3">Are you sure you want to delete this SMC Product?</p>

    <div class="table-responsive">
        <table class="table table-bordered table-hover mb-0">
            <tr>
                <th>SMC Product Name</th>
                <td>@Model.SMCProductName</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>@(Model.IsActive ? "Active" : "Inactive")</td>
            </tr>
        </table>
    </div>

    <div class="modal-footer px-0 pb-0 mt-3">
        <button type="button" class="btn btn-default" data-dismiss="modal">Back</button>
        <button type="submit" class="btn btn-danger">Delete</button>
    </div>
</form>