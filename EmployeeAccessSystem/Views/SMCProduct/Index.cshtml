@model IEnumerable<EmployeeAccessSystem.Models.SMCProduct>

@{
    ViewData["Title"] = "SMC Product";
    int sn = 1;
}

<section class="content pt-2 pb-0">
    <div class="container-fluid px-0">

        <div class="row mb-2 mx-0 align-items-center">
            <div class="col-sm-6 px-0">
                <h3 class="mb-0">SMC Product</h3>
            </div>
            <div class="col-sm-6 text-right px-0">
                <a asp-action="Create"
                   asp-controller="SMCProduct"
                   class="btn btn-primary rounded-pill open-modal-btn"
                   data-title="Add SMC Product">
                    <i class="fas fa-plus mr-1"></i> Add
                </a>
            </div>
        </div>

        <div class="card mb-0 border-left border-right border-bottom shadow-none rounded-0">
            <div class="card-header bg-white border-bottom-0 py-1 px-2 rounded-0">
                <div class="d-flex justify-content-end">
                    <div class="col-md-3 px-0">
                        <input type="text"
                               id="customSearch"
                               class="form-control form-control-sm"
                               placeholder="Search" />
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                <table id="smcProductTable"
                       class="table table-bordered table-hover table-sm mb-0 rounded-0"
                       style="border-color:#dee2e6;">
                    <thead class="bg-light border-bottom">
                        <tr>
                            <th class="text-center align-middle" style="width: 70px;">SN</th>
                            <th class="text-center align-middle">SMC Product Name</th>
                            <th class="text-center align-middle" style="width: 140px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center align-middle">@sn</td>

                                    <td class="align-middle">
                                        @item.SMCProductName

                                        @if (!item.IsActive)
                                        {
                                            <span class="text-muted ml-2">(Inactive)</span>
                                        }
                                    </td>

                                    <td class="text-center align-middle">
                                        <a asp-action="Edit"
                                           asp-controller="SMCProduct"
                                           asp-route-id="@item.SMCProductId"
                                           class="btn btn-sm btn-light border open-modal-btn"
                                           data-title="Edit SMC Product"
                                           title="Edit">
                                            <i class="fas fa-pen"></i>
                                        </a>

                                        <a asp-action="Delete"
                                           asp-controller="SMCProduct"
                                           asp-route-id="@item.SMCProductId"
                                           class="btn btn-sm btn-outline-danger open-modal-btn ml-1"
                                           data-title="Delete SMC Product"
                                           title="Delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </td>
                                </tr>

                                sn++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>

<div class="modal fade" id="mainActionModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered modal-md" role="document">
        <div class="modal-content rounded-0">
            <div class="modal-header">
                <h5 class="modal-title" id="mainActionModalTitle">SMC Product</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body" id="mainActionModalBody">
                <div class="text-center py-3">
                    <i class="fas fa-spinner fa-spin mr-2"></i> Loading...
                </div>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <div class="position-fixed" style="top: 15px; right: 15px; z-index: 1055;">

        @if (TempData["Success"] != null)
        {
            <div class="toast bg-success text-white fade" id="successToast" data-delay="3000">
                <div class="toast-header bg-success text-white border-0">
                    <strong class="mr-auto">Success</strong>
                    <small>Now</small>
                    <button type="button" class="close text-white" data-dismiss="toast">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="toast-body">
                    @TempData["Success"]
                </div>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="toast bg-danger text-white fade" id="errorToast" data-delay="4000">
                <div class="toast-header bg-danger text-white border-0">
                    <strong class="mr-auto">Error</strong>
                    <small>Now</small>
                    <button type="button" class="close text-white" data-dismiss="toast">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="toast-body">
                    @TempData["Error"]
                </div>
            </div>
        }

    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {

            var table = $('#smcProductTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                info: false,
                lengthChange: false,
                pageLength: 7,
                autoWidth: false,
                columnDefs: [
                    { orderable: false, targets: 2 }
                ],
                dom: 't<"row mt-2 mx-0"<"col-md-6 px-0"><"col-md-6 text-right px-0"p>>'
            });

            $('#customSearch').on('keyup', function () {
                table.search(this.value).draw();
            });

            $(document).on('click', '.open-modal-btn', function (e) {
                e.preventDefault();

                var url = $(this).attr('href');
                var title = $(this).data('title') || 'SMC Product';

                $('#mainActionModalTitle').text(title);
                $('#mainActionModalBody').html('<div class="text-center py-3"><i class="fas fa-spinner fa-spin mr-2"></i> Loading...</div>');

                $('#mainActionModalBody').load(url, function () {
                    $('#mainActionModal').modal('show');
                });
            });

                    $(document).on('submit', '#createSMCProductForm, #editSMCProductForm, #deleteSMCProductForm', function (e) {
            e.preventDefault();

            var form = $(this);
            var actionUrl = form.attr('action');
            var formData = form.serialize();

            $.ajax({
                type: 'POST',
                url: actionUrl,
                data: formData,
                success: function (response) {

                    if (typeof response === 'string' && response.startsWith('success|')) {
                        var message = response.split('|')[1];
                        $('#mainActionModal').modal('hide');
                        window.location.href = '/SMCProduct/Index?successMessage=' + encodeURIComponent(message);
                        return;
                    }

                    if (typeof response === 'string' && response.startsWith('error|')) {
                        var errorMessage = response.split('|')[1];
                        $('#mainActionModal').modal('hide');
                        window.location.href = '/SMCProduct/Index?errorMessage=' + encodeURIComponent(errorMessage);
                        return;
                    }

                    var html = $('<div>').html(response);
                    var hasForm =
                        html.find('#createSMCProductForm').length > 0 ||
                        html.find('#editSMCProductForm').length > 0 ||
                        html.find('#deleteSMCProductForm').length > 0;

                    if (hasForm) {
                        $('#mainActionModalBody').html(response);
                    } else {
                        $('#mainActionModal').modal('hide');
                        window.location.href = '/SMCProduct/Index';
                    }
                },
                error: function () {
                    alert('An error occurred while processing your request.');
                }
            });
        });

            $('#mainActionModal').on('hidden.bs.modal', function () {
                $('#mainActionModalBody').html('');
            });

            if ($('#successToast').length) {
                $('#successToast').toast('show');
            }

            if ($('#errorToast').length) {
                $('#errorToast').toast('show');
            }

        });
    </script>

}