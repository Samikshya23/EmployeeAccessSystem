@model IEnumerable<EmployeeAccessSystem.Models.SMCProduct>

@{
    ViewData["Title"] = "SMC Product";
    var sn = 1;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="mb-0">SMC Product</h2>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add SMC Product
            </a>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-bordered table-hover">
                    <thead class="thead-light">
                        <tr>
                            <th style="width:80px;">ID</th>
                            <th>SMC Product Name</th>
                            <th style="width:180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@sn</td>
                                    <td>@item.SMCProductName</td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.SMCProductId" class="btn btn-warning btn-sm mr-2">
                                            Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.SMCProductId" class="btn btn-danger btn-sm">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                                sn++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center">No SMC Products found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>