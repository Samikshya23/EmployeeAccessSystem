@model EmployeeAccessSystem.Models.SMCProduct

@{
    ViewData["Title"] = "Add SMC Product";
}

<div class="content-header">
    <div class="container-fluid">
        <h2>Add SMC Product</h2>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card shadow-sm">
            <div class="card-body">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Create" method="post">
                    <div class="form-group">
                        <label asp-for="SMCProductName"></label>
                        <input asp-for="SMCProductName" class="form-control" />
                        <span asp-validation-for="SMCProductName" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Index" class="btn btn-secondary">Back</a>
                </form>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}