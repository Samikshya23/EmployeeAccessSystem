@model EmployeeAccessSystem.Models.SMCProduct

@{
    ViewData["Title"] = "Add SMC Product";
}

<div class="content-header">
    <div class="container-fluid">
        <h2>Add SMC Product</h2>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card shadow-sm">
            <div class="card-header">
                <h3 class="card-title">Create SMC Product</h3>
            </div>
            <div class="card-body">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Create" method="post">
                    <div class="form-group mb-3">
                        <label asp-for="SMCProductName" class="form-label font-weight-bold">SMC Product Name</label>
                        <input asp-for="SMCProductName" class="form-control" placeholder="Enter SMC Product Name" />
                        <span asp-validation-for="SMCProductName" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label font-weight-bold">Is Active</label>
                    </div>

                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Index" class="btn btn-secondary ml-2">Back</a>
                </form>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}