@model IEnumerable<EmployeeAccessSystem.Models.Employee>
@{
    ViewData["Title"] = "Employee List";
    int sn = 1;
    var search = ViewBag.Search as string;
}

<div class="employee-page-wrapper">
    <div class="employee-list-card">

        <div class="employee-list-header">
            <h3>Employee List</h3>

            <form method="get" asp-action="Index" class="employee-search-bar">
                <input type="text"
                       name="search"
                       value="@search"
                       placeholder="Search employee by name" />
                <button type="submit" class="btn-search">Search</button>
                <a asp-action="Index" class="btn-clear">Clear</a>
            </form>
        </div>

        <div class="employee-table-wrap">
            <table class="employee-modern-table">
                <thead>
                    <tr>
                        <th style="width:60px;">SN</th>
                        <th style="min-width:180px;">Name</th>
                        <th style="min-width:220px;">Email</th>
                        <th style="width:120px;">Department</th>
                        <th style="width:130px;">Role</th>
                        <th style="min-width:140px;">Supervisor</th>
                        <th style="width:220px;" class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@sn</td>
                                <td class="emp-name">@item.FullName</td>
                                <td class="text-truncate-email">@item.Email</td>
                                <td>@item.DepartmentName</td>
                                <td>
                                    @if (item.Role == "Admin")
                                    {
                                        <span class="status-badge badge-admin">Admin</span>
                                    }
                                    else if (item.Role == "Supervisor")
                                    {
                                        <span class="status-badge badge-supervisor">Supervisor</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge badge-employee">Employee</span>
                                    }
                                </td>
                                <td>
                                    @(string.IsNullOrWhiteSpace(item.SupervisorName) ? "-" : item.SupervisorName)
                                </td>
                                <td class="text-center">
                                    <div class="action-box">
                                        <a asp-action="Details"
                                           asp-route-id="@item.EmployeeId"
                                           class="action-link action-details">
                                            Details
                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@item.EmployeeId"
                                           class="action-link action-edit">
                                            Edit
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@item.EmployeeId"
                                           class="action-link action-delete">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>

                            sn++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="no-data">No employees found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .employee-page-wrapper {
        padding: 8px 12px 16px 12px;
        background: #f4f6f9;
    }

    .employee-list-card {
        background: #ffffff;
        border-radius: 20px;
        padding: 18px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .employee-list-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 16px;
    }

        .employee-list-header h3 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            color: #0f172a;
        }

    .employee-search-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

        .employee-search-bar input {
            width: 300px;
            max-width: 100%;
            height: 42px;
            border: 1px solid #d9e2ec;
            border-radius: 12px;
            padding: 0 14px;
            font-size: 0.94rem;
            outline: none;
            background: #fff;
        }

            .employee-search-bar input:focus {
                border-color: #0f172a;
                box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.06);
            }

    .btn-search,
    .btn-clear {
        height: 42px;
        padding: 0 18px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.92rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        transition: 0.2s ease;
    }

    .btn-search {
        background: #0b1533;
        color: #fff;
    }

        .btn-search:hover {
            background: #162347;
            color: #fff;
        }

    .btn-clear {
        background: #edf2f7;
        color: #0f172a;
    }

        .btn-clear:hover {
            background: #e2e8f0;
            color: #0f172a;
        }

    .employee-table-wrap {
        overflow-x: auto;
    }

    .employee-modern-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 10px;
        table-layout: auto;
    }

        .employee-modern-table thead th {
            background: #eef2f6;
            color: #334155;
            font-size: 0.92rem;
            font-weight: 700;
            padding: 14px 12px;
            white-space: nowrap;
        }

            .employee-modern-table thead th:first-child {
                border-top-left-radius: 14px;
                border-bottom-left-radius: 14px;
            }

            .employee-modern-table thead th:last-child {
                border-top-right-radius: 14px;
                border-bottom-right-radius: 14px;
            }

        .employee-modern-table tbody tr {
            background: #ffffff;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.03);
        }

        .employee-modern-table tbody td {
            padding: 14px 12px;
            vertical-align: middle;
            color: #334155;
            font-size: 0.94rem;
            border-top: 1px solid #f1f5f9;
            border-bottom: 1px solid #f1f5f9;
        }

            .employee-modern-table tbody td:first-child {
                border-left: 1px solid #f1f5f9;
                border-top-left-radius: 14px;
                border-bottom-left-radius: 14px;
                text-align: center;
            }

            .employee-modern-table tbody td:last-child {
                border-right: 1px solid #f1f5f9;
                border-top-right-radius: 14px;
                border-bottom-right-radius: 14px;
            }

    .emp-name {
        font-weight: 600;
        color: #0f172a;
    }

    .text-truncate-email {
        max-width: 220px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .status-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 600;
        min-width: 88px;
        text-align: center;
    }

    .badge-admin {
        background: #fee2e2;
        color: #dc2626;
    }

    .badge-supervisor {
        background: #dbeafe;
        color: #2563eb;
    }

    .badge-employee {
        background: #dcfce7;
        color: #16a34a;
    }

    .action-box {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
        white-space: nowrap;
    }

    .action-link {
        padding: 8px 12px;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        line-height: 1;
        transition: 0.2s ease;
        border-right: 1px solid #e2e8f0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 62px;
    }

        .action-link:last-child {
            border-right: none;
        }

    .action-details {
        color: #0f4c81;
        background: #ffffff;
    }

        .action-details:hover {
            background: #eff6ff;
            color: #0f4c81;
        }

    .action-edit {
        color: #9a5b00;
        background: #ffffff;
    }

        .action-edit:hover {
            background: #fff7e6;
            color: #9a5b00;
        }

    .action-delete {
        color: #c62828;
        background: #ffffff;
    }

        .action-delete:hover {
            background: #fff1f2;
            color: #c62828;
        }

    .no-data {
        text-align: center;
        padding: 26px !important;
        color: #64748b;
        font-weight: 500;
        background: #fff;
    }

    @@media (max-width: 992px) {
        .employee-list-header {
            flex-direction: column;
            align-items: stretch;
        }

        .employee-search-bar {
            width: 100%;
        }

            .employee-search-bar input {
                width: 100%;
            }
    }
</style>