@model EmployeeAccessSystem.Models.PingProductItemValue

@{
    Layout = null;
}

<form asp-action="Create" method="post" id="createPingProductItemValueForm">
    @Html.AntiForgeryToken()

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <div class="form-group">
        <label class="font-weight-bold">Ping Product Item</label>
        <select name="pingProductItemId" asp-items="ViewBag.PingProductItemList" class="form-control" id="PingProductItemId">
            <option value="">Select Ping Product Item</option>
        </select>
    </div>

    <div id="dynamicFieldContainer" class="mt-3">
    </div>

    <div class="form-group mb-4 mt-3">
        <div class="custom-control custom-switch">
            <input type="checkbox" name="isActive" value="true" checked class="custom-control-input" id="CreateIsActive" />
            <input type="hidden" name="isActive" value="false" />
            <label class="custom-control-label font-weight-bold" for="CreateIsActive" id="createStatusLabel">
                Active
            </label>
        </div>
    </div>

    <div class="modal-footer px-0 pb-0">
        <button type="button" class="btn btn-default" data-dismiss="modal">Back</button>
        <button type="submit" class="btn btn-primary">Save</button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />

<script>
    $(document).ready(function () {

        function updateCreateStatus() {
            if ($('#CreateIsActive').is(':checked')) {
                $('#createStatusLabel').text('Active');
            } else {
                $('#createStatusLabel').text('Inactive');
            }
        }

        updateCreateStatus();

        $('#CreateIsActive').change(function () {
            updateCreateStatus();
        });

        $('#PingProductItemId').change(function () {
            var itemId = $(this).val();

            if (!itemId) {
                $('#dynamicFieldContainer').html('');
                return;
            }

            $.get('/PingProductItemValue/LoadFieldsByItem', { pingProductItemId: itemId }, function (html) {
                $('#dynamicFieldContainer').html(html);
            });
        });

    });
</script>