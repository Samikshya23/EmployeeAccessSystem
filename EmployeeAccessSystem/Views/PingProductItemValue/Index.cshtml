@model IEnumerable<EmployeeAccessSystem.Models.PingProductItemValue>

@{
    ViewData["Title"] = "Ping Product Item Value";
    int sn = 1;
    var shownItemNames = new List<string>();
}

<section class="content pt-2 pb-0">
    <div class="container-fluid px-0">

        <div class="row mb-2 mx-0 align-items-center">
            <div class="col-sm-6 px-0">
                <h3 class="mb-0">Ping Product Item Value</h3>
            </div>
            <div class="col-sm-6 text-right px-0">
                <a asp-action="Create"
                   asp-controller="PingProductItemValue"
                   class="btn btn-primary rounded-pill open-modal-btn"
                   data-title="Add Ping Product Item Value">
                    <i class="fas fa-plus mr-1"></i> Add
                </a>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mx-0 mb-2" role="alert">
                @TempData["Success"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mx-0 mb-2" role="alert">
                @TempData["Error"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <div class="card mb-0 border-left border-right border-bottom shadow-none rounded-0">
            <div class="card-header bg-white border-bottom-0 py-1 px-2 rounded-0">
                <div class="d-flex justify-content-end">
                    <div class="col-md-3 px-0">
                        <input type="text"
                               id="customSearch"
                               class="form-control form-control-sm"
                               placeholder="Search" />
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                <table id="pingProductItemValueTable"
                       class="table table-bordered table-hover table-sm mb-0 rounded-0"
                       style="border-color:#dee2e6;">
                    <thead class="bg-light border-bottom">
                        <tr>
                            <th class="text-center align-middle" style="width:70px;">SN</th>
                            <th class="text-center align-middle" style="width:20%;">Item Name</th>
                            <th class="text-center align-middle" style="width:25%;">Field Name</th>
                            <th class="text-center align-middle" style="width:30%;">Field Value</th>
                            <th class="text-center align-middle" style="width:110px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                if (!shownItemNames.Contains(item.ItemName))
                                {
                                    shownItemNames.Add(item.ItemName);

                                    var groupItems = new List<EmployeeAccessSystem.Models.PingProductItemValue>();

                                    foreach (var row in Model)
                                    {
                                        if (row.ItemName == item.ItemName)
                                        {
                                            groupItems.Add(row);
                                        }
                                    }

                                    for (int i = 0; i < groupItems.Count; i++)
                                    {
                                        <tr>
                                            @if (i == 0)
                                            {
                                                <td class="text-center align-middle" rowspan="@groupItems.Count" style="vertical-align: middle !important;">
                                                    @sn
                                                </td>

                                                <td class="align-middle" rowspan="@groupItems.Count" style="vertical-align: middle !important;">
                                                    @item.ItemName
                                                </td>
                                            }

                                            <td class="align-middle">
                                                @groupItems[i].FieldName
                                            </td>

                                            <td class="align-middle">
                                                @groupItems[i].FieldValue
                                                @if (!groupItems[i].IsActive)
                                                {
                                                    <span class="text-muted ml-2">(Inactive)</span>
                                                }
                                            </td>

                                            <td class="text-center align-middle">
                                                <a asp-action="Edit"
                                                   asp-controller="PingProductItemValue"
                                                   asp-route-id="@groupItems[i].PingProductItemValueId"
                                                   class="btn btn-xs btn-light border open-modal-btn"
                                                   data-title="Edit Ping Product Item Value"
                                                   title="Edit">
                                                    <i class="fas fa-pen"></i>
                                                </a>

                                                <a asp-action="Delete"
                                                   asp-controller="PingProductItemValue"
                                                   asp-route-id="@groupItems[i].PingProductItemValueId"
                                                   class="btn btn-xs btn-outline-danger open-modal-btn ml-1"
                                                   data-title="Delete Ping Product Item Value"
                                                   title="Delete">
                                                    <i class="fas fa-trash-alt"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }

                                    sn++;
                                }
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center align-middle">No Ping Product Item Values found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>

<div class="modal fade" id="mainActionModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered modal-md" role="document">
        <div class="modal-content rounded-0">
            <div class="modal-header">
                <h5 class="modal-title" id="mainActionModalTitle">Ping Product Item Value</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body" id="mainActionModalBody">
                <div class="text-center py-3">
                    <i class="fas fa-spinner fa-spin mr-2"></i> Loading...
                </div>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <div class="position-fixed" style="top: 15px; right: 15px; z-index: 1055;">

        @if (TempData["Success"] != null)
        {
            <div class="toast bg-success text-white fade" id="successToast" data-delay="3000">
                <div class="toast-header bg-success text-white border-0">
                    <strong class="mr-auto">Success</strong>
                    <small>Now</small>
                    <button type="button" class="close text-white" data-dismiss="toast">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="toast-body">
                    @TempData["Success"]
                </div>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="toast bg-danger text-white fade" id="errorToast" data-delay="4000">
                <div class="toast-header bg-danger text-white border-0">
                    <strong class="mr-auto">Error</strong>
                    <small>Now</small>
                    <button type="button" class="close text-white" data-dismiss="toast">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="toast-body">
                    @TempData["Error"]
                </div>
            </div>
        }

    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {

            var table = $('#pingProductItemValueTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                info: true,
                lengthChange: true,
                pageLength: 10,
                autoWidth: false,
                columnDefs: [
                    { orderable: true, targets: 0 },
                    { orderable: true, targets: 1 },
                    { orderable: true, targets: 2 },
                    { orderable: true, targets: 3 },
                    { orderable: false, targets: 4 }
                ],
                dom: 'lrtip'
            });

            $('#customSearch').on('keyup', function () {
                table.search(this.value).draw();
            });

            $(document).on('click', '.open-modal-btn', function (e) {
                e.preventDefault();

                var url = $(this).attr('href');
                var title = $(this).data('title') || 'Ping Product Item Value';

                $('#mainActionModalTitle').text(title);
                $('#mainActionModalBody').html('<div class="text-center py-3"><i class="fas fa-spinner fa-spin mr-2"></i> Loading...</div>');

                $('#mainActionModalBody').load(url, function () {
                    $('#mainActionModal').modal('show');
                });
            });

            $(document).on('submit', '#createPingProductItemValueForm, #editPingProductItemValueForm, #deletePingProductItemValueForm', function (e) {
                e.preventDefault();

                var form = $(this);
                var actionUrl = form.attr('action');
                var formData = form.serialize();

                $.ajax({
                    type: 'POST',
                    url: actionUrl,
                    data: formData,
                    success: function (response) {

                        if (typeof response === 'string' && response.startsWith('success|')) {
                            var message = response.split('|')[1];
                            $('#mainActionModal').modal('hide');
                            window.location.href = '/PingProductItemValue/Index?successMessage=' + encodeURIComponent(message);
                            return;
                        }

                        if (typeof response === 'string' && response.startsWith('error|')) {
                            var errorMessage = response.split('|')[1];
                            $('#mainActionModal').modal('hide');
                            window.location.href = '/PingProductItemValue/Index?errorMessage=' + encodeURIComponent(errorMessage);
                            return;
                        }

                        var html = $('<div>').html(response);
                        var hasForm =
                            html.find('#createPingProductItemValueForm').length > 0 ||
                            html.find('#editPingProductItemValueForm').length > 0 ||
                            html.find('#deletePingProductItemValueForm').length > 0;

                        if (hasForm) {
                            $('#mainActionModalBody').html(response);
                        } else {
                            $('#mainActionModal').modal('hide');
                            window.location.href = '/PingProductItemValue/Index';
                        }
                    },
                    error: function () {
                        alert('An error occurred while processing your request.');
                    }
                });
            });

            $('#mainActionModal').on('hidden.bs.modal', function () {
                $('#mainActionModalBody').html('');
            });

            if ($('#successToast').length) {
                $('#successToast').toast('show');
            }

            if ($('#errorToast').length) {
                $('#errorToast').toast('show');
            }

        });
    </script>
}