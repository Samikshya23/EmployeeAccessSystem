@model EmployeeAccessSystem.Models.ProductConfiguration

@{
    Layout = null;
}

<form asp-action="Edit" method="post" id="editConfigurationNodeForm">
    @Html.AntiForgeryToken()
    <input asp-for="NodeId" type="hidden" />

    <div class="modal-header">
        <h4 class="modal-title font-weight-bold">Edit Node</h4>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>

    <div class="modal-body">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2">@ViewBag.Error</div>
        }

        <div class="form-group">
            <label>Product</label>
            <select asp-for="ProductId"
                    asp-items="ViewBag.ProductList"
                    class="form-control">
                <option value="">Select Product</option>
            </select>
            <span asp-validation-for="ProductId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Parent Node</label>
            <select asp-for="ParentNodeId"
                    asp-items="ViewBag.ParentNodeList"
                    class="form-control">
                <option value="">-- Root Node --</option>
            </select>
            <span asp-validation-for="ParentNodeId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Node Name</label>
            <input asp-for="NodeName" class="form-control" />
            <span asp-validation-for="NodeName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Node Type</label>
            <select asp-for="NodeType"
                    class="form-control"
                    id="EditNodeType">
                <option value="">-- Select Node Type --</option>
                <option value="Group">Group</option>
                <option value="Field">Field</option>
            </select>
            <span asp-validation-for="NodeType" class="text-danger"></span>
        </div>

        <div class="form-group edit-input-type-box">
            <label>Input Type</label>
            <select asp-for="InputType" class="form-control" id="EditInputType">
                <option value="">-- Select Input Type --</option>
                <option value="Tick / Cross">Tick / Cross</option>
                <option value="Yes / No">Yes / No</option>
                <option value="UP / DOWN">UP / DOWN</option>
                <option value="Percentage">Percentage</option>
                <option value="Number">Number</option>
                <option value="Text Box">Text Box</option>
                <option value="Date">Date</option>
            </select>
            <span asp-validation-for="InputType" class="text-danger"></span>
        </div>

        <div class="custom-control custom-switch mt-3">
            <input asp-for="IsActive"
                   type="checkbox"
                   class="custom-control-input"
                   id="EditIsActive" />
            <label class="custom-control-label" for="EditIsActive">Active</label>
        </div>
    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Back</button>
        <button type="submit" class="btn btn-warning">Update</button>
    </div>
</form>

<script>
    $(document).ready(function () {
        toggleEditInputType();

        $('#EditNodeType').change(function () {
            toggleEditInputType();
        });

        function toggleEditInputType() {
            var nodeType = $('#EditNodeType').val();

            if (nodeType === 'Field') {
                $('.edit-input-type-box').show();
            } else {
                $('.edit-input-type-box').hide();
                $('#EditInputType').val('');
            }
        }
    });
</script>