@model List<EmployeeAccessSystem.Models.ProductConfigurationIndexItem>

@{
    ViewData["Title"] = "Product Configuration";
    int selectedProductId = ViewBag.SelectedProductId;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2 align-items-center">
            <div class="col-sm-6">
                <h4 class="m-0 font-weight-bold">
                    Product Configuration
                </h4>
            </div>

            <div class="col-sm-6 text-right">
                <button type="button" class="btn btn-primary btn-sm" id="btnAddConfiguration">
                    <i class="fas fa-plus"></i> Add Product Configuration
                </button>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="close" data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="close" data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        }

        @if (Model != null && Model.Count > 0)
        {
            for (int i = 0; i < Model.Count; i++)
            {
                var item = Model[i];

                <div class="card card-outline card-primary mb-3">
                    <div class="card-header py-2">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h3 class="card-title font-weight-bold mb-0">
                                    @item.ProductName
                                </h3>
                            </div>

                            <div class="col-md-4 text-right">
                                <button type="button"
                                        class="btn btn-info btn-sm btnEditConfiguration"
                                        data-product-id="@item.ProductId"
                                        title="Edit Structure">
                                    <i class="fas fa-edit"></i>
                                </button>

                                <form asp-action="Delete" method="post" class="d-inline deleteForm">
                                    <input type="hidden" name="productId" value="@item.ProductId" />

                                    <button type="submit"
                                            class="btn btn-danger btn-sm"
                                            title="Delete Structure">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="card-body p-2">
                        @if (item.Nodes != null && item.Nodes.Count > 0)
                        {
                            for (int j = 0; j < item.Nodes.Count; j++)
                            {
                                @await Html.PartialAsync("_TreeNode", item.Nodes[j])
                            }
                        }
                        else
                        {
                            <div class="text-muted text-center py-3">
                                No structure added for this product.
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="card">
                <div class="card-body text-center text-muted py-4">
                    Click <strong>Add Product Configuration</strong> to create or edit a product structure.
                </div>
            </div>
        }

    </div>
</section>

<div class="modal fade" id="configurationModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content" id="configurationModalContent">
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            $("#btnAddConfiguration").click(function () {
                $.get("/ProductConfiguration/Add", function (data) {
                    $("#configurationModalContent").html(data);
                    $("#configurationModal").modal("show");
                });
            });

            $(document).on("click", ".btnEditConfiguration", function () {
                var productId = $(this).attr("data-product-id");

                $.get("/ProductConfiguration/Add?productId=" + productId, function (data) {
                    $("#configurationModalContent").html(data);
                    $("#configurationModal").modal("show");
                });
            });

            $(document).on("click", ".btnDeleteNode", function () {
                var nodeId = $(this).attr("data-node-id");

                $.get("/ProductConfiguration/DeleteNode?nodeId=" + nodeId, function (data) {
                    $("#configurationModalContent").html(data);
                    $("#configurationModal").modal("show");
                });
            });

            $(".deleteForm").submit(function () {
                return confirm("Are you sure you want to delete this product configuration?");
            });

        });
    </script>
}