@model List<EmployeeAccessSystem.Models.ProductConfigurationIndexItem>

@{
    ViewData["Title"] = "Product Configuration";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2 align-items-center">
            <div class="col-sm-6">
                <h4 class="m-0">
                    <i class="fas fa-project-diagram text-primary"></i>
                    Product Configuration
                </h4>
            </div>
            <div class="col-sm-6 text-right">
                <button type="button" class="btn btn-primary btn-sm" id="btnAddConfiguration">
                    <i class="fas fa-plus"></i> Add Product Configuration
                </button>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="close" data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="close" data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        }

        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title">Saved Configuration Structure</h3>
            </div>

            <div class="card-body p-0">
                <table class="table table-bordered table-hover table-sm mb-0">
                    <thead>
                        <tr>
                            <th style="width:70px;">SN</th>
                            <th style="width:220px;">Product</th>
                            <th>Structure</th>
                            <th style="width:150px;" class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int sn = 1;
                        }

                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@sn</td>
                                    <td>
                                        <span class="badge badge-primary">@item.ProductName</span>
                                    </td>
                                    <td>
                                        @if (item.Nodes != null && item.Nodes.Count > 0)
                                        {
                                            <ul class="mb-0 pl-3">
                                                @foreach (var node in item.Nodes)
                                                {
                                                    @await Html.PartialAsync("_TreeNode", node)
                                                }
                                            </ul>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No structure added.</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <button type="button"
                                                class="btn btn-info btn-sm btnEditConfiguration"
                                                data-product-id="@item.ProductId">
                                            <i class="fas fa-edit"></i>
                                        </button>

                                        <form asp-action="Delete" method="post" class="d-inline deleteForm">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>

                                sn++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">
                                    No product configuration found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>

<div class="modal fade" id="configurationModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content" id="configurationModalContent">
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            $("#btnAddConfiguration").click(function () {
                $.get("/ProductConfiguration/Add", function (data) {
                    $("#configurationModalContent").html(data);
                    $("#configurationModal").modal("show");
                });
            });

            $(".btnEditConfiguration").click(function () {
                var productId = $(this).data("product-id");

                $.get("/ProductConfiguration/Add", { productId: productId }, function (data) {
                    $("#configurationModalContent").html(data);
                    $("#configurationModal").modal("show");
                });
            });

            $(".deleteForm").submit(function () {
                return confirm("Are you sure you want to delete this product configuration?");
            });

        });
    </script>
}