@model EmployeeAccessSystem.Models.ProductConfiguration

@{
    Layout = null;
}

<div class="modal-header bg-white border-bottom">
    <h5 class="modal-title font-weight-bold text-dark">
        Delete Node
    </h5>

    <button type="button" class="close text-dark" data-dismiss="modal">
        <span>&times;</span>
    </button>
</div>

<form asp-action="DeleteNodeConfirmed" method="post">
    <div class="modal-body">

        <input type="hidden" name="nodeId" value="@Model.NodeId" />
        <input type="hidden" name="productId" value="@Model.ProductId" />

        <div class="alert alert-warning">
            Are you sure you want to delete this node?
        </div>

        <div class="border rounded p-2">
            <strong>Node Name:</strong> @Model.NodeName <br />
            <strong>Node Type:</strong> @Model.NodeType <br />
            <strong>Input Type:</strong> @Model.InputType
        </div>

        <small class="text-muted">
            If this node has child nodes, child nodes will also be deleted.
        </small>

    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">
            Cancel
        </button>

        <button type="submit" class="btn btn-danger btn-sm">
            Delete
        </button>
    </div>
</form>