@{
    Layout = null;
    int selectedProductId = ViewBag.SelectedProductId;
    string existingJson = ViewBag.ExistingJson;
}

<div class="modal-header bg-primary">
    <h5 class="modal-title">
        <i class="fas fa-project-diagram"></i> Add Product Configuration
    </h5>
    <button type="button" class="close text-white" data-dismiss="modal">
        <span>&times;</span>
    </button>
</div>

<div class="modal-body">

    <div id="configErrorArea"></div>

    <div class="card card-outline card-primary mb-2">
        <div class="card-body p-2">
            <div class="row align-items-end">
                <div class="col-md-8">
                    <div class="form-group mb-0">
                        <label class="mb-1">Product</label>
                        <select id="ProductId" class="form-control form-control-sm" asp-items="ViewBag.ProductList">
                            <option value="">Select Product</option>
                        </select>
                    </div>
                </div>

                <div class="col-md-4 text-right">
                    <button type="button" class="btn btn-primary btn-sm" id="btnAddMainBlock">
                        <i class="fas fa-plus"></i> Block
                    </button>

                    <button type="button" class="btn btn-success btn-sm" id="btnAddMainField">
                        <i class="fas fa-plus"></i> Field
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card card-outline card-secondary mb-0">
        <div class="card-header py-2">
            <h3 class="card-title">
                Structure Builder
            </h3>
        </div>

        <div class="card-body p-2" id="nodeContainer">
            <div class="text-muted text-center py-3" id="emptyMessage">
                Select product and add block or field.
            </div>
        </div>
    </div>

</div>

<div class="modal-footer">
    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">
        Close
    </button>

    <button type="button" class="btn btn-primary btn-sm" id="btnSaveStructure">
        <i class="fas fa-save"></i> Save Structure
    </button>
</div>

<script>
    $(document).ready(function () {

        var selectedProductId = @selectedProductId;
        var existingNodes = @Html.Raw(existingJson);

        if (selectedProductId > 0) {
            $("#ProductId").val(selectedProductId);
            $("#ProductId").prop("disabled", true);
        }

        if (existingNodes != null && existingNodes.length > 0) {
            $("#emptyMessage").remove();

            for (var i = 0; i < existingNodes.length; i++) {
                renderExistingNode($("#nodeContainer"), existingNodes[i]);
            }
        }

        $("#btnAddMainBlock").click(function () {
            addNode($("#nodeContainer"), "Block");
        });

        $("#btnAddMainField").click(function () {
            addNode($("#nodeContainer"), "Field");
        });

        $("#btnSaveStructure").click(function () {
            saveStructure();
        });

        $("#ProductId").change(function () {
            $("#nodeContainer").html(`
                <div class="text-muted text-center py-3" id="emptyMessage">
                    Select product and add block or field.
                </div>
            `);
        });

    });

    function getInputTypeOptions(selectedValue) {
        var options = [
            "None",
            "Checkbox",
            "Text",
            "Value",
            "Percentage",
            "Number",
            "Yes/No",
            "Up/Down",
            "Date"
        ];

        var html = "";

        for (var i = 0; i < options.length; i++) {
            var value = options[i];

            if (value === selectedValue) {
                html += `<option value="${value}" selected>${value}</option>`;
            }
            else {
                html += `<option value="${value}">${value}</option>`;
            }
        }

        return html;
    }

    function addNode(container, nodeType) {
        $("#emptyMessage").remove();

        var inputType = "None";

        if (nodeType === "Field") {
            inputType = "Checkbox";
        }

        var nodeHtml = `
            <div class="card card-outline card-light mb-1 node-row" data-node-type="${nodeType}">
                <div class="card-body p-2">
                    <div class="row align-items-center">
                        <div class="col-md-5">
                            <input type="text" class="form-control form-control-sm node-name" placeholder="${nodeType} Name" />
                        </div>

                        <div class="col-md-2">
                            <span class="badge ${nodeType === "Block" ? "badge-secondary" : "badge-info"} node-type">${nodeType}</span>
                        </div>

                        <div class="col-md-3">
                            <select class="form-control form-control-sm input-type" ${nodeType === "Block" ? "disabled" : ""}>
                                ${getInputTypeOptions(inputType)}
                            </select>
                        </div>

                        <div class="col-md-2 text-right action-area">
                            ${nodeType === "Block"
                                ? `<button type="button" class="btn btn-primary btn-sm btn-add-block" title="Add child block">
                                        <i class="fas fa-plus"></i>
                                   </button>
                                   <button type="button" class="btn btn-success btn-sm btn-add-field" title="Add field">
                                        <i class="fas fa-plus"></i>
                                   </button>`
                                : ""
                            }

                            <button type="button" class="btn btn-danger btn-sm btn-remove-node" title="Remove">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>

                    <div class="child-container ml-4 mt-2"></div>
                </div>
            </div>
        `;

        container.append(nodeHtml);

        var newNode = container.children(".node-row").last();
        bindNodeButtons(newNode);
    }

    function renderExistingNode(container, node) {
        var nodeType = node.nodeType;

        if (nodeType == null || nodeType === "") {
            nodeType = "Block";
        }

        var inputType = node.inputType;

        if (inputType == null || inputType === "") {
            inputType = "None";
        }

        var nodeHtml = `
            <div class="card card-outline card-light mb-1 node-row" data-node-type="${nodeType}">
                <div class="card-body p-2">
                    <div class="row align-items-center">
                        <div class="col-md-5">
                            <input type="text" class="form-control form-control-sm node-name" placeholder="${nodeType} Name" value="${escapeHtml(node.nodeName)}" />
                        </div>

                        <div class="col-md-2">
                            <span class="badge ${nodeType === "Block" ? "badge-secondary" : "badge-info"} node-type">${nodeType}</span>
                        </div>

                        <div class="col-md-3">
                            <select class="form-control form-control-sm input-type" ${nodeType === "Block" ? "disabled" : ""}>
                                ${getInputTypeOptions(inputType)}
                            </select>
                        </div>

                        <div class="col-md-2 text-right action-area">
                            ${nodeType === "Block"
                                ? `<button type="button" class="btn btn-primary btn-sm btn-add-block" title="Add child block">
                                        <i class="fas fa-plus"></i>
                                   </button>
                                   <button type="button" class="btn btn-success btn-sm btn-add-field" title="Add field">
                                        <i class="fas fa-plus"></i>
                                   </button>`
                                : ""
                            }

                            <button type="button" class="btn btn-danger btn-sm btn-remove-node" title="Remove">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>

                    <div class="child-container ml-4 mt-2"></div>
                </div>
            </div>
        `;

        container.append(nodeHtml);

        var newNode = container.children(".node-row").last();
        bindNodeButtons(newNode);

        if (node.children != null && node.children.length > 0) {
            var childContainer = newNode.find(">.card-body>.child-container");

            for (var i = 0; i < node.children.length; i++) {
                renderExistingNode(childContainer, node.children[i]);
            }
        }
    }

    function bindNodeButtons(node) {
        node.find(">.card-body>.row .btn-add-block").click(function () {
            var childContainer = $(this).closest(".node-row").find(">.card-body>.child-container");
            addNode(childContainer, "Block");
        });

        node.find(">.card-body>.row .btn-add-field").click(function () {
            var childContainer = $(this).closest(".node-row").find(">.card-body>.child-container");
            addNode(childContainer, "Field");
        });

        node.find(">.card-body>.row .btn-remove-node").click(function () {
            $(this).closest(".node-row").remove();

            if ($("#nodeContainer").children(".node-row").length === 0) {
                $("#nodeContainer").html(`
                    <div class="text-muted text-center py-3" id="emptyMessage">
                        Select product and add block or field.
                    </div>
                `);
            }
        });
    }

    function collectNodes(container) {
        var nodes = [];

        container.children(".node-row").each(function () {
            var nodeType = $(this).data("node-type");
            var nodeName = $(this).find(">.card-body>.row .node-name").val();
            var inputType = $(this).find(">.card-body>.row .input-type").val();

            if (nodeType === "Block") {
                inputType = "None";
            }

            var childContainer = $(this).find(">.card-body>.child-container");
            var children = collectNodes(childContainer);

            if (nodeName != null && nodeName.trim() !== "") {
                nodes.push({
                    nodeName: nodeName.trim(),
                    nodeType: nodeType,
                    inputType: inputType,
                    children: children
                });
            }
        });

        return nodes;
    }

    function saveStructure() {
        var productId = $("#ProductId").val();

        if (productId == null || productId === "") {
            showConfigError("Please select product.");
            return;
        }

        var nodes = collectNodes($("#nodeContainer"));

        if (nodes.length === 0) {
            showConfigError("Please add at least one block or field.");
            return;
        }

        var request = {
            productId: parseInt(productId),
            nodes: nodes
        };

        $.ajax({
            url: "/ProductConfiguration/SaveStructure",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(request),
            success: function (response) {
                if (response.success) {
                    $("#configurationModal").modal("hide");
                    location.reload();
                }
                else {
                    showConfigError(response.message);
                }
            },
            error: function () {
                showConfigError("Something went wrong while saving configuration.");
            }
        });
    }

    function showConfigError(message) {
        $("#configErrorArea").html(`
            <div class="alert alert-danger alert-dismissible fade show">
                ${message}
                <button type="button" class="close" data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        `);
    }

    function escapeHtml(value) {
        if (value == null) {
            return "";
        }

        return value
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }
</script>