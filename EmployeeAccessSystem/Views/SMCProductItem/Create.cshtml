@model EmployeeAccessSystem.Models.SMCProductItem

@{
    ViewData["Title"] = "Create SMC Product Item";
}

@section Styles {
    <style>
        .form-card {
            border: none;
            border-radius: 18px;
            box-shadow: 0 6px 18px rgba(17, 24, 39, 0.06);
            overflow: hidden;
        }

        .form-header {
            background: #fff;
            padding: 24px 28px 18px 28px;
            border-bottom: 1px solid #eef2f7;
        }

        .form-title {
            font-size: 1.9rem;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 0;
        }

        .form-subtitle {
            color: #6b7280;
            margin-top: 6px;
            margin-bottom: 0;
        }

        .form-label {
            font-weight: 600;
            color: #374151;
        }

        .form-control, .form-select {
            border-radius: 12px;
            min-height: 46px;
        }

        .btn-pill {
            border-radius: 999px;
            min-width: 110px;
            font-weight: 600;
        }
    </style>
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card form-card">
            <div class="form-header">
                <h2 class="form-title">Create SMC Product Item</h2>
                <p class="form-subtitle">Add a new item under the selected SMC Product.</p>
            </div>

            <div class="card-body p-4">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.Error
                    </div>
                }

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-group mb-3">
                        <label asp-for="SMCProductId" class="form-label">SMC Product</label>
                        <select asp-for="SMCProductId" asp-items="ViewBag.SMCProductList" class="form-control">
                            <option value="">-- Select SMC Product --</option>
                        </select>
                        <span asp-validation-for="SMCProductId" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="ItemName" class="form-label">Item Name</label>
                        <input asp-for="ItemName" class="form-control" placeholder="Enter item name" />
                        <span asp-validation-for="ItemName" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-pill">Back</a>
                        <button type="submit" class="btn btn-primary btn-pill">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}