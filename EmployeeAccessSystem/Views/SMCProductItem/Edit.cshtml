@model EmployeeAccessSystem.Models.SMCProductItem

@{
    Layout = null;
}

<form asp-action="Edit" method="post" id="editSMCProductItemForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="SMCProductItemId" />

    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <div class="form-group">
        <label asp-for="SMCProductId" class="font-weight-bold">SMC Product</label>
        <select asp-for="SMCProductId" asp-items="ViewBag.SMCProductList" class="form-control">
            <option value="">Select SMC Product</option>
        </select>
        <span asp-validation-for="SMCProductId" class="text-danger small"></span>
    </div>

    <div class="form-group">
        <label asp-for="ItemName" class="font-weight-bold">Item Name</label>
        <input asp-for="ItemName" class="form-control" placeholder="Enter item name" />
        <span asp-validation-for="ItemName" class="text-danger small"></span>
    </div>

    <div class="form-group mb-4">
        <div class="custom-control custom-switch">
            <input asp-for="IsActive" class="custom-control-input" id="EditIsActive" />
            <label class="custom-control-label font-weight-bold" for="EditIsActive">Active</label>
        </div>
    </div>

    <div class="modal-footer px-0 pb-0">
        <button type="button" class="btn btn-default" data-dismiss="modal">Back</button>
        <button type="submit" class="btn btn-warning">Update</button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />