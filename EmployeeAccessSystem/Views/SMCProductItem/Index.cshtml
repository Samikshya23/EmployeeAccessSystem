@model IEnumerable<EmployeeAccessSystem.Models.SMCProductItem>

@{
    ViewData["Title"] = "SMC Product Item";
    int sn = 1;
}

<div class="container-fluid pt-2">
    <div class="card shadow-sm">
        <div class="card-header bg-white py-2">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h3 class="mb-0">SMC Product Item</h3>
                </div>

                <div class="col-md-6 text-md-right mt-2 mt-md-0">
                    <a asp-action="Create"
                       asp-controller="SMCProductItem"
                       class="btn btn-primary rounded-pill open-modal-btn"
                       data-title="Add SMC Product Item">
                        <i class="fas fa-plus mr-1"></i> Add
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body p-2">
            <div class="row mb-2">
                <div class="col-md-9"></div>
                <div class="col-md-3">
                    <input type="text" id="customSearch" class="form-control" placeholder="Search item..." />
                </div>
            </div>

            <div class="table-responsive">
                <table id="smcProductItemTable" class="table table-sm table-bordered table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="text-center" style="width:80px;">SN</th>
                            <th class="text-center">SMC Product</th>
                            <th class="text-center">Item Name</th>
                            <th class="text-center" style="width:120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">@sn</td>
                                    <td>@item.SMCProductName</td>
                                    <td>@item.ItemName</td>
                                    <td class="text-center">
                                        <a asp-action="Edit"
                                           asp-controller="SMCProductItem"
                                           asp-route-id="@item.SMCProductItemId"
                                           class="btn btn-sm btn-light border open-modal-btn"
                                           data-title="Edit SMC Product Item"
                                           title="Edit">
                                            <i class="fas fa-pen"></i>
                                        </a>

                                        <a asp-action="Delete"
                                           asp-controller="SMCProductItem"
                                           asp-route-id="@item.SMCProductItemId"
                                           class="btn btn-sm btn-outline-danger open-modal-btn ml-1"
                                           data-title="Delete SMC Product Item"
                                           title="Delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </td>
                                </tr>

                                sn++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center">No SMC Product Items found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mainActionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="mainActionModalTitle">SMC Product Item</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body" id="mainActionModalBody">
                <div class="text-center py-3">
                    <i class="fas fa-spinner fa-spin mr-2"></i> Loading...
                </div>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed p-3" style="top: 15px; right: 15px; z-index: 9999;">
    @if (TempData["Success"] != null)
    {
        <div class="toast bg-success text-white fade" id="successToast" role="alert" aria-live="assertive" aria-atomic="true" data-delay="3000">
            <div class="toast-header bg-success text-white border-0">
                <strong class="mr-auto">Success</strong>
                <small>Now</small>
                <button type="button" class="ml-2 mb-1 close text-white" data-dismiss="toast" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="toast-body">
                @TempData["Success"]
            </div>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="toast bg-danger text-white fade" id="errorToast" role="alert" aria-live="assertive" aria-atomic="true" data-delay="4000">
            <div class="toast-header bg-danger text-white border-0">
                <strong class="mr-auto">Error</strong>
                <small>Now</small>
                <button type="button" class="ml-2 mb-1 close text-white" data-dismiss="toast" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="toast-body">
                @TempData["Error"]
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            var table = $('#smcProductItemTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                info: false,
                lengthChange: false,
                pageLength: 10,
                autoWidth: false,
                columnDefs: [
                    { orderable: false, targets: 3 }
                ],
                dom: 't<"row mt-2"<"col-md-6"><"col-md-6 text-right"p>>'
            });

            $('#customSearch').on('keyup', function () {
                table.search(this.value).draw();
            });

            $(document).on('click', '.open-modal-btn', function (e) {
                e.preventDefault();

                var url = $(this).attr('href');
                var title = $(this).data('title') || 'SMC Product Item';

                $('#mainActionModalTitle').text(title);
                $('#mainActionModalBody').html('<div class="text-center py-3"><i class="fas fa-spinner fa-spin mr-2"></i> Loading...</div>');

                $('#mainActionModalBody').load(url, function (response, status) {
                    if (status === "error") {
                        $('#mainActionModalBody').html('<div class="alert alert-danger mb-0">Failed to load content.</div>');
                        return;
                    }

                    $('#mainActionModal').modal('show');
                });
            });

            $('#successToast').toast('show');
            $('#errorToast').toast('show');
        });
    </script>
}