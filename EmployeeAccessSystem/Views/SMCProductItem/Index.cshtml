@model IEnumerable<EmployeeAccessSystem.Models.SMCProductItem>

@{
    ViewData["Title"] = "SMC Product Items";
    int sn = 1;
}

@section Styles {
    <style>
        .page-card {
            border: none;
            border-radius: 18px;
            box-shadow: 0 6px 18px rgba(17, 24, 39, 0.06);
            overflow: hidden;
        }

        .page-header {
            background: #fff;
            padding: 24px 28px 18px 28px;
            border-bottom: 1px solid #eef2f7;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 700;
            color: #1f2937;
            margin: 0;
        }

        .page-subtitle {
            color: #6b7280;
            margin-top: 6px;
            margin-bottom: 0;
            font-size: 0.95rem;
        }

        .btn-add-custom {
            background: #2563eb;
            color: #fff;
            border: none;
            border-radius: 999px;
            padding: 10px 22px;
            font-weight: 600;
        }

            .btn-add-custom:hover {
                background: #1d4ed8;
                color: #fff;
            }

        .table thead th {
            background: #f8fafc;
            color: #374151;
            font-weight: 700;
            border-bottom: 1px solid #e5e7eb;
            padding-top: 16px;
            padding-bottom: 16px;
        }

        .table td {
            vertical-align: middle;
            padding-top: 16px;
            padding-bottom: 16px;
        }

        .status-btn {
            border: none;
            border-radius: 999px;
            padding: 7px 16px;
            font-size: 0.84rem;
            font-weight: 700;
            min-width: 100px;
            transition: all 0.2s ease;
        }

        .status-active {
            background: #dcfce7;
            color: #166534;
        }

            .status-active:hover {
                background: #bbf7d0;
                color: #14532d;
            }

        .status-inactive {
            background: #f3f4f6;
            color: #4b5563;
        }

            .status-inactive:hover {
                background: #e5e7eb;
                color: #374151;
            }

        .action-btn {
            min-width: 84px;
            border-radius: 999px;
            font-weight: 600;
        }

        .table-action-group {
            display: flex;
            justify-content: flex-end;
            gap: 8px;
            flex-wrap: wrap;
        }

        .alert {
            border-radius: 12px;
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: #6b7280;
        }

        .status-form {
            margin: 0;
        }
    </style>
}

<div class="card page-card">
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="page-title">SMC Product Items</h2>
            <p class="page-subtitle">Manage the items under each SMC Product.</p>
        </div>

        <a asp-action="Create" class="btn btn-add-custom">
            <i class="fas fa-plus mr-1"></i> Add Item
        </a>
    </div>

    <div class="card-body p-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:80px;">SN</th>
                        <th>SMC Product</th>
                        <th>Item Name</th>
                        <th style="width:160px;">Status</th>
                        <th class="text-right" style="width:320px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@sn</td>
                                <td>@item.SMCProductName</td>
                                <td>@item.ItemName</td>
                                <td>
                                    <form asp-action="Toggle" method="post" class="status-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.SMCProductItemId" />

                                        @if (item.IsActive)
                                        {
                                            <button type="submit" class="status-btn status-active">
                                                Active
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="status-btn status-inactive">
                                                Inactive
                                            </button>
                                        }
                                    </form>
                                </td>
                                <td>
                                    <div class="table-action-group">
                                        <a asp-action="Details" asp-route-id="@item.SMCProductItemId" class="btn btn-outline-dark btn-sm action-btn">
                                            Details
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@item.SMCProductItemId" class="btn btn-outline-primary btn-sm action-btn">
                                            Edit
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.SMCProductItemId" class="btn btn-outline-danger btn-sm action-btn">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            sn++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    No SMC Product Items found.
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>