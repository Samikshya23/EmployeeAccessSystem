@model IEnumerable<EmployeeAccessSystem.Models.SMCProductItem>

@{
    ViewData["Title"] = "SMC Product Items";
    int sn = 1;
}

<div class="card page-card">
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="page-title">SMC Product Items</h2>
            <p class="page-subtitle">Manage the items under each SMC Product.</p>
        </div>

        <a asp-action="Create" class="btn btn-add-custom">
            <i class="fas fa-plus mr-1"></i> Add Item
        </a>
    </div>

    <div class="card-body p-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:80px;">SN</th>
                        <th>SMC Product</th>
                        <th>Item Name</th>
                        <th>Value Type</th>
                        <th class="text-right" style="width:260px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@sn</td>
                                <td>@item.SMCProductName</td>
                                <td>@item.ItemName</td>
                                @* <td>@item.ValueType</td> *@
                                <td>
                                    <div class="table-action-group">
                                        <a asp-action="Details" asp-route-id="@item.SMCProductItemId" class="btn btn-outline-dark btn-sm action-btn">
                                            Details
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@item.SMCProductItemId" class="btn btn-outline-primary btn-sm action-btn">
                                            Edit
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.SMCProductItemId" class="btn btn-outline-danger btn-sm action-btn">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            sn++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    No SMC Product Items found.
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>