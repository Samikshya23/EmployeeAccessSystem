@model EmployeeAccessSystem.Models.SMCProductItem
@{
    Layout = null;
}
<form asp-action="Delete" method="post" id="deleteSMCProductItemForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="smcProductItemId" value="@Model.SMCProductItemId" />
    <p class="text-muted mb-3">Are you sure you want to delete this SMC Product Item?</p>
    <div class="table-responsive">
        <table class="table table-bordered table-hover mb-0">
            <tr>
                <th>SMC Product</th>
                <td>@Model.SMCProductName</td>
            </tr>
            <tr>
                <th>Item Name</th>
                <td>@Model.ItemName</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>@(Model.IsActive ? "Active" : "Inactive")</td>
            </tr>
        </table>
    </div>
    <div class="modal-footer px-0 pb-0 mt-3">
        <button type="button" class="btn btn-default" data-dismiss="modal">Back</button>
        <button type="submit" class="btn btn-danger">Delete</button>
    </div>
</form>