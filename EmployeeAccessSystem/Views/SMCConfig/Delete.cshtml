@model EmployeeAccessSystem.Models.SMCConfig

@{
    Layout = null;
}

<form asp-action="Delete" method="post" id="deleteSmcConfigForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.SMCConfigId" />

    <p class="text-muted mb-3">Are you sure you want to delete this SMC config entry?</p>

    <div class="table-responsive">
        <table class="table table-bordered table-hover mb-0">
            <tr>
                <th>Product</th>
                <td>@Model.ProductName</td>
            </tr>
            <tr>
                <th>SMC Product</th>
                <td>@Model.SMCProductName</td>
            </tr>
            <tr>
                <th>Item</th>
                <td>@Model.ItemName</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>@(Model.IsActive ? "Active" : "Inactive")</td>
            </tr>
        </table>
    </div>

    <div class="modal-footer px-0 pb-0 mt-3">
        <button type="button" class="btn btn-default" data-dismiss="modal">Back</button>
        <button type="submit" class="btn btn-danger">Delete</button>
    </div>
</form>