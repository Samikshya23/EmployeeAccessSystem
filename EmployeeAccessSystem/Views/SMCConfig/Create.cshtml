@model EmployeeAccessSystem.Models.SMCConfig

@{
    ViewData["Title"] = "SMC Config Entry";
}

<style>
    .entry-wrapper {
        padding-top: 32px;
        padding-bottom: 32px;
    }

    .entry-card {
        max-width: 880px;
        margin: auto;
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 12px 35px rgba(15, 23, 42, 0.08);
        overflow: hidden;
    }

    .entry-header {
        padding: 28px 32px 18px 32px;
        border-bottom: 1px solid #edf1f5;
        background: #ffffff;
    }

    .entry-title {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #1f2937;
    }

    .entry-body {
        padding: 30px 32px 34px 32px;
    }

    .field-label {
        display: block;
        margin-bottom: 10px;
        font-weight: 600;
        color: #374151;
        font-size: 1rem;
    }

    .field-input {
        width: 100%;
        height: 54px;
        border-radius: 14px;
        border: 1px solid #d9e1ea;
        background: #f8fafc;
        padding: 12px 16px;
        font-size: 1rem;
        color: #111827;
        transition: all 0.2s ease;
    }

        .field-input:focus {
            outline: none;
            border-color: #7c9cff;
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(124, 156, 255, 0.14);
        }

    .field-select {
        cursor: pointer;
    }

    .validation-text {
        display: block;
        margin-top: 6px;
        font-size: 0.875rem;
    }

    .action-row {
        margin-top: 30px;
        display: flex;
        justify-content: flex-end;
        gap: 14px;
    }

    .btn-soft-back {
        min-width: 140px;
        height: 48px;
        border: 1px solid #d1d9e6;
        background: #ffffff;
        color: #374151;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-soft-back:hover {
            background: #f8fafc;
            color: #111827;
        }

    .btn-save-entry {
        min-width: 140px;
        height: 48px;
        border: none;
        background: linear-gradient(135deg, #4f7cff, #3b5bdb);
        color: #ffffff;
        border-radius: 12px;
        font-weight: 600;
        box-shadow: 0 8px 20px rgba(79, 124, 255, 0.28);
        transition: all 0.2s ease;
    }

        .btn-save-entry:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 24px rgba(79, 124, 255, 0.32);
            color: #ffffff;
        }

    .alert-box {
        border-radius: 12px;
    }

    @@media (max-width: 768px) {
        .entry-header,
        .entry-body {
            padding-left: 20px;
            padding-right: 20px;
        }

        .entry-title {
            font-size: 1.6rem;
        }

        .action-row {
            flex-direction: column;
        }

        .btn-soft-back,
        .btn-save-entry {
            width: 100%;
        }
    }
</style>

<div class="container entry-wrapper">
    <div class="entry-card">
        <div class="entry-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h2 class="entry-title mb-0">SMC Config Entry</h2>

            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-list me-1"></i> View List
            </a>
        </div>

        <div class="entry-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger alert-box">
                    @ViewBag.Error
                </div>
            }

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <form asp-action="Create" method="post">
                <div class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="ProductId" class="field-label">Product</label>
                        <select asp-for="ProductId" asp-items="ViewBag.ProductList" class="field-input field-select" id="ProductId">
                            <option value="">Choose product</option>
                        </select>
                        <span asp-validation-for="ProductId" class="text-danger validation-text"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SMCProductId" class="field-label">SMC Product</label>
                        <select asp-for="SMCProductId" asp-items="ViewBag.SMCProductList" class="field-input field-select" id="SMCProductId">
                            <option value="">Choose SMC product</option>
                        </select>
                        <span asp-validation-for="SMCProductId" class="text-danger validation-text"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SMCProductItemId" class="field-label">SMC Product Item</label>
                        <select asp-for="SMCProductItemId" asp-items="ViewBag.SMCProductItemList" class="field-input field-select" id="SMCProductItemId">
                            <option value="">Choose SMC product item</option>
                        </select>
                        <span asp-validation-for="SMCProductItemId" class="text-danger validation-text"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ConfigValue" class="field-label">Value</label>
                        <input asp-for="ConfigValue" class="field-input" placeholder="Enter value" />
                        <span asp-validation-for="ConfigValue" class="text-danger validation-text"></span>
                    </div>

                    <div class="col-12">
                        <div class="form-check mt-2">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold">Active Entry</label>
                        </div>
                    </div>
                </div>

                <div class="action-row">
                    <a asp-action="Index" class="btn btn-soft-back">Back to List</a>
                    <button type="submit" class="btn btn-save-entry">Save Entry</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById("ProductId").addEventListener("change", function () {
            var productId = this.value;
            var smcProductDropdown = document.getElementById("SMCProductId");
            var smcProductItemDropdown = document.getElementById("SMCProductItemId");

            smcProductDropdown.innerHTML = '<option value="">Choose SMC product</option>';
            smcProductItemDropdown.innerHTML = '<option value="">Choose SMC product item</option>';

            if (productId !== "") {
                fetch('/SMCConfig/GetSMCProductsByProductId?productId=' + productId)
                    .then(function (response) {
                        return response.json();
                    })
                    .then(function (data) {
                        data.forEach(function (item) {
                            smcProductDropdown.innerHTML += '<option value="' + item.smcProductId + '">' + item.smcProductName + '</option>';
                        });
                    })
                    .catch(function (error) {
                        console.log("Error loading SMC products:", error);
                    });
            }
        });

        document.getElementById("SMCProductId").addEventListener("change", function () {
            var smcProductId = this.value;
            var smcProductItemDropdown = document.getElementById("SMCProductItemId");

            smcProductItemDropdown.innerHTML = '<option value="">Choose SMC product item</option>';

            if (smcProductId !== "") {
                fetch('/SMCConfig/GetSMCProductItemsBySMCProductId?smcProductId=' + smcProductId)
                    .then(function (response) {
                        return response.json();
                    })
                    .then(function (data) {
                        data.forEach(function (item) {
                            smcProductItemDropdown.innerHTML += '<option value="' + item.smcProductItemId + '">' + item.itemName + '</option>';
                        });
                    })
                    .catch(function (error) {
                        console.log("Error loading SMC product items:", error);
                    });
            }
        });
    </script>
}