@model IEnumerable<EmployeeAccessSystem.Models.SMCConfig>

@{
    ViewData["Title"] = "SMC Config List";
    int sn = 1;
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h3 class="mb-1">SMC Config List</h3>
                <small class="text-muted">View all saved entries.</small>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Create" class="btn btn-primary">
                    Add New Entry
                </a>
            </div>
        </div>

        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle text-center">
                        <thead class="table-light">
                            <tr>
                                <th>SN</th>
                                <th>Product</th>
                                <th>SMC Product</th>
                                <th>Item</th>
                                <th>Date</th>
                                <th>Save Option</th>
                                <th>Value</th>
                                <th>Check</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@sn</td>
                                    <td>@item.ProductName</td>
                                    <td>@item.SMCProductName</td>
                                    <td>@item.ItemName</td>
                                    <td>@item.EntryDate.ToString("yyyy-MM-dd")</td>
                                    <td>@item.EntryMode</td>
                                    <td>@item.ConfigValue</td>
                                    <td>
                                        @if (item.IsChecked)
                                        {
                                            <span>✔</span>
                                        }
                                        else
                                        {
                                            <span>✘</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.SMCConfigId" class="btn btn-sm btn-warning">
                                            Edit
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.SMCConfigId" class="btn btn-sm btn-danger">
                                            Delete
                                        </a>
                                    </td>
                                </tr>

                                sn++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    No records found.
                </div>
            }
        </div>
    </div>
</div>