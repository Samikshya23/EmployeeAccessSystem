@model IEnumerable<EmployeeAccessSystem.Models.SMCConfig>

@{
    ViewData["Title"] = "SMC Config List";
    int sn = 1;
}

<style>
    .config-page {
        padding-top: 24px;
        padding-bottom: 24px;
    }

    .config-card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
        overflow: hidden;
        background: #ffffff;
    }

    .config-header {
        padding: 24px 28px 18px 28px;
        border-bottom: 1px solid #edf1f5;
        background: #ffffff;
    }

    .config-title {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #13294b;
    }

    .config-subtitle {
        margin-top: 6px;
        color: #6b7280;
        font-size: 0.98rem;
    }

    .config-body {
        padding: 24px 28px 28px 28px;
    }

    .btn-add-entry {
        border: none;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: #ffffff;
        border-radius: 12px;
        font-weight: 600;
        padding: 11px 18px;
        box-shadow: 0 8px 20px rgba(37, 99, 235, 0.22);
    }

        .btn-add-entry:hover {
            color: #ffffff;
            transform: translateY(-1px);
        }

    .table-wrap {
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        overflow: hidden;
    }

    .config-table {
        margin-bottom: 0;
    }

        .config-table thead th {
            background: #f8fafc;
            color: #1f2937;
            font-size: 14px;
            font-weight: 700;
            text-align: center;
            vertical-align: middle;
            padding: 16px 12px;
            border-color: #e5e7eb;
            white-space: nowrap;
        }

        .config-table tbody td {
            font-size: 15px;
            color: #374151;
            text-align: center;
            vertical-align: middle;
            padding: 16px 12px;
            border-color: #eef2f7;
        }

        .config-table tbody tr:hover {
            background: #fafcff;
        }

    .text-left-cell {
        text-align: left !important;
    }

    .date-cell {
        min-width: 110px;
        font-weight: 500;
    }

    .entry-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 58px;
        min-height: 32px;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    .value-badge {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .check-badge {
        background: #dcfce7;
        color: #166534;
    }

    .status-active {
        background: #dcfce7;
        color: #166534;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        padding: 6px 12px;
        display: inline-block;
    }

    .status-inactive {
        background: #f3f4f6;
        color: #6b7280;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        padding: 6px 12px;
        display: inline-block;
    }

    .empty-mark {
        color: #9ca3af;
        font-weight: 700;
        font-size: 18px;
        line-height: 1;
    }

    .action-group {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-action {
        min-width: 74px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        padding: 8px 12px;
    }

    .btn-edit-entry {
        background: #fbbf24;
        border: none;
        color: #111827;
    }

        .btn-edit-entry:hover {
            background: #f59e0b;
            color: #111827;
        }

    .btn-delete-entry {
        background: #ef4444;
        border: none;
        color: #ffffff;
    }

        .btn-delete-entry:hover {
            background: #dc2626;
            color: #ffffff;
        }

    .alert-soft {
        border-radius: 12px;
        padding: 14px 16px;
    }

    .config-table i {
        font-size: 15px;
    }

    @@media (max-width: 768px) {
        .config-header,
        .config-body {
            padding-left: 18px;
            padding-right: 18px;
        }

        .config-title {
            font-size: 1.6rem;
        }
    }
</style>

<div class="container config-page">
    <div class="config-card">
        <div class="config-header d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="config-title">SMC Config List</h2>
                <div class="config-subtitle">View all saved entries.</div>
            </div>

            <a asp-action="Create" class="btn btn-add-entry">
                Add New Entry
            </a>
        </div>

        <div class="config-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-soft">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-soft">
                    @TempData["Error"]
                </div>
            }

            @if (Model != null && Model.Any())
            {
                <div class="table-wrap">
                    <div class="table-responsive">
                        <table class="table config-table align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 70px;">SN</th>
                                    <th>Product</th>
                                    <th>SMC Product</th>
                                    <th>Item</th>
                                    <th>Date</th>
                                    <th>Save Option</th>
                                    <th>Value</th>
                                    <th>Check</th>
                                    <th>Status</th>
                                    <th style="width: 170px;">Actions</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@sn</td>
                                        <td>@item.ProductName</td>
                                        <td>@item.SMCProductName</td>
                                        <td>@item.ItemName</td>
                                        <td class="date-cell">@item.EntryDate.ToString("yyyy-MM-dd")</td>
                                        <td>@item.EntryMode</td>

                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(item.ConfigValue))
                                            {
                                                <span class="entry-badge value-badge">@item.ConfigValue</span>
                                            }
                                            else
                                            {
                                                <span class="empty-mark">-</span>
                                            }
                                        </td>

                                        <td>
                                            @if (item.EntryMode == "Checkbox" && item.IsChecked)
                                            {
                                                <span class="entry-badge check-badge">
                                                    <i class="fas fa-check"></i>
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="empty-mark">-</span>
                                            }
                                        </td>

                                        <td>
                                            @if (item.IsActive)
                                            {
                                                <span class="status-active">Active</span>
                                            }
                                            else
                                            {
                                                <span class="status-inactive">Inactive</span>
                                            }
                                        </td>

                                        <td>
                                            <div class="action-group">
                                                <a asp-action="Edit" asp-route-id="@item.SMCConfigId" class="btn btn-action btn-edit-entry">
                                                    Edit
                                                </a>

                                                <a asp-action="Delete" asp-route-id="@item.SMCConfigId" class="btn btn-action btn-delete-entry"
                                                   onclick="return confirm('Are you sure you want to delete this entry?');">
                                                    Delete
                                                </a>
                                            </div>
                                        </td>
                                    </tr>

                                    sn++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info alert-soft mb-0">
                    No records found.
                </div>
            }
        </div>
    </div>
</div>