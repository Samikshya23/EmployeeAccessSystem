@model IEnumerable<EmployeeAccessSystem.Models.SMCConfig>

@{
    ViewData["Title"] = "SMC Config List";
    int sn = 1;
    var shownProductNames = new List<string>();
}

<div class="card shadow-sm mb-0 h-100">
    <div class="card-header bg-white py-2">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h3 class="mb-0">SMC Config List</h3>
                <small class="text-muted d-block">View all saved monitoring configuration entries.</small>
            </div>
            <div class="col-md-6 text-md-right mt-2 mt-md-0">
                <a asp-action="Create"
                   asp-route-modal="true"
                   class="btn btn-primary rounded-pill open-modal-btn"
                   data-title="Add SMC Config">
                    <i class="fas fa-plus mr-1"></i> Add
                </a>
            </div>
        </div>
    </div>

    <div class="card-body p-2">
        <div class="row mb-2">
            <div class="col-md-8"></div>
            <div class="col-md-4">
                <input type="text"
                       id="customSearch"
                       class="form-control"
                       placeholder="Search entries..." />
            </div>
        </div>

        <div class="table-responsive">
            <table id="smcConfigTable" class="table table-sm table-bordered table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 70px;">SN</th>
                        <th class="text-center" style="width: 24%;">SMC Product</th>
                        <th class="text-center" style="width: 16%;">Item</th>
                        <th class="text-center" style="width: 14%;">Date</th>
                        <th class="text-center" style="width: 10%;">Value</th>
                        <th class="text-center" style="width: 10%;">Check</th>
                        <th class="text-center" style="width: 10%;">Status</th>
                        <th class="text-center" style="width: 120px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var product in Model)
                        {
                            if (!shownProductNames.Contains(product.SMCProductName))
                            {
                                shownProductNames.Add(product.SMCProductName);

                                var groupItems = new List<EmployeeAccessSystem.Models.SMCConfig>();

                                foreach (var item in Model)
                                {
                                    if (item.SMCProductName == product.SMCProductName)
                                    {
                                        groupItems.Add(item);
                                    }
                                }

                                string combinedSearchText = "";
                                bool firstText = true;

                                foreach (var groupItem in groupItems)
                                {
                                    string rowText =
                                        groupItem.SMCProductName + " " +
                                        groupItem.ItemName + " " +
                                        groupItem.EntryDate.ToString("yyyy-MM-dd") + " " +
                                        (string.IsNullOrWhiteSpace(groupItem.ConfigValue) ? "-" : groupItem.ConfigValue) + " " +
                                        (groupItem.EntryMode == "Checkbox" ? (groupItem.IsChecked ? "Checked" : "Unchecked") : "-") + " " +
                                        (groupItem.IsActive ? "Active" : "Inactive");

                                    if (firstText)
                                    {
                                        combinedSearchText = rowText;
                                        firstText = false;
                                    }
                                    else
                                    {
                                        combinedSearchText = combinedSearchText + " " + rowText;
                                    }
                                }

                                <tr data-search="@combinedSearchText">
                                    <td class="text-center align-top pt-3">
                                        @sn
                                    </td>

                                    <td class="align-top pt-3">
                                        @product.SMCProductName
                                    </td>

                                    <td class="p-0 align-top">
                                        <table class="table table-sm mb-0">
                                            <tbody>
                                                @for (int i = 0; i < groupItems.Count; i++)
                                                {
                                                    <tr>
                                                        <td class="py-1 px-2 @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                            @groupItems[i].ItemName
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>

                                    <td class="p-0 align-top">
                                        <table class="table table-sm mb-0">
                                            <tbody>
                                                @for (int i = 0; i < groupItems.Count; i++)
                                                {
                                                    <tr>
                                                        <td class="text-center py-1 px-2 @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                            @groupItems[i].EntryDate.ToString("yyyy-MM-dd")
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>

                                    <td class="p-0 align-top">
                                        <table class="table table-sm mb-0">
                                            <tbody>
                                                @for (int i = 0; i < groupItems.Count; i++)
                                                {
                                                    <tr>
                                                        <td class="text-center py-1 px-2 @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                            @if (!string.IsNullOrWhiteSpace(groupItems[i].ConfigValue))
                                                            {
                                                                @groupItems[i].ConfigValue
                                                            }
                                                            else
                                                            {
                                                                <span>-</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>

                                    <td class="p-0 align-top">
                                        <table class="table table-sm mb-0">
                                            <tbody>
                                                @for (int i = 0; i < groupItems.Count; i++)
                                                {
                                                    <tr>
                                                        <td class="text-center py-1 px-2 @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                            @if (groupItems[i].EntryMode == "Checkbox")
                                                            {
                                                                if (groupItems[i].IsChecked)
                                                                {
                                                                    <i class="fas fa-check text-success"></i>
                                                                }
                                                                else
                                                                {
                                                                    <i class="fas fa-times text-danger"></i>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <span>-</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>

                                    <td class="p-0 align-top">
                                        <table class="table table-sm mb-0">
                                            <tbody>
                                                @for (int i = 0; i < groupItems.Count; i++)
                                                {
                                                    <tr>
                                                        <td class="text-center py-1 px-2 @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                            @if (groupItems[i].IsActive)
                                                            {
                                                                <span class="badge badge-success">Active</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge badge-secondary">Inactive</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>

                                    <td class="p-0 align-top">
                                        <table class="table table-sm mb-0">
                                            <tbody>
                                                @for (int i = 0; i < groupItems.Count; i++)
                                                {
                                                    <tr>
                                                        <td class="text-center py-0 px-1 @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                            <a asp-action="Edit"
                                                               asp-route-id="@groupItems[i].SMCConfigId"
                                                               class="btn btn-sm btn-light border open-modal-btn"
                                                               data-title="Edit SMC Config">
                                                                <i class="fas fa-pen"></i>
                                                            </a>

                                                            <a asp-action="Delete"
                                                               asp-route-id="@groupItems[i].SMCConfigId"
                                                               class="btn btn-sm btn-outline-danger open-modal-btn ml-1"
                                                               data-title="Delete SMC Config">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>

                                sn++;
                            }
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center">No SMC Config entries found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="mainActionModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="mainActionModalTitle">SMC Config</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body" id="mainActionModalBody">
                <div class="text-center py-3">
                    <i class="fas fa-spinner fa-spin mr-2"></i>Loading...
                </div>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed p-3" style="top: 15px; right: 15px; z-index: 9999;">
    @if (TempData["Success"] != null)
    {
        <div class="toast bg-success text-white fade" id="successToast" data-delay="3000">
            <div class="toast-header bg-success text-white border-0">
                <strong class="mr-auto">Success</strong>
                <small>Now</small>
                <button type="button" class="close text-white" data-dismiss="toast">&times;</button>
            </div>
            <div class="toast-body">
                @TempData["Success"]
            </div>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="toast bg-danger text-white fade" id="errorToast" data-delay="4000">
            <div class="toast-header bg-danger text-white border-0">
                <strong class="mr-auto">Error</strong>
                <small>Now</small>
                <button type="button" class="close text-white" data-dismiss="toast">&times;</button>
            </div>
            <div class="toast-body">
                @TempData["Error"]
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            var table = $('#smcConfigTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                info: false,
                lengthChange: false,
                pageLength: 10,
                autoWidth: false,
                columnDefs: [
                    { orderable: false, targets: 7 }
                ],
                dom: 't<"row mt-2"<"col-md-6"><"col-md-6 text-right"p>>'
            });

            $('#customSearch').on('keyup', function () {
                table.search(this.value).draw();
            });

            function openSmcConfigModal(url, title) {
                $('#mainActionModalTitle').text(title);
                $('#mainActionModalBody').html('<div class="text-center py-3"><i class="fas fa-spinner fa-spin mr-2"></i>Loading...</div>');

                $('#mainActionModalBody').load(url, function () {
                    $.validator.unobtrusive.parse('#mainActionModalBody');
                });

                $('#mainActionModal').modal('show');
            }

            $(document).on('click', '.open-modal-btn', function (e) {
                e.preventDefault();

                var url = $(this).attr('href');
                var title = $(this).data('title') || 'SMC Config';

                openSmcConfigModal(url, title);
            });

            var shouldOpenCreate = '@Context.Request.Query["openCreate"]';

            if (shouldOpenCreate === 'true') {
                openSmcConfigModal('/SMCConfig/Create?modal=true', 'Add SMC Config');

                if (window.history.replaceState) {
                    window.history.replaceState({}, document.title, window.location.pathname);
                }
            }

            $('#successToast').toast('show');
            $('#errorToast').toast('show');
        });
    </script>
}