@model IEnumerable<EmployeeAccessSystem.Models.SMCConfig>

@{
    ViewData["Title"] = "SMC Config List";
    int sn = 1;
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>SMC Config List</h1>
                <small class="text-muted">View all saved monitoring configuration entries.</small>
            </div>
            <div class="col-sm-6 text-sm-right mt-2 mt-sm-0">
                <a asp-action="Create" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus mr-1"></i>Add Entry
                </a>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card card-primary card-outline">
            <div class="card-header bg-white py-2">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <h3 class="mb-0">Saved Entries</h3>
                    </div>
                    <div class="col-md-6 text-md-right mt-2 mt-md-0">
                        <input type="text" id="customSearch" class="form-control d-inline-block" placeholder="Search entries..." style="max-width: 260px;">
                    </div>
                </div>
            </div>

            <div class="card-body p-2">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        @TempData["Success"]
                        <button type="button" class="close" data-dismiss="alert">
                            <span>&times;</span>
                        </button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        @TempData["Error"]
                        <button type="button" class="close" data-dismiss="alert">
                            <span>&times;</span>
                        </button>
                    </div>
                }

                <div class="table-responsive">
                    <table id="smcConfigTable" class="table table-sm table-bordered table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="text-center">SN</th>
                                <th class="text-center">Product</th>
                                <th class="text-center">SMC Product</th>
                                <th class="text-center">Item</th>
                                <th class="text-center">Date</th>
                                <th class="text-center">Value</th>
                                <th class="text-center">Check</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="text-center">@sn</td>
                                        <td>@item.ProductName</td>
                                        <td>@item.SMCProductName</td>
                                        <td>@item.ItemName</td>
                                        <td class="text-center">@item.EntryDate.ToString("yyyy-MM-dd")</td>

                                        <td class="text-center">
                                            @if (!string.IsNullOrWhiteSpace(item.ConfigValue))
                                            {
                                                @item.ConfigValue
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>

                                        <td class="text-center">
                                            @if (item.EntryMode == "Checkbox")
                                            {
                                                if (item.IsChecked)
                                                {
                                                    <i class="fas fa-check text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="fas fa-times text-danger"></i>
                                                }
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>

                                        <td class="text-center">
                                            @if (item.IsActive)
                                            {
                                                <span class="badge badge-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-secondary">Inactive</span>
                                            }
                                        </td>

                                        <td class="text-center">
                                            <a asp-action="Edit"
                                               asp-route-id="@item.SMCConfigId"
                                               class="btn btn-sm btn-light border open-modal-btn"
                                               data-title="Edit SMC Config"
                                               title="Edit">
                                                <i class="fas fa-pen"></i>
                                            </a>

                                            <a asp-action="Delete"
                                               asp-route-id="@item.SMCConfigId"
                                               class="btn btn-sm btn-outline-danger open-modal-btn ml-1"
                                               data-title="Delete SMC Config"
                                               title="Delete">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </td>
                                    </tr>

                                    sn++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="mainActionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="mainActionModalTitle">SMC Config</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body" id="mainActionModalBody">
                <div class="text-center py-3">
                    <i class="fas fa-spinner fa-spin mr-2"></i>Loading...
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            var table = $('#smcConfigTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                info: false,
                lengthChange: false,
                pageLength: 10,
                autoWidth: false,
                columnDefs: [
                    { orderable: false, targets: 8 }
                ],
                dom: 't<"row mt-2"<"col-md-6"><"col-md-6 text-right"p>>'
            });

            $('#customSearch').on('keyup', function () {
                table.search(this.value).draw();
            });

            $(document).on('click', '.open-modal-btn', function (e) {
                e.preventDefault();

                var url = $(this).attr('href');
                var title = $(this).data('title') || 'SMC Config';

                $('#mainActionModalTitle').text(title);
                $('#mainActionModalBody').html('<div class="text-center py-3"><i class="fas fa-spinner fa-spin mr-2"></i>Loading...</div>');

                $('#mainActionModalBody').load(url, function (response, status) {
                    if (status === "error") {
                        $('#mainActionModalBody').html('<div class="alert alert-danger mb-0">Failed to load content.</div>');
                        return;
                    }

                    $('#mainActionModal').modal('show');
                });
            });
        });
    </script>
}