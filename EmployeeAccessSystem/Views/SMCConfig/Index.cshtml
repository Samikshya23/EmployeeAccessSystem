@model IEnumerable<EmployeeAccessSystem.Models.SMCConfig>

@{
    ViewData["Title"] = "SMC Config List";
    int sn = 1;
    var shownProductNames = new List<string>();
}

<div class="card card-primary card-outline mb-0 h-100">
    <div class="card-header bg-white py-2">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h3 class="mb-0">SMC Config List</h3>
            </div>
            <div class="col-md-6 text-md-right mt-2 mt-md-0">
                <a asp-action="Create"
                   asp-route-modal="true"
                   class="btn btn-primary rounded-pill open-modal-btn"
                   data-title="Add SMC Config">
                    <i class="fas fa-plus mr-1"></i> Add
                </a>
            </div>
        </div>
    </div>

    <div class="card-body p-2">
        <div class="row mb-2">
            <div class="col-md-3">
                <input type="date" id="fromDate" class="form-control" />
            </div>
            <div class="col-md-3">
                <input type="date" id="toDate" class="form-control" />
            </div>
            <div class="col-md-6">
                <input type="text"
                       id="customSearch"
                       class="form-control"
                       placeholder="Search entries..." />
            </div>
        </div>

        <div class="table-responsive">
            <table id="smcConfigTable" class="table table-sm table-bordered table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 70px;">SN</th>
                        <th class="text-center" style="width: 25%;">SMC Product</th>
                        <th class="text-center" style="width: 18%;">Item</th>
                        <th class="text-center" style="width: 14%;">Date</th>
                        <th class="text-center" style="width: 12%;">Result</th>
                        <th class="text-center" style="width: 11%;">Status</th>
                        <th class="text-center" style="width: 120px;">Actions</th>
                    </tr>
                </thead>
                <tbody id="smcConfigTableBody">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var product in Model)
                        {
                            if (!shownProductNames.Contains(product.SMCProductName))
                            {
                                shownProductNames.Add(product.SMCProductName);

                                var groupItems = new List<EmployeeAccessSystem.Models.SMCConfig>();

                                foreach (var item in Model)
                                {
                                    if (item.SMCProductName == product.SMCProductName)
                                    {
                                        groupItems.Add(item);
                                    }
                                }

                                string combinedSearchText = "";
                                bool firstText = true;

                                foreach (var groupItem in groupItems)
                                {
                                    string resultText = "-";

                                    if (groupItem.EntryMode == "Value")
                                    {
                                        if (!string.IsNullOrWhiteSpace(groupItem.ConfigValue))
                                        {
                                            resultText = groupItem.ConfigValue;
                                        }
                                    }
                                    else if (groupItem.EntryMode == "Checkbox")
                                    {
                                        if (groupItem.IsChecked)
                                        {
                                            resultText = "Checked";
                                        }
                                        else
                                        {
                                            resultText = "Cross";
                                        }
                                    }

                                    string rowText =
                                        groupItem.SMCProductName + " " +
                                        groupItem.ItemName + " " +
                                        groupItem.EntryDate.ToString("yyyy-MM-dd") + " " +
                                        resultText + " " +
                                        (groupItem.IsActive ? "Active" : "Inactive");

                                    if (firstText)
                                    {
                                        combinedSearchText = rowText;
                                        firstText = false;
                                    }
                                    else
                                    {
                                        combinedSearchText = combinedSearchText + " " + rowText;
                                    }
                                }

                                <tr class="group-row" data-search="@combinedSearchText">
                                    <td class="text-center align-top pt-3 group-sn">
                                        @sn
                                    </td>

                                    <td class="align-top pt-3">
                                        @product.SMCProductName
                                    </td>

                                    <td class="p-0 align-top">
                                        <table class="table table-sm mb-0 inner-table">
                                            <tbody>
                                                @for (int i = 0; i < groupItems.Count; i++)
                                                {
                                                    <tr class="child-row"
                                                        data-entry-date="@groupItems[i].EntryDate.ToString("yyyy-MM-dd")"
                                                        data-row-index="@i">
                                                        <td class="py-1 px-2 @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                            @groupItems[i].ItemName
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>

                                    <td class="p-0 align-top">
                                        <table class="table table-sm mb-0 inner-table">
                                            <tbody>
                                                @for (int i = 0; i < groupItems.Count; i++)
                                                {
                                                    <tr class="child-row"
                                                        data-entry-date="@groupItems[i].EntryDate.ToString("yyyy-MM-dd")"
                                                        data-row-index="@i">
                                                        <td class="text-center py-1 px-2 @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                            @groupItems[i].EntryDate.ToString("dd MMM yyyy")
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>

                                    <td class="p-0 align-top">
                                        <table class="table table-sm mb-0 inner-table">
                                            <tbody>
                                                @for (int i = 0; i < groupItems.Count; i++)
                                                {
                                                    <tr class="child-row"
                                                        data-entry-date="@groupItems[i].EntryDate.ToString("yyyy-MM-dd")"
                                                        data-row-index="@i">
                                                        <td class="text-center py-1 px-2 @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                            @if (groupItems[i].EntryMode == "Value")
                                                            {
                                                                if (!string.IsNullOrWhiteSpace(groupItems[i].ConfigValue))
                                                                {
                                                                    <span>@groupItems[i].ConfigValue</span>
                                                                }
                                                                else
                                                                {
                                                                    <span>-</span>
                                                                }
                                                            }
                                                            else if (groupItems[i].EntryMode == "Checkbox")
                                                            {
                                                                if (groupItems[i].IsChecked)
                                                                {
                                                                    <i class="fas fa-check text-success"></i>
                                                                }
                                                                else
                                                                {
                                                                    <i class="fas fa-times text-danger"></i>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <span>-</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>

                                    <td class="p-0 align-top">
                                        <table class="table table-sm mb-0 inner-table">
                                            <tbody>
                                                @for (int i = 0; i < groupItems.Count; i++)
                                                {
                                                    <tr class="child-row"
                                                        data-entry-date="@groupItems[i].EntryDate.ToString("yyyy-MM-dd")"
                                                        data-row-index="@i">
                                                        <td class="text-center py-1 px-2 @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                            @if (groupItems[i].IsActive)
                                                            {
                                                                <span class="badge badge-success">Active</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge badge-secondary">Inactive</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>

                                    <td class="p-0 align-top">
                                        <table class="table table-sm mb-0 inner-table">
                                            <tbody>
                                                @for (int i = 0; i < groupItems.Count; i++)
                                                {
                                                    <tr class="child-row"
                                                        data-entry-date="@groupItems[i].EntryDate.ToString("yyyy-MM-dd")"
                                                        data-row-index="@i">
                                                        <td class="text-center py-0 px-1 @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                            <a asp-action="Edit"
                                                               asp-route-id="@groupItems[i].SMCConfigId"
                                                               class="btn btn-sm btn-light border open-modal-btn"
                                                               data-title="Edit SMC Config">
                                                                <i class="fas fa-pen"></i>
                                                            </a>

                                                            <a asp-action="Delete"
                                                               asp-route-id="@groupItems[i].SMCConfigId"
                                                               class="btn btn-sm btn-outline-danger open-modal-btn ml-1"
                                                               data-title="Delete SMC Config">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>

                                sn++;
                            }
                        }
                    }
                    else
                    {
                        <tr id="noDataRow">
                            <td colspan="7" class="text-center">No SMC Config entries found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-3 align-items-center">
            <div class="col-md-6">
                <div id="paginationInfo" class="text-muted"></div>
            </div>
            <div class="col-md-6 text-md-right mt-2 mt-md-0">
                <nav>
                    <ul class="pagination pagination-sm justify-content-md-end mb-0" id="customPagination"></ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mainActionModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="mainActionModalTitle">SMC Config</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body" id="mainActionModalBody">
                <div class="text-center py-3">
                    <i class="fas fa-spinner fa-spin mr-2"></i>Loading...
                </div>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed p-3" style="top: 15px; right: 15px; z-index: 9999;">
    @if (TempData["Success"] != null)
    {
        <div class="toast bg-success text-white fade" id="successToast" data-delay="3000">
            <div class="toast-header bg-success text-white border-0">
                <strong class="mr-auto">Success</strong>
                <small>Now</small>
                <button type="button" class="close text-white" data-dismiss="toast">&times;</button>
            </div>
            <div class="toast-body">
                @TempData["Success"]
            </div>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="toast bg-danger text-white fade" id="errorToast" data-delay="4000">
            <div class="toast-header bg-danger text-white border-0">
                <strong class="mr-auto">Error</strong>
                <small>Now</small>
                <button type="button" class="close text-white" data-dismiss="toast">&times;</button>
            </div>
            <div class="toast-body">
                @TempData["Error"]
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            var rowsPerPage = 2;
            var currentPage = 1;

            function formatDateToInputValue(date) {
                var year = date.getFullYear();
                var month = (date.getMonth() + 1).toString();
                var day = date.getDate().toString();

                if (month.length < 2) {
                    month = '0' + month;
                }

                if (day.length < 2) {
                    day = '0' + day;
                }

                return year + '-' + month + '-' + day;
            }

            function setDefaultDateRange() {
                var today = new Date();
                var from = new Date();
                from.setDate(today.getDate() - 29);

                $('#toDate').val(formatDateToInputValue(today));
                $('#fromDate').val(formatDateToInputValue(from));
            }

            function isDateInRange(entryDate, fromDate, toDate) {
                if (fromDate !== '' && entryDate < fromDate) {
                    return false;
                }

                if (toDate !== '' && entryDate > toDate) {
                    return false;
                }

                return true;
            }

            function applyChildRowFilter() {
                var fromDate = $('#fromDate').val();
                var toDate = $('#toDate').val();

                $('#smcConfigTableBody tr.group-row').each(function () {
                    var groupRow = $(this);
                    var visibleRowIndexes = [];

                    var dateTable = groupRow.find('table.inner-table').eq(1);

                    dateTable.find('tr.child-row').each(function () {
                        var entryDate = $(this).attr('data-entry-date');
                        var rowIndex = $(this).attr('data-row-index');

                        if (isDateInRange(entryDate, fromDate, toDate)) {
                            visibleRowIndexes.push(rowIndex);
                        }
                    });

                    groupRow.find('table.inner-table').each(function () {
                        $(this).find('tr.child-row').each(function () {
                            var rowIndex = $(this).attr('data-row-index');

                            if (visibleRowIndexes.indexOf(rowIndex) > -1) {
                                $(this).show();
                            } else {
                                $(this).hide();
                            }
                        });
                    });

                    if (visibleRowIndexes.length > 0) {
                        groupRow.attr('data-has-visible-children', 'true');
                    } else {
                        groupRow.attr('data-has-visible-children', 'false');
                    }
                });
            }

            function getFilteredRows() {
                var searchText = $('#customSearch').val().toLowerCase().trim();
                var filteredRows = [];

                $('#smcConfigTableBody tr.group-row').each(function () {
                    var rowSearchText = ($(this).attr('data-search') || '').toLowerCase();
                    var hasVisibleChildren = $(this).attr('data-has-visible-children') === 'true';

                    if (hasVisibleChildren) {
                        if (searchText === '' || rowSearchText.indexOf(searchText) > -1) {
                            filteredRows.push(this);
                        }
                    }
                });

                return filteredRows;
            }

            function updateSerialNumbers(filteredRows) {
                var i;

                for (i = 0; i < filteredRows.length; i++) {
                    $(filteredRows[i]).find('.group-sn').text(i + 1);
                }
            }

            function renderPagination() {
                applyChildRowFilter();

                var filteredRows = getFilteredRows();
                var totalRows = filteredRows.length;
                var totalPages = Math.ceil(totalRows / rowsPerPage);

                $('#smcConfigTableBody tr.group-row').hide();

                if (totalRows === 0) {
                    $('#paginationInfo').text('No matching entries found.');
                    $('#customPagination').html('');
                    return;
                }

                updateSerialNumbers(filteredRows);

                if (currentPage > totalPages) {
                    currentPage = 1;
                }

                var startIndex = (currentPage - 1) * rowsPerPage;
                var endIndex = startIndex + rowsPerPage;
                var i;

                for (i = startIndex; i < endIndex && i < totalRows; i++) {
                    $(filteredRows[i]).show();
                }

                var fromRecord = startIndex + 1;
                var toRecord = endIndex;

                if (toRecord > totalRows) {
                    toRecord = totalRows;
                }

                $('#paginationInfo').text('Showing ' + fromRecord + ' to ' + toRecord + ' of ' + totalRows + ' grouped entries');

                var paginationHtml = '';
                var page;

                if (currentPage > 1) {
                    paginationHtml += '<li class="page-item"><a href="#" class="page-link pagination-link" data-page="' + (currentPage - 1) + '">Previous</a></li>';
                } else {
                    paginationHtml += '<li class="page-item disabled"><span class="page-link">Previous</span></li>';
                }

                for (page = 1; page <= totalPages; page++) {
                    if (page === currentPage) {
                        paginationHtml += '<li class="page-item active"><span class="page-link">' + page + '</span></li>';
                    } else {
                        paginationHtml += '<li class="page-item"><a href="#" class="page-link pagination-link" data-page="' + page + '">' + page + '</a></li>';
                    }
                }

                if (currentPage < totalPages) {
                    paginationHtml += '<li class="page-item"><a href="#" class="page-link pagination-link" data-page="' + (currentPage + 1) + '">Next</a></li>';
                } else {
                    paginationHtml += '<li class="page-item disabled"><span class="page-link">Next</span></li>';
                }

                $('#customPagination').html(paginationHtml);
            }

            $('#fromDate').on('change', function () {
                currentPage = 1;
                renderPagination();
            });

            $('#toDate').on('change', function () {
                currentPage = 1;
                renderPagination();
            });

            $('#customSearch').on('keyup', function () {
                currentPage = 1;
                renderPagination();
            });

            $(document).on('click', '.pagination-link', function (e) {
                e.preventDefault();

                var page = $(this).data('page');
                currentPage = parseInt(page);
                renderPagination();
            });

            setDefaultDateRange();
            renderPagination();

            function openSmcConfigModal(url, title) {
                $('#mainActionModalTitle').text(title);
                $('#mainActionModalBody').html('<div class="text-center py-3"><i class="fas fa-spinner fa-spin mr-2"></i>Loading...</div>');

                $('#mainActionModalBody').load(url, function () {
                    $.validator.unobtrusive.parse('#mainActionModalBody');
                });

                $('#mainActionModal').modal('show');
            }

            $(document).on('click', '.open-modal-btn', function (e) {
                e.preventDefault();

                var url = $(this).attr('href');
                var title = $(this).data('title') || 'SMC Config';

                openSmcConfigModal(url, title);
            });

            var shouldOpenCreate = '@Context.Request.Query["openCreate"]';

            if (shouldOpenCreate === 'true') {
                openSmcConfigModal('/SMCConfig/Create?modal=true', 'Add SMC Config');

                if (window.history.replaceState) {
                    window.history.replaceState({}, document.title, window.location.pathname);
                }
            }

            $('#successToast').toast('show');
            $('#errorToast').toast('show');
        });
    </script>
}