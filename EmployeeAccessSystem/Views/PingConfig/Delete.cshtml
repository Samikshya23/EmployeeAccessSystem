@model EmployeeAccessSystem.Models.PingConfig
@{
    Layout = null;
}

<form asp-action="Delete" method="post" id="deletePingConfigForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="pingConfigId" value="@Model.PingConfigId" />

    <div class="text-center">
        <h5 class="mb-2">Are you sure?</h5>
        <p class="mb-4">
            You want to delete this configuration
            <strong>"@Model.ServerHostName"</strong>
        </p>
    </div>

    <div class="modal-footer justify-content-center border-0 pt-0">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-danger">Confirm</button>
    </div>
</form>