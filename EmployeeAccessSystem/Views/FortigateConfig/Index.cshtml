@model IEnumerable<EmployeeAccessSystem.Models.FortigateConfig>
@using System.Collections.Generic

@{
    ViewData["Title"] = "Fortigate Config List";
    int sn = 1;
    var shownCategoryNames = new List<string>();
}

<section class="content pt-2 pb-0">
    <div class="container-fluid px-0">

        <div class="row mb-2 mx-0 align-items-center">
            <div class="col-sm-6 px-0">
                <h3 class="mb-0">Fortigate Config List</h3>
            </div>
            <div class="col-sm-6 text-right px-0">
                <a asp-action="Create"
                   class="btn btn-primary rounded-pill open-modal-btn"
                   data-title="Add Fortigate Config">
                    <i class="fas fa-plus mr-1"></i> Add
                </a>
            </div>
        </div>

        <div class="card mb-0 border-left border-right border-bottom shadow-none rounded-0">

            <div class="card-header bg-white border-bottom-0 py-2 px-2 rounded-0">
                <div class="row mx-0 align-items-center">
                    <div class="col-md-6 px-0">
                        <div class="d-flex align-items-center">
                            <span class="mr-2">Show</span>
                            <select id="entriesPerPage" class="custom-select custom-select-sm w-auto">
                                <option value="10" selected>10</option>
                                <option value="15">15</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                            </select>
                            <span class="ml-2">entries</span>
                        </div>
                    </div>

                    <div class="col-md-6 px-0 mt-2 mt-md-0">
                        <div class="d-flex justify-content-md-end">
                            <div style="width:220px;">
                                <input type="text"
                                       id="customSearch"
                                       class="form-control form-control-sm"
                                       placeholder="Search" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                <table id="fortigateConfigTable"
                       class="table table-bordered table-hover table-sm mb-0 rounded-0"
                       style="border-color:#dee2e6; table-layout:fixed; width:100%;">

                    <thead class="bg-light border-bottom">
                        <tr>
                            <th class="text-center align-middle sticky-top bg-light sort-header"
                                data-sort="sn"
                                style="width:60px; z-index:2; cursor:pointer;">
                                SN
                                <span class="ml-1 sort-icon" data-for="sn" style="display:inline-flex; align-items:center;">
                                    <span class="sort-up" style="font-size:13px; line-height:1; color:#bcbcbc;">↑</span>
                                    <span class="sort-down" style="font-size:13px; line-height:1; color:#bcbcbc;">↓</span>
                                </span>
                            </th>

                            <th class="text-center align-middle sticky-top bg-light sort-header"
                                data-sort="category"
                                style="width:18%; z-index:2; cursor:pointer;">
                                Category
                                <span class="ml-1 sort-icon" data-for="category" style="display:inline-flex; align-items:center;">
                                    <span class="sort-up" style="font-size:13px; line-height:1; color:#bcbcbc;">↑</span>
                                    <span class="sort-down" style="font-size:13px; line-height:1; color:#bcbcbc;">↓</span>
                                </span>
                            </th>

                            <th class="text-center align-middle sticky-top bg-light"
                                style="width:20%; z-index:2;">
                                Item
                            </th>

                            <th class="text-center align-middle sticky-top bg-light sort-header"
                                data-sort="date"
                                style="width:12%; z-index:2; cursor:pointer;">
                                Date
                                <span class="ml-1 sort-icon" data-for="date" style="display:inline-flex; align-items:center;">
                                    <span class="sort-up" style="font-size:13px; line-height:1; color:#bcbcbc;">↑</span>
                                    <span class="sort-down" style="font-size:13px; line-height:1; color:#bcbcbc;">↓</span>
                                </span>
                            </th>

                            <th class="text-center align-middle sticky-top bg-light sort-header"
                                data-sort="user"
                                style="width:24%; z-index:2; cursor:pointer;">
                                User
                                <span class="ml-1 sort-icon" data-for="user" style="display:inline-flex; align-items:center;">
                                    <span class="sort-up" style="font-size:13px; line-height:1; color:#bcbcbc;">↑</span>
                                    <span class="sort-down" style="font-size:13px; line-height:1; color:#bcbcbc;">↓</span>
                                </span>
                            </th>

                            <th class="text-center align-middle sticky-top bg-light sort-header"
                                data-sort="status"
                                style="width:90px; z-index:2; cursor:pointer;">
                                Status
                                <span class="ml-1 sort-icon" data-for="status" style="display:inline-flex; align-items:center;">
                                    <span class="sort-up" style="font-size:13px; line-height:1; color:#bcbcbc;">↑</span>
                                    <span class="sort-down" style="font-size:13px; line-height:1; color:#bcbcbc;">↓</span>
                                </span>
                            </th>

                            <th class="text-center align-middle sticky-top bg-light"
                                style="width:90px; z-index:2;">
                                Active
                            </th>

                            <th class="text-center align-middle sticky-top bg-light text-nowrap"
                                style="width:110px; z-index:2;">
                                Actions
                            </th>
                        </tr>
                    </thead>

                    <tbody id="fortigateConfigTableBody">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var category in Model)
                            {
                                if (!shownCategoryNames.Contains(category.CategoryName))
                                {
                                    shownCategoryNames.Add(category.CategoryName);

                                    var groupItems = new List<EmployeeAccessSystem.Models.FortigateConfig>();

                                    foreach (var item in Model)
                                    {
                                        if (item.CategoryName == category.CategoryName)
                                        {
                                            groupItems.Add(item);
                                        }
                                    }

                                    string combinedSearchText = "";
                                    bool firstText = true;
                                    string groupKey = "group_" + sn;

                                    DateTime latestDate = groupItems[0].EntryDate;
                                    string firstUser = "";
                                    bool firstUserFound = false;
                                    string firstStatus = "";

                                    foreach (var groupItem in groupItems)
                                    {
                                        if (groupItem.EntryDate > latestDate)
                                        {
                                            latestDate = groupItem.EntryDate;
                                        }

                                        if (!firstUserFound && !string.IsNullOrWhiteSpace(groupItem.CreatedBy))
                                        {
                                            firstUser = groupItem.CreatedBy;
                                            firstUserFound = true;
                                        }

                                        if (string.IsNullOrWhiteSpace(firstStatus) && !string.IsNullOrWhiteSpace(groupItem.ConfigValue))
                                        {
                                            firstStatus = groupItem.ConfigValue;
                                        }

                                        string statusText = string.IsNullOrWhiteSpace(groupItem.ConfigValue) ? "-" : groupItem.ConfigValue;
                                        string dateText = groupItem.EntryDate.ToString("dd-MM-yyyy");
                                        string userText = string.IsNullOrWhiteSpace(groupItem.CreatedBy) ? "-" : groupItem.CreatedBy;

                                        string rowText =
                                            groupItem.CategoryName + " " +
                                            groupItem.ItemName + " " +
                                            dateText + " " +
                                            userText + " " +
                                            statusText + " " +
                                            (groupItem.IsActive ? "Active" : "Inactive");

                                        if (firstText)
                                        {
                                            combinedSearchText = rowText;
                                            firstText = false;
                                        }
                                        else
                                        {
                                            combinedSearchText = combinedSearchText + " " + rowText;
                                        }
                                    }

                                    if (string.IsNullOrWhiteSpace(firstUser))
                                    {
                                        firstUser = "-";
                                    }

                                    if (string.IsNullOrWhiteSpace(firstStatus))
                                    {
                                        firstStatus = "-";
                                    }

                                    <tr class="group-row"
                                        data-search="@combinedSearchText"
                                        data-group="@groupKey"
                                        data-sn="@sn"
                                        data-category="@category.CategoryName"
                                        data-date="@latestDate.ToString("yyyyMMdd")"
                                        data-user="@firstUser"
                                        data-status="@firstStatus">
                                        <td class="text-center align-middle p-0 group-sn">
                                            <div class="d-flex align-items-center justify-content-center px-2 group-sn-wrap" style="height:136px;">
                                                @sn
                                            </div>
                                        </td>

                                        <td class="align-middle p-0">
                                            <div class="d-flex align-items-center px-2 group-category-wrap" style="height:136px;">
                                                @if (groupItems.Count > 4)
                                                {
                                                    <a href="javascript:void(0);"
                                                       class="text-dark mr-2 group-toggle-btn"
                                                       data-group="@groupKey"
                                                       data-expanded="false"
                                                       title="Expand"
                                                       style="display:flex; align-items:center; line-height:1;">
                                                        <i class="fas fa-caret-right"></i>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="mr-3"></span>
                                                }

                                                <span>@category.CategoryName</span>
                                            </div>
                                        </td>

                                        <td class="p-0 align-top">
                                            <table class="table table-sm mb-0" style="table-layout:fixed; width:100%;">
                                                <tbody>
                                                    @for (int i = 0; i < groupItems.Count; i++)
                                                    {
                                                        string hiddenClass = i >= 4 ? "d-none extra-row " + groupKey : "";
                                                        <tr class="child-row @hiddenClass" data-row-index="@i">
                                                            <td class="p-0 align-middle @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                                <div class="d-flex align-items-center px-2" style="height:34px;">
                                                                    @groupItems[i].ItemName
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </td>

                                        <td class="p-0 align-top">
                                            <table class="table table-sm mb-0" style="table-layout:fixed; width:100%;">
                                                <tbody>
                                                    @for (int i = 0; i < groupItems.Count; i++)
                                                    {
                                                        string hiddenClass = i >= 4 ? "d-none extra-row " + groupKey : "";
                                                        <tr class="child-row @hiddenClass" data-row-index="@i">
                                                            <td class="p-0 align-middle text-center @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                                <div class="d-flex justify-content-center align-items-center px-2" style="height:34px;">
                                                                    @groupItems[i].EntryDate.ToString("dd-MM-yyyy")
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </td>

                                        <td class="p-0 align-top">
                                            <table class="table table-sm mb-0" style="table-layout:fixed; width:100%;">
                                                <tbody>
                                                    @for (int i = 0; i < groupItems.Count; i++)
                                                    {
                                                        string hiddenClass = i >= 4 ? "d-none extra-row " + groupKey : "";
                                                        string createdByText = string.IsNullOrWhiteSpace(groupItems[i].CreatedBy) ? "-" : groupItems[i].CreatedBy;

                                                        <tr class="child-row @hiddenClass" data-row-index="@i">
                                                            <td class="p-0 align-middle @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                                @if (createdByText == "-")
                                                                {
                                                                    <div class="d-flex justify-content-center align-items-center" style="height:34px;">
                                                                        -
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <div class="px-2"
                                                                         style="height:34px; line-height:34px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"
                                                                         title="@createdByText">
                                                                        @createdByText
                                                                    </div>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </td>

                                        <td class="p-0 align-top">
                                            <table class="table table-sm mb-0" style="table-layout:fixed; width:100%;">
                                                <tbody>
                                                    @for (int i = 0; i < groupItems.Count; i++)
                                                    {
                                                        string hiddenClass = i >= 4 ? "d-none extra-row " + groupKey : "";
                                                        string valueText = string.IsNullOrWhiteSpace(groupItems[i].ConfigValue) ? "-" : groupItems[i].ConfigValue;

                                                        <tr class="child-row @hiddenClass" data-row-index="@i">
                                                            <td class="p-0 align-middle text-center @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                                <div class="px-2" style="height:34px; line-height:34px; white-space:nowrap;">
                                                                    @valueText
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </td>

                                        <td class="p-0 align-top">
                                            <table class="table table-sm mb-0" style="table-layout:fixed; width:100%;">
                                                <tbody>
                                                    @for (int i = 0; i < groupItems.Count; i++)
                                                    {
                                                        string hiddenClass = i >= 4 ? "d-none extra-row " + groupKey : "";
                                                        <tr class="child-row @hiddenClass" data-row-index="@i">
                                                            <td class="p-0 align-middle text-center @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                                <div class="d-flex justify-content-center align-items-center px-2" style="height:34px;">
                                                                    @if (groupItems[i].IsActive)
                                                                    {
                                                                        <span class="badge badge-success">Active</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="badge badge-secondary">Inactive</span>
                                                                    }
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </td>

                                        <td class="p-0 align-top">
                                            <table class="table table-sm mb-0" style="table-layout:fixed; width:100%;">
                                                <tbody>
                                                    @for (int i = 0; i < groupItems.Count; i++)
                                                    {
                                                        string hiddenClass = i >= 4 ? "d-none extra-row " + groupKey : "";
                                                        <tr class="child-row @hiddenClass" data-row-index="@i">
                                                            <td class="p-0 align-middle text-center @(i != groupItems.Count - 1 ? "border-bottom" : "")">
                                                                <div class="d-flex justify-content-center align-items-center" style="height:34px; gap:3px;">
                                                                    <a asp-action="Edit"
                                                                       asp-route-id="@groupItems[i].FortigateConfigId"
                                                                       class="btn btn-light border open-modal-btn p-0"
                                                                       data-title="Edit Fortigate Config"
                                                                       title="Edit"
                                                                       style="width:24px; height:24px; line-height:22px;">
                                                                        <i class="fas fa-pen" style="font-size:10px;"></i>
                                                                    </a>

                                                                    <a asp-action="Delete"
                                                                       asp-route-id="@groupItems[i].FortigateConfigId"
                                                                       class="btn btn-outline-danger open-modal-btn p-0"
                                                                       data-title="Delete Fortigate Config"
                                                                       title="Delete"
                                                                       style="width:24px; height:24px; line-height:22px;">
                                                                        <i class="fas fa-trash-alt" style="font-size:10px;"></i>
                                                                    </a>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </td>
                                    </tr>

                                    sn++;
                                }
                            }
                        }
                        else
                        {
                            <tr id="noDataRow">
                                <td colspan="8" class="text-center align-middle">No Fortigate Config entries found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="row mt-2 mx-0 align-items-center">
            <div class="col-md-6 px-0">
                <div id="paginationInfo" class="text-muted"></div>
            </div>
            <div class="col-md-6 text-right px-0 mt-2 mt-md-0">
                <nav>
                    <ul class="pagination pagination-sm justify-content-md-end mb-0" id="customPagination"></ul>
                </nav>
            </div>
        </div>

    </div>
</section>

<div class="modal fade" id="mainActionModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered" role="document">
        <div class="modal-content rounded-0">
            <div class="modal-header">
                <h5 class="modal-title" id="mainActionModalTitle">Fortigate Config</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body" id="mainActionModalBody">
                <div class="text-center py-3">
                    <i class="fas fa-spinner fa-spin mr-2"></i> Loading...
                </div>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <div class="position-fixed" style="top: 15px; right: 15px; z-index: 1055;">
        @if (TempData["Success"] != null)
        {
            <div class="toast bg-success text-white fade" id="successToast" data-delay="3000">
                <div class="toast-header bg-success text-white border-0">
                    <strong class="mr-auto">Success</strong>
                    <small>Now</small>
                    <button type="button" class="close text-white" data-dismiss="toast">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="toast-body">
                    @TempData["Success"]
                </div>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="toast bg-danger text-white fade" id="errorToast" data-delay="4000">
                <div class="toast-header bg-danger text-white border-0">
                    <strong class="mr-auto">Error</strong>
                    <small>Now</small>
                    <button type="button" class="close text-white" data-dismiss="toast">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="toast-body">
                    @TempData["Error"]
                </div>
            </div>
        }
    </div>
}

@section Scripts {
<script>
    $(document).ready(function () {

        var rowsPerPage = parseInt($('#entriesPerPage').val());
        var currentPage = 1;
        var currentSortColumn = 'sn';
        var currentSortDirection = 'asc';

        function getFilteredRows() {
            var searchText = $('#customSearch').val().toLowerCase().trim();
            var filteredRows = [];

            $('#fortigateConfigTableBody tr.group-row').each(function () {
                var rowSearchText = ($(this).attr('data-search') || '').toLowerCase();

                if (searchText === '' || rowSearchText.indexOf(searchText) > -1) {
                    filteredRows.push(this);
                }
            });

            return filteredRows;
        }

        function updateSerialNumbers(filteredRows) {
            var i;
            for (i = 0; i < filteredRows.length; i++) {
                $(filteredRows[i]).find('.group-sn-wrap').text(i + 1);
            }
        }

        function syncGroupHeights() {
            $('#fortigateConfigTableBody tr.group-row:visible').each(function () {
                var $row = $(this);
                var visibleRowCount = 0;

                $row.find('td:eq(2) tbody tr').each(function () {
                    if (!$(this).hasClass('d-none')) {
                        visibleRowCount++;
                    }
                });

                if (visibleRowCount < 1) {
                    visibleRowCount = 1;
                }

                var calculatedHeight = visibleRowCount * 34;

                $row.find('.group-sn-wrap').css('height', calculatedHeight + 'px');
                $row.find('.group-category-wrap').css('height', calculatedHeight + 'px');
            });
        }

        function sortRows(rows) {
            rows.sort(function (a, b) {

                var valueA = $(a).attr('data-' + currentSortColumn) || '';
                var valueB = $(b).attr('data-' + currentSortColumn) || '';

                if (currentSortColumn === 'sn' || currentSortColumn === 'date') {
                    valueA = parseInt(valueA);
                    valueB = parseInt(valueB);
                } else {
                    valueA = valueA.toLowerCase();
                    valueB = valueB.toLowerCase();
                }

                if (valueA < valueB) {
                    return currentSortDirection === 'asc' ? -1 : 1;
                }

                if (valueA > valueB) {
                    return currentSortDirection === 'asc' ? 1 : -1;
                }

                return 0;
            });

            return rows;
        }

        function updateSortIcons() {
            $('.sort-icon').each(function () {
                $(this).find('.sort-up').css('color', '#bcbcbc');
                $(this).find('.sort-down').css('color', '#bcbcbc');
            });

            var activeIcon = $('.sort-icon[data-for="' + currentSortColumn + '"]');

            if (currentSortDirection === 'asc') {
                activeIcon.find('.sort-up').css('color', '#1f2d3d');
            } else {
                activeIcon.find('.sort-down').css('color', '#1f2d3d');
            }
        }

        function renderPagination() {
            var filteredRows = getFilteredRows();
            filteredRows = sortRows(filteredRows);

            var totalRows = filteredRows.length;
            var totalPages = Math.ceil(totalRows / rowsPerPage);

            $('#fortigateConfigTableBody tr.group-row').hide();

            if (totalRows === 0) {
                $('#paginationInfo').text('No matching entries found.');
                $('#customPagination').html('');
                return;
            }

            updateSerialNumbers(filteredRows);

            if (currentPage > totalPages) {
                currentPage = 1;
            }

            var startIndex = (currentPage - 1) * rowsPerPage;
            var endIndex = startIndex + rowsPerPage;
            var i;

            for (i = startIndex; i < endIndex && i < totalRows; i++) {
                $(filteredRows[i]).show();
            }

            var fromRecord = startIndex + 1;
            var toRecord = endIndex;

            if (toRecord > totalRows) {
                toRecord = totalRows;
            }

            $('#paginationInfo').text('Showing ' + fromRecord + ' to ' + toRecord + ' of ' + totalRows + ' grouped entries');

            var paginationHtml = '';
            var page;

            if (currentPage > 1) {
                paginationHtml += '<li class="page-item"><a href="#" class="page-link pagination-link" data-page="' + (currentPage - 1) + '">Previous</a></li>';
            } else {
                paginationHtml += '<li class="page-item disabled"><span class="page-link">Previous</span></li>';
            }

            for (page = 1; page <= totalPages; page++) {
                if (page === currentPage) {
                    paginationHtml += '<li class="page-item active"><span class="page-link">' + page + '</span></li>';
                } else {
                    paginationHtml += '<li class="page-item"><a href="#" class="page-link pagination-link" data-page="' + page + '">' + page + '</a></li>';
                }
            }

            if (currentPage < totalPages) {
                paginationHtml += '<li class="page-item"><a href="#" class="page-link pagination-link" data-page="' + (currentPage + 1) + '">Next</a></li>';
            } else {
                paginationHtml += '<li class="page-item disabled"><span class="page-link">Next</span></li>';
            }

            $('#customPagination').html(paginationHtml);

            updateSortIcons();
            syncGroupHeights();
        }

        $('#customSearch').on('keyup', function () {
            currentPage = 1;
            renderPagination();
        });

        $('#entriesPerPage').on('change', function () {
            rowsPerPage = parseInt($(this).val());
            currentPage = 1;
            renderPagination();
        });

        $(document).on('click', '.pagination-link', function (e) {
            e.preventDefault();
            currentPage = parseInt($(this).data('page'));
            renderPagination();
        });

        $(document).on('click', '.sort-header', function () {
            var clickedColumn = $(this).data('sort');

            if (currentSortColumn === clickedColumn) {
                currentSortDirection = currentSortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                currentSortColumn = clickedColumn;
                currentSortDirection = 'asc';
            }

            currentPage = 1;
            renderPagination();
        });

        $(document).on('click', '.group-toggle-btn', function (e) {
            e.preventDefault();

            var groupKey = $(this).data('group');
            var isExpanded = $(this).attr('data-expanded') === 'true';

            if (isExpanded) {
                $('.' + groupKey).addClass('d-none');
                $(this).attr('data-expanded', 'false');
                $(this).attr('title', 'Expand');
                $(this).find('i').removeClass('fa-caret-down').addClass('fa-caret-right');
            } else {
                $('.' + groupKey).removeClass('d-none');
                $(this).attr('data-expanded', 'true');
                $(this).attr('title', 'Collapse');
                $(this).find('i').removeClass('fa-caret-right').addClass('fa-caret-down');
            }

            syncGroupHeights();
        });

        renderPagination();

        function openFortigateConfigModal(url, title) {
            $('#mainActionModalTitle').text(title);
            $('#mainActionModalBody').html('<div class="text-center py-3"><i class="fas fa-spinner fa-spin mr-2"></i> Loading...</div>');

            $('#mainActionModalBody').load(url, function (response, status) {
                if (status === 'error') {
                    $('#mainActionModalBody').html('<div class="alert alert-danger mb-0">Failed to load data.</div>');
                    return;
                }

                $.validator.unobtrusive.parse('#mainActionModalBody');
            });

            $('#mainActionModal').modal('show');
        }

        $(document).on('click', '.open-modal-btn', function (e) {
            e.preventDefault();

            var url = $(this).attr('href');
            var title = $(this).data('title') || 'Fortigate Config';

            openFortigateConfigModal(url, title);
        });

        $(document).on('submit', '#createFortigateConfigForm', function (e) {
            e.preventDefault();

            var form = $(this);

            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: form.serialize(),
                success: function (response) {
                    if (typeof response === 'string' && response.indexOf('success|') === 0) {
                        location.reload();
                    } else {
                        $('#mainActionModalBody').html(response);
                        $.validator.unobtrusive.parse('#mainActionModalBody');
                    }
                }
            });
        });

        $(document).on('submit', '#editFortigateConfigForm', function (e) {
            e.preventDefault();

            var form = $(this);

            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: form.serialize(),
                success: function (response) {
                    if (typeof response === 'string' && response.indexOf('success|') === 0) {
                        location.reload();
                    } else {
                        $('#mainActionModalBody').html(response);
                        $.validator.unobtrusive.parse('#mainActionModalBody');
                    }
                }
            });
        });

        $(document).on('submit', '#deleteFortigateConfigForm', function (e) {
            e.preventDefault();

            var form = $(this);

            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: form.serialize(),
                success: function (response) {
                    if (typeof response === 'string' && response.indexOf('success|') === 0) {
                        location.reload();
                    } else {
                        $('#mainActionModalBody').html(response);
                    }
                }
            });
        });

        if ($('#successToast').length) {
            $('#successToast').toast('show');
        }

        if ($('#errorToast').length) {
            $('#errorToast').toast('show');
        }
    });
</script>
}