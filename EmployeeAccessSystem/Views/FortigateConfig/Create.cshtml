@model EmployeeAccessSystem.Models.FortigateConfig
@{
    Layout = null;
}

<form asp-action="Create" method="post" id="createFortigateConfigForm">
    @Html.AntiForgeryToken()

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="ProductId" class="font-weight-bold">Product</label>
                <select asp-for="ProductId"
                        asp-items="ViewBag.ProductList"
                        class="form-control select2bs4"
                        id="ProductId">
                </select>
                <span asp-validation-for="ProductId" class="text-danger small"></span>
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="FortigateCategoryId" class="font-weight-bold">Category</label>
                <select asp-for="FortigateCategoryId"
                        asp-items="ViewBag.CategoryList"
                        class="form-control select2bs4"
                        id="FortigateCategoryId">
                </select>
                <span asp-validation-for="FortigateCategoryId" class="text-danger small"></span>
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="FortigateItemId" class="font-weight-bold">Item</label>
                <select asp-for="FortigateItemId"
                        asp-items="ViewBag.ItemList"
                        class="form-control select2bs4"
                        id="FortigateItemId">
                </select>
                <span asp-validation-for="FortigateItemId" class="text-danger small"></span>
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="EntryDate" class="font-weight-bold">Entry Date</label>
                <input asp-for="EntryDate" type="date" class="form-control" />
                <span asp-validation-for="EntryDate" class="text-danger small"></span>
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="ConfigValue" class="font-weight-bold">Status</label>
                <select asp-for="ConfigValue"
                        asp-items="ViewBag.StatusList"
                        class="form-control"
                        id="ConfigValue">
                </select>
                <span asp-validation-for="ConfigValue" class="text-danger small"></span>
            </div>
        </div>

        <div class="col-12">
            <div class="form-group mb-2">
                <div class="custom-control custom-checkbox">
                    <input asp-for="IsActive" class="custom-control-input" id="CreateIsActive" />
                    <label class="custom-control-label font-weight-bold" for="CreateIsActive">Active Entry</label>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-footer px-0 pb-0 pt-2">
        <button type="button" class="btn btn-default" data-dismiss="modal">Back</button>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save mr-1"></i>Save Entry
        </button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />

<script>
    $(document).ready(function () {
        $('.select2bs4').select2({
            theme: 'bootstrap4',
            width: '100%',
            dropdownParent: $('#mainActionModal')
        });

        $("#ProductId").change(function () {
            var productId = $(this).val();

            $("#FortigateCategoryId").empty();
            $("#FortigateItemId").empty();

            if (productId !== "") {
                $.get('/FortigateConfig/GetCategoriesByProductId', { productId: productId }, function (data) {
                    $.each(data, function (i, item) {
                        $("#FortigateCategoryId").append('<option value="' + item.fortigateCategoryId + '">' + item.categoryName + '</option>');
                    });

                    if (data.length > 0) {
                        $("#FortigateCategoryId").val(data[0].fortigateCategoryId).trigger('change');
                    }
                });
            }
        });

        $("#FortigateCategoryId").change(function () {
            var fortigateCategoryId = $(this).val();

            $("#FortigateItemId").empty();

            if (fortigateCategoryId !== "") {
                $.get('/FortigateConfig/GetItemsByCategoryId', { fortigateCategoryId: fortigateCategoryId }, function (data) {
                    $.each(data, function (i, item) {
                        $("#FortigateItemId").append('<option value="' + item.fortigateItemId + '">' + item.itemName + '</option>');
                    });

                    if (data.length > 0) {
                        $("#FortigateItemId").val(data[0].fortigateItemId);
                    }
                });
            }
        });
    });
</script>